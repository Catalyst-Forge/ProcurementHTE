@{
    ViewData["Title"] = "PR Tracking";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <!-- Header -->
            <div class="text-center mb-4">
                <div class="bg-primary bg-opacity-10 d-inline-flex align-items-center justify-content-center rounded-circle mb-3" style="width: 64px; height: 64px;">
                    <i class="bi bi-search fs-4 text-primary"></i>
                </div>
                <h4 class="fw-bold mb-1">Track Purchase Requisition</h4>
                <p class="text-muted small">Masukkan nomor PR untuk melihat status</p>
            </div>
            
            <!-- Search Card -->
            <div class="card border-0 shadow-sm">
                <div class="card-body p-4">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger d-flex align-items-center py-2" role="alert">
                            <i class="bi bi-exclamation-circle me-2"></i>
                            <small>@TempData["Error"]</small>
                        </div>
                    }

                    <form asp-action="Search" method="post" class="needs-validation" novalidate>
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label for="prNumber" class="form-label small fw-medium">Nomor PR</label>
                                    <i class="bi bi-hash text-muted"></i>
                                <input type="text"
                                       class="form-control border-start-5 ps-0"
                                       id="prNumber"
                                       name="prNumber"
                                       placeholder="PR-2024-001"
                                       required
                                       autofocus>
                            <div class="invalid-feedback">Nomor PR wajib diisi.</div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search me-2"></i>Cari
                        </button>
                    </form>
                </div>
            </div>
            
            <!-- Tips -->
            <div class="mt-4">
                <p class="text-muted small mb-2">
                    <i class="bi bi-lightbulb me-1"></i> Tips:
                </p>
                <ul class="text-muted small ps-4 mb-0">
                    <li>Masukkan nomor PR lengkap</li>
                    <li>Bisa juga scan QR code pada dokumen</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms).forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    if (!form.checkValidity()) {
                        event.preventDefault()
                        event.stopPropagation()
                    }
                    form.classList.add('was-validated')
                }, false)
            })
        })()
    </script>
}
