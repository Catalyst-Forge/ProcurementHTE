@model ProcurementHTE.Core.Models.DTOs.PRTrackingDto

@{
    ViewData["Title"] = $"Tracking - {Model.PrNumber}";
}

<div class="container-fluid py-4">
    <header class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="h3 mb-0">Tracking Details</h1>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i>
                Kembali ke Pencarian
            </a>
        </div>
    </header>
    <div class="row">
        <!-- PR Info Card -->
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-info-circle me-2"></i>
                        Informasi PR
                    </h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm table-borderless">
                        <tbody>
                            <tr>
                                <td class="text-muted" width="40%">PR Number:</td>
                                <td class="fw-bold">@Model.PrNumber</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Request Date:</td>
                                <td>@Model.RequestDate.ToString("dd MMM yyyy")</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Created By:</td>
                                <td>@Model.CreatedByFullName</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Description:</td>
                                <td>@Model.Description</td>
                            </tr>
                            <tr>
                                <td class="text-muted">Current Status:</td>
                                <td>
                                    @if (Model.CurrentStatus == ProcurementHTE.Core.Enums.PurchaseRequisitionStatus.Rejected)
                                    {
                                        <span class="badge bg-danger">@Model.CurrentStatusDescription</span>
                                    }
                                    else if (Model.CurrentStatus == ProcurementHTE.Core.Enums.PurchaseRequisitionStatus.DonePO)
                                    {
                                        <span class="badge bg-success">@Model.CurrentStatusDescription</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary">@Model.CurrentStatusDescription</span>
                                    }
                                </td>
                            </tr>
                        </tbody>
                    </table>

                    <!-- Additional Info -->
                    @if (!string.IsNullOrEmpty(Model.IspaNumber))
                    {
                        <hr>
                        <div class="mb-2">
                            <small class="text-muted">ISPA Number:</small>
                            <div class="fw-bold">@Model.IspaNumber</div>
                            <small class="text-muted">Submitted: @Model.IspaSubmittedAt?.ToString("dd MMM yyyy HH:mm")</small>
                        </div>
                    }

                    @if (!string.IsNullOrEmpty(Model.PoNumber))
                    {
                        <hr>
                        <div class="mb-2">
                            <small class="text-muted">PO Number:</small>
                            <div class="fw-bold">@Model.PoNumber</div>
                            <small class="text-muted">Submitted: @Model.PoSubmittedAt?.ToString("dd MMM yyyy HH:mm")</small>
                        </div>
                    }
                </div>
            </div>

            <!-- QR Code / Barcode Card -->
            <div class="card shadow-sm mt-4">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-qr-code me-2"></i>
                        QR Code
                    </h5>
                </div>
                <div class="card-body text-center">
                    <div id="qrcode" class="mb-3 d-flex justify-content-center"></div>
                    <p class="small text-muted mb-0">
                        Scan QR code ini untuk approval via mobile app
                    </p>
                    <div class="mt-3">
                        <code class="bg-light p-2 rounded">@Model.PrNumber</code>
                    </div>
                </div>
            </div>
        </div>

        <!-- Progress Tracker -->
        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">
                        <i class="bi bi-list-task me-2"></i>
                        Progress Tracking
                    </h5>
                </div>
                <div class="card-body">
                    @await Html.PartialAsync("_PRProgressBar", Model)
                </div>
            </div>
        </div>
    </div>

    <!-- Status History -->
    @if (Model.StatusHistory.Any())
    {
        <div class="row">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-clock-history me-2"></i>
                            Status History
                        </h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Date & Time</th>
                                        <th>Status</th>
                                        <th>Changed By</th>
                                        <th>Note</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var history in Model.StatusHistory.OrderByDescending(h => h.ChangedAt))
                                    {
                                        <tr>
                                            <td>@history.ChangedAt.ToString("dd MMM yyyy HH:mm")</td>
                                            <td>
                                                <span class="badge bg-info">@history.StatusDescription</span>
                                            </td>
                                            <td>@history.ChangedByFullName</td>
                                            <td>@history.Note</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <!-- QR Code Library with integrity check -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js" 
            integrity="sha512-CNgIRecGo7nphbeZ04Sc13ka07paqdeTu0WR1IM4kNcpmBAUSHSQX0FslNhTDadL4O5SAGapGt4FodqL8My0mA==" 
            crossorigin="anonymous" 
            referrerpolicy="no-referrer"></script>
    <script>
        (function() {
            function generateQRCode() {
                var qrContainer = document.getElementById("qrcode");
                var prNumber = "@Html.Raw(Model.PrNumber)";
                
                if (!qrContainer) {
                    console.error("QR container not found");
                    return;
                }
                
                // Clear any existing content
                qrContainer.innerHTML = '';
                
                // Check if QRCode library is loaded
                if (typeof QRCode === 'undefined') {
                    console.error("QRCode library not loaded, retrying...");
                    // Show loading indicator
                    qrContainer.innerHTML = '<div class="spinner-border text-secondary" role="status"><span class="visually-hidden">Loading...</span></div>';
                    // Retry after a delay
                    setTimeout(generateQRCode, 500);
                    return;
                }
                
                try {
                    new QRCode(qrContainer, {
                        text: prNumber,
                        width: 200,
                        height: 200,
                        colorDark: "#000000",
                        colorLight: "#ffffff",
                        correctLevel: QRCode.CorrectLevel.H
                    });
                } catch (e) {
                    console.error("Error generating QR code:", e);
                    qrContainer.innerHTML = '<div class="alert alert-warning"><i class="bi bi-exclamation-triangle me-2"></i>Gagal memuat QR Code. <button class="btn btn-sm btn-outline-secondary ms-2" onclick="location.reload()">Refresh</button></div>';
                }
            }
            
            // Wait for DOM to be ready
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', function() {
                    // Additional delay to ensure library is loaded
                    setTimeout(generateQRCode, 100);
                });
            } else {
                // DOM is already ready
                setTimeout(generateQRCode, 100);
            }
        })();
    </script>
}
