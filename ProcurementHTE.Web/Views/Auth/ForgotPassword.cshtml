@model ProcurementHTE.Web.Models.Auth.ForgotPasswordPageViewModel
@{
    ViewData["Title"] = "Lupa Password";
    Layout = "_AuthenticationLayout";
    var activeTab = (Model.ActiveTab ?? "recovery").ToLowerInvariant();
}

@await Html.PartialAsync("Partials/_ForgotHeaderTabs", Model)

<div class="tab-content">
    @await Html.PartialAsync("Partials/_ForgotRecoveryForm", Model)
    @await Html.PartialAsync("Partials/_ForgotEmailForm", Model)
    @await Html.PartialAsync("Partials/_ForgotSmsForm", Model)
</div>

<div class="text-center mt-4">
    <a asp-action="Login" class="link-secondary">Kembali ke halaman login</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @await Html.PartialAsync("Partials/_OtpScript")
    @await Html.PartialAsync("Partials/_ForgotScripts")
}
