@model ProcurementHTE.Web.Models.Auth.TwoFactorSetupViewModel
@{
    ViewData["Title"] = "Aktifkan Two-Factor";
    Layout = "_AuthenticationLayout";
}

<div class="twofactor-setup-page">
    @await Html.PartialAsync("Partials/_TwoFactorSetupTabs", Model)

    <div class="tab-content twofactor-setup-content">
        @await Html.PartialAsync("Partials/_TwoFactorSetupAuth", Model)
        @await Html.PartialAsync("Partials/_TwoFactorSetupEmail", Model)
        @await Html.PartialAsync("Partials/_TwoFactorSetupSms", Model)
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @await Html.PartialAsync("Partials/_OtpScript")
    @await Html.PartialAsync("Partials/_TwoFactorSetupScripts")
}
