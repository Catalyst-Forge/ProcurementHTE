@model ProcurementHTE.Core.Models.Procurement
@{
    ViewData["Title"] = "AR Pickup Details";
}

<header class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">AR Pickup Details</h1>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</header>

<div class="row">
    <div class="col-lg-8">
        <div class="card mb-3">
            <div class="card-header bg-primary text-white">
                <h5 class="card-title mb-0"><i class="bi bi-info-circle"></i> Procurement Information</h5>
            </div>
            <div class="card-body">
                <div class="row mb-2">
                    <div class="col-md-4 fw-semibold">Procurement No:</div>
                    <div class="col-md-8">@Model.ProcNum</div>
                </div>
                <div class="row mb-2">
                    <div class="col-md-4 fw-semibold">Job Name:</div>
                    <div class="col-md-8">@Model.JobName</div>
                </div>
                <div class="row mb-2">
                    <div class="col-md-4 fw-semibold">WO Number:</div>
                    <div class="col-md-8">@(Model.Wonum ?? "-")</div>
                </div>
                <div class="row mb-2">
                    <div class="col-md-4 fw-semibold">SPK Number:</div>
                    <div class="col-md-8">@(Model.SpkNumber ?? "-")</div>
                </div>
                <div class="row mb-2">
                    <div class="col-md-4 fw-semibold">Job Type:</div>
                    <div class="col-md-8">@(Model.JobType?.TypeName ?? "-")</div>
                </div>
                <div class="row mb-2">
                    <div class="col-md-4 fw-semibold">Start Date:</div>
                    <div class="col-md-8">@(Model.StartDate == default ? "-" : Model.StartDate.ToString("dd MMM yyyy"))</div>
                </div>
                <div class="row mb-2">
                    <div class="col-md-4 fw-semibold">End Date:</div>
                    <div class="col-md-8">@(Model.EndDate == default ? "-" : Model.EndDate.ToString("dd MMM yyyy"))</div>
                </div>
                @if (Model.ProfitLosses?.Any() == true)
                {
                    var pl = Model.ProfitLosses.First();
                    <div class="row mb-2">
                        <div class="col-md-4 fw-semibold">Selected Vendor:</div>
                        <div class="col-md-8">@(pl.SelectedVendor?.VendorName ?? "-")</div>
                    </div>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-header bg-info text-white">
                <h5 class="card-title mb-0"><i class="bi bi-calculator"></i> Accrual Data</h5>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrEmpty(Model.NoAccrual))
                {
                    <div class="alert alert-success">
                        <i class="bi bi-check-circle"></i> <strong>Accrual data has been filled</strong>
                    </div>

                    <div class="row mb-2">
                        <div class="col-md-4 fw-semibold">No Accrual:</div>
                        <div class="col-md-8">@Model.NoAccrual</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-4 fw-semibold">Potensi Accrual:</div>
                        <div class="col-md-8">@((Model.PotensiAccrual?.ToString("N0") ?? "-") + " Rp")</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-md-4 fw-semibold">Status Accrual:</div>
                        <div class="col-md-8">@(Model.StatusAccrual ?? "-")</div>
                    </div>

                    @if (Model.AccrualFilledByUser != null)
                    {
                        <div class="row mb-2">
                            <div class="col-md-4 fw-semibold">Filled By:</div>
                            <div class="col-md-8">
                                @Model.AccrualFilledByUser.FullName
                                @if (Model.AccrualFilledAt.HasValue)
                                {
                                    <br /><small class="text-muted">on @Model.AccrualFilledAt.Value.ToString("dd MMM yyyy HH:mm")</small>
                                }
                            </div>
                        </div>
                    }

                    <div class="mt-3">
                        <a asp-controller="Accrual" asp-action="Index" class="btn btn-primary">
                            <i class="bi bi-pencil"></i> Edit Accrual Data
                        </a>
                    </div>
                }
                else
                {
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle"></i> <strong>Accrual data has not been filled yet</strong>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.ArUserId))
                    {
                        <p class="text-muted mb-3">This procurement has been picked up by AR. Please fill in the accrual data using the Data Accrual menu.</p>
                        <div class="d-grid">
                            <a asp-controller="Accrual" asp-action="Index" class="btn btn-primary">
                                <i class="bi bi-calculator"></i> Go to Data Accrual
                            </a>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Pickup this procurement first to fill accrual data.</p>
                    }
                }
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-header bg-secondary text-white">
                <h5 class="card-title mb-0"><i class="bi bi-clock-history"></i> Pickup History</h5>
            </div>
            <div class="card-body">
                @if (Model.AppoUser != null)
                {
                    <div class="mb-3">
                        <h6 class="text-muted mb-1">AP-PO Pickup</h6>
                        <div><i class="bi bi-person"></i> @Model.AppoUser.FullName</div>
                        @if (Model.PickedUpAt.HasValue)
                        {
                            <small class="text-muted">
                                <i class="bi bi-calendar"></i> @Model.PickedUpAt.Value.ToString("dd MMM yyyy HH:mm")
                            </small>
                        }
                    </div>
                }

                @if (Model.ApInvoiceUser != null)
                {
                    <div class="mb-3">
                        <h6 class="text-muted mb-1">AP-Invoice Pickup</h6>
                        <div><i class="bi bi-person"></i> @Model.ApInvoiceUser.FullName</div>
                        @if (Model.ApInvoicePickedUpAt.HasValue)
                        {
                            <small class="text-muted">
                                <i class="bi bi-calendar"></i> @Model.ApInvoicePickedUpAt.Value.ToString("dd MMM yyyy HH:mm")
                            </small>
                        }
                    </div>
                }

                @if (Model.ArUser != null)
                {
                    <div class="mb-3">
                        <h6 class="text-muted mb-1">AR Pickup</h6>
                        <div><i class="bi bi-person"></i> @Model.ArUser.FullName</div>
                        @if (Model.ArPickedUpAt.HasValue)
                        {
                            <small class="text-muted">
                                <i class="bi bi-calendar"></i> @Model.ArPickedUpAt.Value.ToString("dd MMM yyyy HH:mm")
                            </small>
                        }
                    </div>
                }

                @if (Model.AppoUser == null && Model.ApInvoiceUser == null && Model.ArUser == null)
                {
                    <p class="text-muted">No pickup history available</p>
                }
            </div>
        </div>

        @if (Model.SANo != null || Model.SP3No != null)
        {
            <div class="card mt-3">
                <div class="card-header bg-warning text-dark">
                    <h5 class="card-title mb-0"><i class="bi bi-receipt"></i> Invoice Info</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-2">
                        <div class="col-5 fw-semibold">SA No:</div>
                        <div class="col-7">@(Model.SANo ?? "-")</div>
                    </div>
                    <div class="row mb-2">
                        <div class="col-5 fw-semibold">SP 3 No:</div>
                        <div class="col-7">@(Model.SP3No ?? "-")</div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
