@model PurchaseRequisitionDocumentRowViewModel

@{
    var doc = Model.Document;
}

<tr class="@(Model.IsApproved ? "table-success" : Model.IsPending ? "table-warning" : "")"
    data-doc-id="@doc.ProcDocumentId"
    data-row-index="@Model.RowIndex"
    data-procurement-id="@Model.ProcurementId">
    <td class="ps-3">@Model.RowIndex</td>
    <td>
        <div class="d-flex align-items-center gap-2">
            @await Html.PartialAsync("_PrRequiredDocumentIcon", Model)
            <div class="flex-grow-1">
                <div class="fw-semibold mb-1">@doc.DocumentTypeName</div>
                @if (!string.IsNullOrWhiteSpace(doc.Note))
                {
                    <div class="small text-muted"><i class="bi bi-info-circle me-1"></i>@doc.Note</div>
                }
                @if (Model.IsPending && !string.IsNullOrEmpty(doc.ProcDocumentId))
                {
                    <div class="small mt-2" id="next-@doc.ProcDocumentId">
                        <span class="badge bg-light text-dark border">
                            <i class="bi bi-person-check me-1"></i>Next approver: <em class="text-muted">&bull;</em>
                        </span>
                    </div>
                }
            </div>
        </div>
    </td>
    <td class="text-center">@await Html.PartialAsync("_PrRequiredDocumentTypeBadges", Model)</td>
    <td class="text-center">@await Html.PartialAsync("_PrRequiredDocumentStatusBadge", Model)</td>
    <td>@await Html.PartialAsync("_PrRequiredDocumentFileCell", Model)</td>
    <td class="pe-4" data-actions-row="@Model.RowIndex">
        @await Html.PartialAsync("_PrRequiredDocumentActions", Model)
    </td>
</tr>
