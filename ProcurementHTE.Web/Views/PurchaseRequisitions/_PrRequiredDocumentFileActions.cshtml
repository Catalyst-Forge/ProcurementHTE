@model PurchaseRequisitionDocumentRowViewModel

<div class="btn-group btn-group-sm" role="group">
    <button type="button"
            class="btn btn-outline-secondary btn-preview"
            data-doc-id="@Model.Document.ProcDocumentId"
            data-doc-name="@Model.Document.DocumentTypeName"
            data-file-name="@Model.Document.FileName"
            title="Preview">
        <i class="bi bi-eye"></i>
    </button>

    <button type="button"
            class="btn btn-outline-primary btn-download"
            data-doc-id="@Model.Document.ProcDocumentId"
            data-file-name="@Model.Document.FileName"
            title="Download">
        <i class="bi bi-download"></i>
    </button>

    @if (Model.CanEditDelete)
    {
        <button type="button"
                class="btn btn-outline-danger btn-delete"
                data-doc-id="@Model.Document.ProcDocumentId"
                data-doc-name="@Model.Document.DocumentTypeName"
                data-file-name="@Model.Document.FileName"
                data-procurement-id="@Model.ProcurementId"
                data-document-type-id="@Model.Document.DocumentTypeId"
                data-is-generated="@Model.Document.IsGenerated.ToString().ToLower()"
                data-pr-id="@Model.PrId"
                title="Delete">
            <i class="bi bi-trash"></i>
        </button>
    }
</div>
