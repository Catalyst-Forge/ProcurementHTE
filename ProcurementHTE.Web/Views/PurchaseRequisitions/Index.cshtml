@using Microsoft.AspNetCore.Authorization
@using ProcurementHTE.Core.Common
@using ProcurementHTE.Core.Models
@using ProcurementHTE.Core.Authorization
@model PagedResult<ProcurementHTE.Web.Models.ViewModels.PurchaseRequisitionListViewModel>
@inject IAuthorizationService AuthZ
@{
    ViewData["Title"] = "Purchase Requisition (PR) Data";
    var canCreate = true;
    var canEdit = true;
    var canDelete = true;
    
    var currentSearch = Context.Request.Query["search"].ToString();
    var pageSize = Model.PageSize;
}

<header class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-0">Purchase Requisitions (PR)</h1>
        <p class="text-muted mb-0 small">Manage all purchase requisition data</p>
    </div>
    @if (canCreate)
    {
        <a asp-action="Create" class="btn btn-outline-primary" role="button">
            <i class="bi bi-plus-circle"></i> Create New PR
        </a>
    }
</header>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form method="get" id="filterForm" class="border rounded-3 d-flex flex-wrap gap-2 p-2 mb-2">
    <button type="button" class="btn btn-outline-secondary" id="btnRefresh">
        <i class="bi bi-arrow-clockwise"></i> Refresh
    </button>

    <div class="input-group w-auto">
        <span class="input-group-text"><i class="bi bi-search"></i></span>
        <input class="form-control" type="search" name="search" id="searchBox" 
               placeholder="Search PR..." value="@currentSearch" />
    </div>

    <input type="hidden" name="page" id="pageHidden" value="@Model.Page" />
    <input type="hidden" name="pageSize" id="pageSizeHidden" value="@pageSize" />
</form>

<div class="table-responsive border rounded-3">
    <table class="table table-hover align-middle mobile-table">
        <thead class="table-light">
            <tr class="align-middle">
                <th class="border-end">PR Number</th>
                <th class="border-end">Request Date</th>
                <th class="border-end">Description</th>
                <th class="border-end">Document</th>
                <th class="border-end text-center">Linked Procurements</th>
                <th class="border-end">Created By</th>
                <th class="border-end">Created At</th>
                <th class="text-center width-10-rem">Action</th>
            </tr>
        </thead>

        <tbody>
            @if (Model == null || !Model.Items.Any())
            {
                <tr>
                    <td colspan="8" class="text-center text-muted py-4">
                        <i class="bi bi-inbox fs-1 d-block mb-2 text-muted"></i>
                        No Purchase Requisition data found
                    </td>
                </tr>
            }
            else
            {
                foreach (var item in Model.Items)
                {
                    var deleteTitle = $"Delete {item.PrNumber}?";
                    var deleteMessage = string.IsNullOrWhiteSpace(item.Description)
                        ? "This action cannot be undone."
                        : $"You are about to delete \"{item.Description}\". This action cannot be undone.";
                    <tr>
                        <td class="d-flex d-sm-table-cell" data-label="PR Number">
                            <span class="fw-semibold">@item.PrNumber</span>
                        </td>
                        <td class="d-flex d-sm-table-cell" data-label="Request Date">
                            @item.RequestDate.ToString("d MMM yyyy")
                        </td>
                        <td class="d-flex d-sm-table-cell" data-label="Description">
                            @(item.Description ?? "-")
                        </td>
                        <td class="d-flex d-sm-table-cell" data-label="Document">
                            @if (!string.IsNullOrEmpty(item.DocumentFileName))
                            {
                                <span class="badge bg-primary">
                                    <i class="bi bi-file-earmark"></i> @item.DocumentFileName
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td class="d-flex d-sm-table-cell text-center" data-label="Linked Procurements">
                            <span class="badge bg-info">@item.ProcurementCount</span>
                        </td>
                        <td class="d-flex d-sm-table-cell" data-label="Created By">
                            @(item.CreatedByUserName ?? "-")
                        </td>
                        <td class="d-flex d-sm-table-cell" data-label="Created At">
                            @item.CreatedAt.ToString("d MMM yyyy HH:mm")
                        </td>
                        <td class="d-flex d-sm-table-cell text-center" data-label="Action">
                            @if (canEdit)
                            {
                                <a class="btn btn-outline-warning mb-sm-2 w-100" 
                                    asp-action="Edit" asp-route-id="@item.PrId" role="button" title="Edit">
                                    <i class="bi bi-pencil-fill"></i> Edit
                                </a>
                            }
                            <a class="btn btn-outline-info mb-sm-2 w-100" 
                                asp-action="Details" asp-route-id="@item.PrId" role="button" title="Details">
                                <i class="bi bi-eye-fill"></i> Detail
                            </a>

                            @if (canDelete)
                            {
                                <form asp-action="Delete"
                                        method="post"
                                        class="d-inline delete-form"
                                        hx-boost="false"
                                        hx-ignore="true"
                                        data-loading-overlay="true"
                                        data-confirm-title="@deleteTitle"
                                        data-confirm-message="@System.Text.Encodings.Web.HtmlEncoder.Default.Encode(deleteMessage)">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.PrId" />
                                    <button type="submit"
                                            class="btn btn-outline-danger mb-sm-2 btn-sm w-100"
                                            title="Delete">
                                        <i class="bi bi-trash-fill"></i> Delete
                                    </button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@await Html.PartialAsync("_Pager", Model)

@section Scripts {
    <script>
        (function () {
            const form = document.getElementById('filterForm');
            const searchBox = document.getElementById('searchBox');
            const pageHidden = document.getElementById('pageHidden');
            const pageSizeHidden = document.getElementById('pageSizeHidden');

            searchBox.addEventListener('keydown', function (e) {
                if (e.key === 'Enter') {
                    e.preventDefault();
                    pageHidden.value = 1;
                    form.submit();
                }
            });

            document.getElementById('btnRefresh').addEventListener('click', function () {
                searchBox.value = '';
                pageHidden.value = 1;
                form.submit();
            });
        })();
    </script>
}

@section HeadScripts {
    <style>
        .width-10-rem {
            width: 10rem;
        }
    </style>
}