@model string
@* PrId - ID of the Purchase Requisition *@

<!-- Modal Input Justification -->
<div class="modal fade" id="inputJustificationModal" tabindex="-1" aria-labelledby="inputJustificationModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="PurchaseRequisitions" asp-action="SubmitJustification" method="post" id="formSubmitJustification">
                @Html.AntiForgeryToken()
                <input type="hidden" name="prId" value="@Model" />

                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title" id="inputJustificationModalLabel">
                        <i class="fas fa-file-upload me-2"></i>
                        Submit Justifikasi & Hardcopy
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body">
                    <div class="alert alert-success">
                        <i class="fas fa-info-circle me-2"></i>
                        Konfirmasi bahwa dokumen justifikasi dan hardcopy telah disubmit.
                    </div>

                    <p class="mb-3">
                        Dengan menekan tombol <strong>Submit</strong>, Anda mengkonfirmasi bahwa:
                    </p>
                    <ul class="mb-0">
                        <li>Dokumen justifikasi telah lengkap</li>
                        <li>Hardcopy telah diserahkan ke pihak terkait</li>
                        <li>Semua persyaratan dokumen telah terpenuhi</li>
                    </ul>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times me-2"></i>
                        Batal
                    </button>
                    <button type="submit" class="btn btn-success">
                        <i class="fas fa-check me-2"></i>
                        Konfirmasi Submit
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
