@model ProcurementHTE.Core.Models.DTOs.PRTrackingDto

@if (Model != null)
{
    <!-- PR Tracking Section -->
    <section class="card shadow-sm mb-4 rounded-4">
        <div class="card-header rounded-top-4 d-flex justify-content-between align-items-center py-3">
            <h5 class="card-title mb-0">
                <i class="bi bi-graph-up-arrow me-2"></i>PR Tracking & Progress
            </h5>
            <div>
                @if (Model.CurrentStatus == ProcurementHTE.Core.Enums.PurchaseRequisitionStatus.Rejected)
                {
                    <span class="badge bg-danger px-3 py-2 fs-6">
                        <i class="bi bi-x-circle-fill me-1"></i>Rejected
                    </span>
                }
                else if (Model.CurrentStatus == ProcurementHTE.Core.Enums.PurchaseRequisitionStatus.DonePO)
                {
                    <span class="badge bg-success px-3 py-2 fs-6">
                        <i class="bi bi-check-circle-fill me-1"></i>Completed
                    </span>
                }
                else if (Model.IsWaitingApproval)
                {
                    <span class="badge bg-warning text-dark px-3 py-2 fs-6">
                        <i class="bi bi-hourglass-split me-1"></i>Waiting Approval
                    </span>
                }
                else
                {
                    <span class="badge text-primary px-3 py-2 fs-6">
                        In Progress
                    </span>
                }
            </div>
        </div>

        <div class="card-body p-4">
            <!-- Progress Bar -->
            @await Html.PartialAsync("_PRProgressBar", Model)

            <!-- Approval Status Card - Shows when waiting for approval -->
            @if (Model.IsWaitingApproval)
            {
                // QR data format: procurehte://approve/{prId} (for Flutter deep link)
                // Alternative: JSON format for more info
                var qrData = $"procurehte://approve/{Model.PrId}";
                var qrImageUrl = $"https://api.qrserver.com/v1/create-qr-code/?size=150x150&data={Uri.EscapeDataString(qrData)}";
                var qrImageUrlLarge = $"https://api.qrserver.com/v1/create-qr-code/?size=300x300&data={Uri.EscapeDataString(qrData)}";
                
                <div class="row mt-4">
                    <div class="col-12">
                        <div class="card border-warning bg-warning-subtle">
                            <div class="card-body p-4">
                                <div class="row align-items-center">
                                    <!-- QR Code Section -->
                                    <div class="col-md-4 text-center border-end">
                                        <h6 class="fw-bold text-warning-emphasis mb-3">
                                            <i class="bi bi-qr-code-scan me-2"></i>Scan untuk Approval
                                        </h6>
                                        <div class="bg-white p-3 rounded-3 d-inline-block shadow-sm">
                                            <img src="@qrImageUrl" alt="QR Code for PR Approval" width="150" height="150" />
                                        </div>
                                        <div class="mt-2">
                                            <small class="text-muted">PR: @Model.PrNumber</small>
                                        </div>
                                        <div class="btn-group mt-2">
                                            <a href="@qrImageUrlLarge" target="_blank" class="btn btn-sm btn-outline-warning" download="QR-@(Model.PrNumber).png">
                                                <i class="bi bi-download me-1"></i>Download
                                            </a>
                                            <button type="button" class="btn btn-sm btn-outline-warning" onclick="printQrCode('@Html.Raw(qrImageUrlLarge)', '@Html.Raw(Model.PrNumber)')">
                                                <i class="bi bi-printer me-1"></i>Print
                                            </button>
                                        </div>
                                    </div>

                                    <!-- Approval Info Section -->
                                    <div class="col-md-8">
                                        <div class="ps-md-4">
                                            <h5 class="fw-bold text-warning-emphasis mb-3">
                                                <i class="bi bi-clock-history me-2"></i>Menunggu Approval
                                            </h5>
                                            
                                            <div class="row g-3 mb-3">
                                                <div class="col-sm-6">
                                                    <div class="bg-white rounded-3 p-3 h-100">
                                                        <div class="d-flex align-items-center">
                                                            <div class="bg-warning bg-opacity-25 rounded-circle p-2 me-3">
                                                                <i class="bi bi-person-badge text-warning fs-4"></i>
                                                            </div>
                                                            <div>
                                                                <small class="text-muted d-block">Next Approver</small>
                                                                <strong class="text-warning-emphasis">@(Model.NextApproverRole ?? "-")</strong>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="col-sm-6">
                                                    <div class="bg-white rounded-3 p-3 h-100">
                                                        <div class="d-flex align-items-center">
                                                            <div class="bg-info bg-opacity-25 rounded-circle p-2 me-3">
                                                                <i class="bi bi-file-earmark-check text-info fs-4"></i>
                                                            </div>
                                                            <div>
                                                                <small class="text-muted d-block">Docs Status</small>
                                                                <strong>
                                                                    <span class="text-warning">@Model.DocumentsPendingApproval pending</span>
                                                                    @if (Model.DocumentsApproved > 0)
                                                                    {
                                                                        <span class="text-success ms-2">@Model.DocumentsApproved approved</span>
                                                                    }
                                                                </strong>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="alert alert-info mb-0 py-2">
                                                <i class="bi bi-info-circle me-2"></i>
                                                <small>Approver dapat scan QR code di atas atau klik link di email untuk melakukan approval.</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Action Buttons Section -->
            <div class="mt-4 pt-3 border-top">
                <h6 class="fw-bold mb-3">
                    <i class="bi bi-lightning-charge-fill text-warning me-2"></i>Quick Actions
                </h6>

                <div class="d-flex flex-wrap gap-2 align-items-center">
                    @if (Model.CurrentStatus == ProcurementHTE.Core.Enums.PurchaseRequisitionStatus.OnCreateDP3)
                    {
                        @if (User.IsInRole("AP-PO") || User.IsInRole("Admin"))
                        {
                            @if (Model.CanSendApproval)
                            {
                                <!-- Send for Approval Button - All requirements met -->
                                <form asp-controller="PurchaseRequisitions" asp-action="SendApproval" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="prId" value="@Model.PrId" />
                                    <button type="submit" class="btn btn-primary btn-lg shadow-sm" 
                                            onclick="return confirm('Send PR untuk approval? QR Code akan di-generate untuk dokumen yang memerlukan approval.')">
                                        <i class="bi bi-send-fill me-2"></i>
                                        Send for Approval
                                    </button>
                                </form>
                            }
                            else
                            {
                                <!-- Show why button is disabled -->
                                <div class="alert alert-warning d-flex align-items-start mb-0 py-2" role="alert">
                                    <i class="bi bi-exclamation-triangle-fill me-2 mt-1"></i>
                                    <div>
                                        <strong>Tidak dapat mengirim approval:</strong>
                                        <ul class="mb-0 mt-1 small ps-3">
                                            @if (Model.LinkedProcurementsCount == 0)
                                            {
                                                <li>Belum ada procurement yang di-link</li>
                                            }
                                            @if (!Model.AllMandatoryDocsReady)
                                            {
                                                <li>Dokumen mandatory belum lengkap (@Model.UploadedMandatoryDocs/@Model.TotalMandatoryDocs uploaded)</li>
                                            }
                                        </ul>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="alert alert-info d-flex align-items-center mb-0 py-2" role="alert">
                                <i class="bi bi-info-circle-fill me-2"></i>
                                Hanya role <strong class="mx-1">AP-PO</strong> yang dapat mengirim untuk approval.
                            </div>
                        }
                    }
                    else if (Model.CurrentStatus == ProcurementHTE.Core.Enums.PurchaseRequisitionStatus.OnSubmitISPA)
                    {
                        <!-- Input ISPA Button -->
                        <button type="button" class="btn btn-primary btn-lg shadow-sm" data-bs-toggle="modal" data-bs-target="#inputIspaModal">
                            <i class="bi bi-file-earmark-plus-fill me-2"></i>
                            Input No ISPA
                        </button>
                    }
                    else if (Model.CurrentStatus == ProcurementHTE.Core.Enums.PurchaseRequisitionStatus.OnSubmitHardcopy)
                    {
                        <!-- Submit Justification Button -->
                        <button type="button" class="btn btn-success btn-lg shadow-sm" data-bs-toggle="modal" data-bs-target="#inputJustificationModal">
                            <i class="bi bi-file-earmark-check-fill me-2"></i>
                            Submit Justifikasi & Hardcopy
                        </button>
                    }
                    else if (Model.CurrentStatus == ProcurementHTE.Core.Enums.PurchaseRequisitionStatus.OnSubmitPO)
                    {
                        @if (User.IsInRole("SCM"))
                        {
                            <!-- Submit PO Button (SCM Only) -->
                            <button type="button" class="btn btn-warning btn-lg shadow-sm" data-bs-toggle="modal" data-bs-target="#inputPoModal">
                                <i class="bi bi-file-earmark-medical-fill me-2"></i>
                                Input No PO (SCM)
                            </button>
                        }
                        else
                        {
                            <div class="alert alert-warning d-flex align-items-center mb-0" role="alert">
                                <i class="bi bi-hourglass-split me-2"></i>
                                Waiting for SCM to input PO number
                            </div>
                        }
                    }

                    <!-- View Full Tracking -->
                    <a asp-controller="PurchaseRequisitionTracking" asp-action="Details" asp-route-prId="@Model.PrId" 
                       class="btn btn-outline-info">
                        <i class="bi bi-eye-fill me-2"></i>View Full Tracking
                    </a>
                </div>

                <!-- Display Additional Info -->
                @if (!string.IsNullOrEmpty(Model.IspaNumber) || !string.IsNullOrEmpty(Model.PoNumber))
                {
                    <div class="mt-4 pt-3 border-top">
                        <div class="row g-3">
                            @if (!string.IsNullOrEmpty(Model.IspaNumber))
                            {
                                <div class="col-md-6">
                                    <div class="bg-success-subtle border border-success-subtle p-3 rounded-3">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-success bg-opacity-25 rounded-circle p-2 me-3">
                                                <i class="bi bi-file-text-fill text-success fs-4"></i>
                                            </div>
                                            <div>
                                                <small class="text-muted d-block">ISPA Number</small>
                                                <strong class="text-success-emphasis fs-5">@Model.IspaNumber</strong>
                                                <br>
                                                <small class="text-muted">
                                                    <i class="bi bi-calendar-check me-1"></i>
                                                    @Model.IspaSubmittedAt?.ToString("dd MMM yyyy HH:mm")
                                                </small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(Model.PoNumber))
                            {
                                <div class="col-md-6">
                                    <div class="bg-primary-subtle border border-primary-subtle p-3 rounded-3">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-primary bg-opacity-25 rounded-circle p-2 me-3">
                                                <i class="bi bi-receipt-cutoff text-primary fs-4"></i>
                                            </div>
                                            <div>
                                                <small class="text-muted d-block">PO Number</small>
                                                <strong class="text-primary-emphasis fs-5">@Model.PoNumber</strong>
                                                <br>
                                                <small class="text-muted">
                                                    <i class="bi bi-calendar-check me-1"></i>
                                                    @Model.PoSubmittedAt?.ToString("dd MMM yyyy HH:mm")
                                                </small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- Rejection Info -->
                @if (Model.CurrentStatus == ProcurementHTE.Core.Enums.PurchaseRequisitionStatus.Rejected && !string.IsNullOrEmpty(Model.RejectionNote))
                {
                    <div class="mt-4 pt-3 border-top">
                        <div class="alert alert-danger d-flex align-items-start mb-0">
                            <i class="bi bi-x-octagon-fill me-3 fs-4"></i>
                            <div>
                                <strong>Alasan Penolakan:</strong>
                                <p class="mb-1 mt-2">@Model.RejectionNote</p>
                                <small class="text-muted">
                                    Ditolak oleh @Model.RejectedByUserName pada @Model.RejectedAt?.ToString("dd MMM yyyy HH:mm")
                                </small>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- Include Modals -->
    @await Html.PartialAsync("_InputIspaModal", Model.PrId)
    @await Html.PartialAsync("_InputJustificationModal", Model.PrId)
    @await Html.PartialAsync("_InputPoModal", Model.PrId)
}
else
{
    <div class="alert alert-info d-flex align-items-center">
        <i class="bi bi-info-circle-fill me-2"></i>
        PR Tracking data belum tersedia untuk PR ini.
    </div>
}

<script>
    function printQrCode(qrUrl, prNumber) {
        var w = window.open('', '_blank', 'width=500,height=600');
        w.document.write('<html><head><title>QR Code - ' + prNumber + '</title>');
        w.document.write('<style>');
        w.document.write('body { font-family: Arial, sans-serif; text-align: center; padding: 40px; }');
        w.document.write('.qr-container { border: 2px solid #333; padding: 20px; display: inline-block; }');
        w.document.write('h2 { margin-bottom: 20px; }');
        w.document.write('img { max-width: 300px; }');
        w.document.write('p { margin-top: 15px; font-size: 14px; color: #666; }');
        w.document.write('</style></head><body>');
        w.document.write('<div class="qr-container">');
        w.document.write('<h2>PR Approval</h2>');
        w.document.write('<img src="' + qrUrl + '" alt="QR Code"/>');
        w.document.write('<p><strong>PR Number:</strong> ' + prNumber + '</p>');
        w.document.write('<p>Scan dengan aplikasi ProcureHTE untuk approval</p>');
        w.document.write('</div></body></html>');
        w.document.close();
        w.onload = function () { w.print(); };
    }
</script>
