@model PurchaseRequisitionDetailsViewModel

@{
    ViewData["Title"] = $"PR Details - {Model.PrNumber}";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var canEditDelete = User.IsInRole("Admin") || Model.CreatedByUserId == currentUserId;
    ViewData["CanEditDelete"] = canEditDelete;
}

@await Html.PartialAsync("_PrDetailsHeader", Model)
@await Html.PartialAsync("_PrInformationCard", Model)

@if (ViewData["ProcurementTrackings"] is List<ProcurementHTE.Core.Models.DTOs.ProcurementTrackingDto> procurementTrackings)
{
    ViewData["CanPerformActions"] = canEditDelete;
    @await Html.PartialAsync("_ProcurementTrackingList", procurementTrackings, ViewData)
}

@await Html.PartialAsync("_PrLinkedProcurementsSection", Model)
@await Html.PartialAsync("_PrDetailsModals", Model)

@section Scripts {
    <script>
        window.prDetailsConfig = {
            prId: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PrId)),
            maxUploadSize: 10 * 1024 * 1024
        };
    </script>
    <script src="~/js/purchase-requisitions/details/core.js" asp-append-version="true"></script>
    <script src="~/js/purchase-requisitions/details/preview-download.js" asp-append-version="true"></script>
    <script src="~/js/purchase-requisitions/details/document-counts.js" asp-append-version="true"></script>
    <script src="~/js/purchase-requisitions/details/action-markup.js" asp-append-version="true"></script>
    <script src="~/js/purchase-requisitions/details/delete-document.js" asp-append-version="true"></script>
    <script src="~/js/purchase-requisitions/details/upload-selection.js" asp-append-version="true"></script>
    <script src="~/js/purchase-requisitions/details/upload-submit.js" asp-append-version="true"></script>
    <script src="~/js/purchase-requisitions/details/generate-document.js" asp-append-version="true"></script>
    <script src="~/js/purchase-requisitions/details/boot.js" asp-append-version="true"></script>
}

@section HeadScripts {
    <link rel="stylesheet" href="~/css/purchase-requisition-details.css" asp-append-version="true" />
}
