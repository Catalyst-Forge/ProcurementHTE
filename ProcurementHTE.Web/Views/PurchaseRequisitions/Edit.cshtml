@using Microsoft.AspNetCore.Mvc.Rendering
@model ProcurementHTE.Web.Models.ViewModels.PurchaseRequisitionEditViewModel
@{
    ViewData["Title"] = "Edit Purchase Requisition";
}

<header class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-0">Edit Purchase Requisition (PR)</h1>
        <p class="text-muted mb-0 small">Update purchase requisition data and linked procurements</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary" role="button">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</header>

@if (ViewData.ModelState.ErrorCount > 0)
{
    var errorMessages = ViewData.ModelState.Values
        .SelectMany(v => v.Errors)
        .Select(e => "• " + e.ErrorMessage);
    var escapedMessages = System.Text.Json.JsonSerializer.Serialize(string.Join("<br/>", errorMessages));
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var msg = @Html.Raw(escapedMessages);
            Swal.fire({
                icon: 'error',
                title: 'Validation Error',
                html: msg,
                confirmButtonText: 'OK',
                confirmButtonColor: '#0d6efd'
            });
        });
    </script>
}

<form asp-action="Edit" 
      asp-route-id="@Model.PrId" 
      method="post" 
      enctype="multipart/form-data"
      hx-boost="false">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="PrId" />

    @await Html.PartialAsync("_EditPrInfo", Model)

    @await Html.PartialAsync("_EditPrDocument", Model)

    @await Html.PartialAsync("_EditPrProcurements", Model)

    <div class="d-flex justify-content-end gap-2 mb-3">
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        <button type="submit" class="btn btn-success"><i class="bi bi-check2-circle"></i> Update PR</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    @await Html.PartialAsync("_EditPrScripts", Model)
}
