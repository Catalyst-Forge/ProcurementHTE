@using Microsoft.AspNetCore.Mvc.Rendering
@model ProcurementHTE.Web.Models.ViewModels.PurchaseRequisitionCreateViewModel
@{
    ViewData["Title"] = "Create Purchase Requisition";
}

<header class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h3 mb-0">Create Purchase Requisition (PR)</h1>
        <p class="text-muted mb-0 small">Create new purchase requisition linked to procurement</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary" role="button">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</header>

@if (ViewData.ModelState.ErrorCount > 0)
{
    var errorMessages = ViewData.ModelState.Values
        .SelectMany(v => v.Errors)
        .Select(e => "• " + e.ErrorMessage);
    var escapedMessages = System.Text.Json.JsonSerializer.Serialize(string.Join("<br/>", errorMessages));
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            var msg = @Html.Raw(escapedMessages);
            Swal.fire({
                icon: 'error',
                title: 'Validation Error',
                html: msg,
                confirmButtonText: 'OK',
                confirmButtonColor: '#0d6efd'
            });
        });
    </script>
}

<form asp-action="Create" 
      method="post" 
      enctype="multipart/form-data" 
      id="createPrForm"
      hx-boost="false">
    @Html.AntiForgeryToken()

    @await Html.PartialAsync("Partials/_CreatePrInfo", Model)
    @await Html.PartialAsync("Partials/_CreatePrDocument", Model)
    @await Html.PartialAsync("Partials/_CreatePrProcurements", Model)

    <div class="d-flex justify-content-end gap-2 mb-3">
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
        <button type="submit" class="btn btn-success" id="btnSubmit"><i class="bi bi-check2-circle"></i> Create PR</button>
    </div>
</form>

@section Scripts {
    @await Html.PartialAsync("Partials/_CreatePrScripts")
}
