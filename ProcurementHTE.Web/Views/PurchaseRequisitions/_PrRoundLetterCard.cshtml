@model PurchaseRequisitionRoundLetterCardViewModel

<div class="card shadow-sm h-100 rounded-4">
    <div class="card-body py-3">
        <h6 class="mb-2 fw-semibold">
            <i class="@Model.IconClass"></i> @Model.Title
        </h6>

        @if (Model.Letters.Any())
        {
            @await Html.PartialAsync("_PrRoundLetterTable", Model)
        }
        else
        {
            <div class="alert alert-info py-2 mb-0 small">
                <i class="bi bi-info-circle me-1"></i>@Model.EmptyText
            </div>
        }
    </div>
</div>
