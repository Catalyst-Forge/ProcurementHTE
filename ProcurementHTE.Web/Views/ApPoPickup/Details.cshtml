@using ProcurementHTE.Core.Models
@model Procurement
@{
    ViewData["Title"] = "Procurement Details";
}

<header class="mb-3">
    <div class="hstack flex-wrap justify-content-between my-2">
        <h1 class="h2 fw-bold">@ViewBag.Title</h1>

        <div class="d-flex gap-2 flex-column flex-md-row bg-body p-3 p-md-0 mb-2 border rounded shadow group-nav-button" id="groupNavButton" role="group" aria-label="Button Action">
            <a asp-action="Index" class="btn btn-outline-secondary" role="button"><i class="bi bi-arrow-left"></i> Back to List</a>
        </div>
    </div>
</header>

@* Content body *@
<div class="d-grid gap-md-3 mt-2 procurement-content">
    <div>
        @await Html.PartialAsync("Partials/_JobInformation", Model)
        @await Html.PartialAsync("Partials/_ReferenceNumbers", Model)
        @await Html.PartialAsync("Partials/_Schedule", Model)
        @await Html.PartialAsync("Partials/_Items", Model)
        @await Html.PartialAsync("Partials/_JobDescription", Model)
    </div>

    <div>
        @await Html.PartialAsync("Partials/_Status", Model)
        @await Html.PartialAsync("Partials/_Approvers", Model)
    </div>
</div>

@section Styles {
    <style>
        .procurement-content {
            grid-template-columns: 1fr;
        }

        @@media (min-width: 768px) {
            .procurement-content {
                grid-template-columns: 2fr 1fr;
            }
        }
    </style>
}
