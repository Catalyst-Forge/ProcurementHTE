@model ProcurementHTE.Core.Models.Procurement

<article class="card shadow-sm mb-3 rounded-4">
    <header class="card-header mt-2 fw-semibold bg-transparent border-bottom-0">
        <h2 class="card-title mb-0 h5"><i class="bi bi-people text-primary me-1"></i> Approvers</h2>
    </header>
    <hr class="mx-3 my-2" />

    <div class="card-body">
        <dl class="text-bg-light p-3 rounded-4 mb-2">
            <dt class="fw-semibold text-secondary mb-2">PIC Ops</dt>
            <dd class="fw-medium text-secondary-emphasis">@(ViewBag.PicOpsName ?? "-")</dd>
        </dl>

        <dl class="text-bg-light p-3 rounded-4 mb-2">
            <dt class="fw-semibold text-secondary mb-2">Analyst HTE</dt>
            <dd class="fw-medium text-secondary-emphasis">@(ViewBag.AnalystName ?? "-")</dd>
        </dl>

        <dl class="text-bg-light p-3 rounded-4 mb-2">
            <dt class="fw-semibold text-secondary mb-2">Assistant Manager</dt>
            <dd class="fw-medium text-secondary-emphasis">@(ViewBag.AssistantManagerName ?? "-")</dd>
        </dl>

        <dl class="text-bg-light p-3 rounded-4 mb-2">
            <dt class="fw-semibold text-secondary mb-2">Manager</dt>
            <dd class="fw-medium text-secondary-emphasis">@(ViewBag.ManagerName ?? "-")</dd>
        </dl>
    </div>
</article>
