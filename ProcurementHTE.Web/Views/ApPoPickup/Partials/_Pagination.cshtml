@using ProcurementHTE.Core.Common
@using ProcurementHTE.Core.Models
@model PagedResult<Procurement>
@{
    if (Model == null || Model.TotalPages <= 1) return;

    var currentTab = ViewData["CurrentTab"] as string;
    var currentSearch = ViewData["CurrentSearch"] as string;
    var currentFields = ViewData["CurrentFields"] as HashSet<string> ?? new HashSet<string>();
    var pageSize = Model.PageSize;
    var fieldsStr = string.Join(",", currentFields);
}

<nav aria-label="Page navigation" class="mt-3">
    <ul class="pagination justify-content-center">
        @if (Model.Page > 1) {
            <li class="page-item">
                <a class="page-link" href="?tab=@currentTab&page=@(Model.Page - 1)&pageSize=@pageSize&search=@currentSearch&fields=@fieldsStr">
                    Previous
                </a>
            </li>
        }

        @for (var i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++) {
            <li class="page-item @(i == Model.Page ? "active" : "")">
                <a class="page-link" href="?tab=@currentTab&page=@i&pageSize=@pageSize&search=@currentSearch&fields=@fieldsStr">
                    @i
                </a>
            </li>
        }

        @if (Model.Page < Model.TotalPages) {
            <li class="page-item">
                <a class="page-link" href="?tab=@currentTab&page=@(Model.Page + 1)&pageSize=@pageSize&search=@currentSearch&fields=@fieldsStr">
                    Next
                </a>
            </li>
        }
    </ul>
</nav>
