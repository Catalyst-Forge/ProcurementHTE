@model ProcurementHTE.Web.Models.ViewModels.AccrualIndexViewModel
@{
    ViewData["Title"] = "Data Accrual";
    
    string FormatMoney(decimal? value) => value.HasValue ? value.Value.ToString("N0") : "-";
    string FormatDate(DateTime? date) => date.HasValue ? date.Value.ToString("dd MMM yyyy") : "-";
}

<header class="hstack justify-content-between mb-3">
    <div>
        <h2 class="mb-1">@ViewData["Title"]</h2>
        <p class="text-muted mb-0">Input data accrual untuk setiap procurement</p>
    </div>
</header>

<!-- Filter & Search -->
<div class="card shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Pencarian</label>
                <input type="text" name="search" class="form-control" placeholder="No WO, Job Name, No Accrual..." value="@Model.Search" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Filter Status</label>
                <select name="filter" class="form-select">
                    <option value="all" selected="@(Model.Filter == "all")">Semua</option>
                    <option value="pending" selected="@(Model.Filter == "pending")">Belum Diisi</option>
                    <option value="filled" selected="@(Model.Filter == "filled")">Sudah Diisi</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search"></i> Cari
                </button>
            </div>
            <div class="col-md-3 text-end">
                <span class="badge bg-secondary fs-6">Total: @Model.TotalItems data</span>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 50px;">#</th>
                        <th>No WO</th>
                        <th>Job Name</th>
                        <th>Vendor</th>
                        <th>Status Accrual</th>
                        <th>No Accrual</th>
                        <th class="text-end">Potensi Accrual</th>
                        <th>Diisi Oleh</th>
                        <th class="text-center" style="width: 120px;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Procurements.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                Tidak ada data ditemukan
                            </td>
                        </tr>
                    }
                    else
                    {
                        var rowNum = (Model.CurrentPage - 1) * Model.PageSize;
                        @foreach (var item in Model.Procurements)
                        {
                            rowNum++;
                            var vendor = item.ProfitLosses.FirstOrDefault()?.SelectedVendor?.VendorName ?? "-";
                            var hasAccrual = !string.IsNullOrEmpty(item.NoAccrual);
                            var isPickedByAr = !string.IsNullOrEmpty(item.ArUserId);

                            <tr>
                                <td>@rowNum</td>
                                <td><code>@(item.Wonum ?? "-")</code></td>
                                <td>
                                    <span class="text-truncate d-inline-block" style="max-width: 250px;" title="@item.JobName">
                                        @item.JobName
                                    </span>
                                </td>
                                <td>@vendor</td>
                                <td>
                                    @if (hasAccrual)
                                    {
                                        <span class="badge bg-success">@(item.StatusAccrual ?? "Filled")</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                </td>
                                <td>@(item.NoAccrual ?? "-")</td>
                                <td class="text-end">@FormatMoney(item.PotensiAccrual)</td>
                                <td>
                                    @if (item.AccrualFilledByUser != null)
                                    {
                                        <small class="text-muted">
                                            @item.AccrualFilledByUser.FullName<br />
                                            <span class="text-secondary">@FormatDate(item.AccrualFilledAt)</span>
                                        </small>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (User.IsInRole("Admin") || (User.IsInRole("AR") && isPickedByAr))
                                    {
                                        <button type="button"
                                                class="btn btn-sm @(hasAccrual ? "btn-outline-primary" : "btn-primary") btn-edit-accrual"
                                                data-procurement-id="@item.ProcurementId"
                                                data-bs-toggle="modal"
                                                data-bs-target="#accrualModal">
                                            <i class="bi @(hasAccrual ? "bi-pencil" : "bi-plus-lg")"></i>
                                            @(hasAccrual ? "Edit" : "Isi Data")
                                        </button>
                                    }
                                    else if (User.IsInRole("AR") && !isPickedByAr)
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-exclamation-triangle"></i> Pickup Dulu
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">View Only</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer">
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center mb-0">
                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                        <a class="page-link" href="?page=@(Model.CurrentPage - 1)&search=@Model.Search&filter=@Model.Filter">
                            <i class="bi bi-chevron-left"></i>
                        </a>
                    </li>
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="?page=@i&search=@Model.Search&filter=@Model.Filter">@i</a>
                        </li>
                    }
                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                        <a class="page-link" href="?page=@(Model.CurrentPage + 1)&search=@Model.Search&filter=@Model.Filter">
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    }
</div>

<!-- Modal Input Accrual -->
<div class="modal fade" id="accrualModal" tabindex="-1" aria-labelledby="accrualModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="accrualModalLabel">
                    <i class="bi bi-pencil-square me-2"></i>Input Data Accrual
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="modalLoading" class="text-center py-4">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <div class="text-muted mt-2">Memuat data...</div>
                </div>
                <div id="modalError" class="text-center py-4" style="display: none;">
                    <i class="bi bi-exclamation-triangle text-danger fs-1"></i>
                    <div class="text-danger mt-2">Gagal memuat data</div>
                    <div class="error-message text-muted small"></div>
                </div>
                <div id="modalContent" style="display: none;">
                    <div class="mb-3">
                        <label class="form-label text-muted small">Procurement</label>
                        <div class="fw-semibold" id="modalProcInfo"></div>
                    </div>
                    <hr />
                    <input type="hidden" id="modalProcurementId" />
                    <div class="mb-3">
                        <label for="noAccrual" class="form-label">No. Accrual</label>
                        <input type="text" class="form-control" id="noAccrual" maxlength="100" placeholder="Masukkan No. Accrual" />
                    </div>
                    <div class="mb-3">
                        <label for="potensiAccrual" class="form-label">Potensi Accrual (Rp)</label>
                        <input type="text" class="form-control" id="potensiAccrual" placeholder="0" />
                        <div class="form-text">Format: 1.000.000</div>
                    </div>
                    <div class="mb-3">
                        <label for="statusAccrual" class="form-label">Status Accrual</label>
                        <select class="form-select" id="statusAccrual">
                            <option value="">Pilih Status</option>
                            <option value="Open">Open</option>
                            <option value="In Progress">In Progress</option>
                            <option value="Completed">Completed</option>
                            <option value="Closed">Closed</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                <button type="button" class="btn btn-primary" id="btnSaveAccrual">
                    <i class="bi bi-check-lg me-1"></i>Simpan
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Html.AntiForgeryToken()
    <script>
        (function() {
            const modal = document.getElementById('accrualModal');
            const modalLoading = document.getElementById('modalLoading');
            const modalContent = document.getElementById('modalContent');
            const modalError = document.getElementById('modalError');
            const btnSave = document.getElementById('btnSaveAccrual');

            // Cleanup previous event listeners if any (for HTMX navigation)
            const newModal = modal.cloneNode(true);
            modal.parentNode.replaceChild(newModal, modal);

            // Re-get references after clone
            const accrualModal = document.getElementById('accrualModal');
            const accrualModalLoading = document.getElementById('modalLoading');
            const accrualModalContent = document.getElementById('modalContent');
            const accrualModalError = document.getElementById('modalError');
            const accrualBtnSave = document.getElementById('btnSaveAccrual');

            // Helper functions untuk format number
            function formatNumber(value) {
                if (!value) return '';
                // Hapus semua karakter non-digit
                const numStr = value.toString().replace(/\D/g, '');
                if (!numStr) return '';
                // Tambahkan titik setiap 3 digit dari belakang
                return numStr.replace(/\B(?=(\d{3})+(?!\d))/g, '.');
            }

            function unformatNumber(value) {
                if (!value) return null;
                // Hapus semua titik pemisah
                const numStr = value.toString().replace(/\./g, '');
                const num = parseFloat(numStr);
                return isNaN(num) ? null : num;
            }

            // Handle modal open - using Bootstrap event
            accrualModal.addEventListener('show.bs.modal', async function(event) {
                const button = event.relatedTarget;
                if (!button) return;
                
                const procurementId = button.dataset.procurementId;
                
                // Reset state
                accrualModalLoading.style.display = 'block';
                accrualModalContent.style.display = 'none';
                accrualModalError.style.display = 'none';

                try {
                    const response = await fetch(`/Accrual/GetDetails/${procurementId}`, {
                        method: 'GET',
                        headers: {
                            'Accept': 'application/json'
                        }
                    });
                    
                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}: ${response.statusText}`);
                    }

                    const data = await response.json();
                    
                    document.getElementById('modalProcurementId').value = data.procurementId;
                    document.getElementById('modalProcInfo').innerHTML = `
                        <div><strong>${data.wonum || '-'}</strong></div>
                        <div class="small text-muted">${data.jobName || '-'}</div>
                    `;
                    document.getElementById('noAccrual').value = data.noAccrual || '';
                    // Format nilai potensi accrual dengan pemisah titik
                    document.getElementById('potensiAccrual').value = formatNumber(data.potensiAccrual);
                    document.getElementById('statusAccrual').value = data.statusAccrual || '';

                    accrualModalLoading.style.display = 'none';
                    accrualModalContent.style.display = 'block';

                    // Setup auto-format untuk input potensi accrual
                    const potensiAccrualInput = document.getElementById('potensiAccrual');
                    potensiAccrualInput.addEventListener('input', function(e) {
                        const cursorPosition = e.target.selectionStart;
                        const oldLength = e.target.value.length;
                        const oldValue = e.target.value;

                        // Format value
                        e.target.value = formatNumber(e.target.value);

                        // Adjust cursor position after formatting
                        const newLength = e.target.value.length;
                        const diff = newLength - oldLength;
                        e.target.setSelectionRange(cursorPosition + diff, cursorPosition + diff);
                    });
                } catch (error) {
                    console.error('Error loading details:', error);
                    accrualModalLoading.style.display = 'none';
                    accrualModalError.style.display = 'block';
                    accrualModalError.querySelector('.error-message').textContent = error.message;
                }
            });

            // Reset modal when hidden
            accrualModal.addEventListener('hidden.bs.modal', function() {
                accrualModalLoading.style.display = 'block';
                accrualModalContent.style.display = 'none';
                accrualModalError.style.display = 'none';
            });

            // Handle save
            accrualBtnSave.addEventListener('click', async function() {
                const procurementId = document.getElementById('modalProcurementId').value;
                const noAccrual = document.getElementById('noAccrual').value;
                const potensiAccrualFormatted = document.getElementById('potensiAccrual').value;
                const statusAccrual = document.getElementById('statusAccrual').value;

                // Unformat potensi accrual untuk dikirim ke backend
                const potensiAccrual = unformatNumber(potensiAccrualFormatted);

                accrualBtnSave.disabled = true;
                accrualBtnSave.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Menyimpan...';

                try {
                    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                    const response = await fetch('/Accrual/Save', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'RequestVerificationToken': token
                        },
                        body: JSON.stringify({
                            procurementId,
                            noAccrual: noAccrual || null,
                            potensiAccrual: potensiAccrual,
                            statusAccrual: statusAccrual || null
                        })
                    });

                    const result = await response.json();
                    
                    if (result.success) {
                        bootstrap.Modal.getInstance(accrualModal).hide();
                        location.reload();
                    } else {
                        alert(result.message || 'Gagal menyimpan data');
                    }
                } catch (error) {
                    console.error('Error saving:', error);
                    alert('Terjadi kesalahan saat menyimpan data');
                } finally {
                    accrualBtnSave.disabled = false;
                    accrualBtnSave.innerHTML = '<i class="bi bi-check-lg me-1"></i>Simpan';
                }
            });
        })();
    </script>
}
