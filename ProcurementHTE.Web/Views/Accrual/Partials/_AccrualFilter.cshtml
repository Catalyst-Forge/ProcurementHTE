@model ProcurementHTE.Web.Models.ViewModels.AccrualIndexViewModel

<!-- Filter & Search -->
<div class="card shadow-sm mb-3">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label">Pencarian</label>
                <input type="text" name="search" class="form-control" placeholder="No WO, Job Name, No Accrual..." value="@Model.Search" />
            </div>
            <div class="col-md-3">
                <label class="form-label">Filter Status</label>
                <select name="filter" class="form-select">
                    <option value="all" selected="@(Model.Filter == "all")">Semua</option>
                    <option value="pending" selected="@(Model.Filter == "pending")">Belum Diisi</option>
                    <option value="filled" selected="@(Model.Filter == "filled")">Sudah Diisi</option>
                </select>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-search"></i> Cari
                </button>
            </div>
            <div class="col-md-3 text-end">
                <span class="badge bg-secondary fs-6">Total: @Model.TotalItems data</span>
            </div>
        </form>
    </div>
</div>
