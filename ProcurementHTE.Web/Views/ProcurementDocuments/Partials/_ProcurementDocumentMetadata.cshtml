@model ProcurementHTE.Web.Models.ViewModels.ProcurementDocumentRowViewModel

@{
    var item = Model.Item;
}

@if (item.Uploaded && !string.IsNullOrEmpty(item.FileName))
{
    <div class="small text-muted mb-1">
        <i class="bi bi-paperclip me-1"></i>@item.FileName
        @if (item.Size.HasValue)
        {
            var sizeKb = item.Size.Value / 1024.0;
            var sizeMb = sizeKb / 1024.0;
            var sizeText = sizeMb >= 1 ? $"{sizeMb:F2} MB" : $"{sizeKb:F2} KB";
            <span class="text-muted">&bull; @sizeText</span>
        }
    </div>
}

@if (!string.IsNullOrWhiteSpace(item.Note))
{
    <div class="small text-muted">
        <i class="bi bi-info-circle me-1"></i>@item.Note
    </div>
}

@if (Model.IsPending && !string.IsNullOrEmpty(item.ProcDocumentId))
{
    <div class="small mt-2" id="next-@item.ProcDocumentId">
        <span class="badge bg-light text-dark border">
            <i class="bi bi-person-check me-1"></i>Next approver: <em class="text-muted">&bull;</em>
        </span>
    </div>
}
