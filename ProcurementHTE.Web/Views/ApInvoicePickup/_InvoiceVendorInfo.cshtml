@model ProcurementHTE.Core.Models.Procurement
@{
    var pl = Model.ProfitLosses?.FirstOrDefault();
}

<!-- Vendor & P&L Information -->
<article class="card shadow-sm mb-3 rounded-4">
    <header class="card-header mt-2 fw-semibold bg-transparent border-bottom-0">
        <h2 class="card-title mb-0 h5"><i class="bi bi-building text-primary me-1"></i> Vendor & P&L Information</h2>
    </header>
    <hr class="mx-3 my-2" />
    <div class="card-body">
        @if (pl != null)
        {
            <div class="row mb-0">
                <dl class="col-12 col-sm-6 col-md-4 mb-2">
                    <dt class="fw-semibold text-uppercase text-secondary">Selected Vendor</dt>
                    <dd class="fw-medium text-secondary-emphasis">
                        @if (pl.SelectedVendor != null)
                        {
                            <span class="badge bg-success">@pl.SelectedVendor.VendorName</span>
                        }
                        else
                        {
                            <text>-</text>
                        }
                    </dd>
                </dl>
                <dl class="col-12 col-sm-6 col-md-4 mb-2">
                    <dt class="fw-semibold text-uppercase text-secondary">Final Offer</dt>
                    <dd class="fw-medium text-secondary-emphasis">@pl.SelectedVendorFinalOffer.ToString("N0")</dd>
                </dl>
                <dl class="col-12 col-sm-6 col-md-4 mb-2">
                    <dt class="fw-semibold text-uppercase text-secondary">Profit/Loss</dt>
                    <dd class="fw-medium text-secondary-emphasis">
                        @{
                            var isProfit = pl.Profit >= 0;
                        }
                        <span class="badge @(isProfit ? "bg-success" : "bg-danger")">
                            @(isProfit ? "+" : "")@pl.Profit.ToString("N0")
                        </span>
                    </dd>
                </dl>
                <dl class="col-12 col-sm-6 col-md-4 mb-2">
                    <dt class="fw-semibold text-uppercase text-secondary">Margin (%)</dt>
                    <dd class="fw-medium text-secondary-emphasis">@pl.ProfitPercent.ToString("N2")%</dd>
                </dl>
            </div>
        }
        else
        {
            <p class="text-muted mb-0">No P&L data available</p>
        }
    </div>
</article>
