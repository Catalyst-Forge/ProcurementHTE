@model ProcurementHTE.Core.Models.Procurement

<!-- Timestamps -->
<article class="card shadow-sm mb-3 rounded-4">
    <header class="card-header mt-2 fw-semibold bg-transparent border-bottom-0">
        <h2 class="card-title mb-0 h5"><i class="bi bi-calendar-check text-primary me-1"></i> Timestamps</h2>
    </header>
    <hr class="mx-3 my-2" />
    <div class="card-body">
        <dl class="mb-2">
            <dt class="fw-semibold text-uppercase text-secondary small">Created</dt>
            <dd class="fw-medium text-secondary-emphasis">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</dd>
        </dl>
        @if (Model.UpdatedAt.HasValue)
        {
            <dl class="mb-0">
                <dt class="fw-semibold text-uppercase text-secondary small">Updated</dt>
                <dd class="fw-medium text-secondary-emphasis">@Model.UpdatedAt.Value.ToString("dd MMM yyyy HH:mm")</dd>
            </dl>
        }
    </div>
</article>
