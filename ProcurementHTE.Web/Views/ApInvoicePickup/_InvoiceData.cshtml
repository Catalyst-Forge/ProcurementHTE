@model ProcurementHTE.Core.Models.Procurement
@inject Microsoft.AspNetCore.Identity.UserManager<ProcurementHTE.Core.Models.User> UserManager
@{
    var currentUserId = UserManager.GetUserId(User);
    var isPickedByCurrentUser = Model.ApInvoiceUserId == currentUserId;
    var hasInvoiceData = !string.IsNullOrEmpty(Model.SANo) || !string.IsNullOrEmpty(Model.SP3No);
}

<!-- Invoice Data -->
<article class="card shadow-sm mb-3 rounded-4">
    <header class="card-header mt-2 fw-semibold bg-transparent border-bottom-0 d-flex justify-content-between align-items-center">
        <h2 class="card-title mb-0 h5"><i class="bi bi-receipt text-primary me-1"></i> Invoice Data</h2>
        @if (isPickedByCurrentUser && hasInvoiceData)
        {
            <button type="button" class="btn btn-outline-primary btn-sm" id="btnEditInvoice">
                <i class="bi bi-pencil me-1"></i> Edit
            </button>
        }
    </header>
    <hr class="mx-3 my-2" />
    <div class="card-body">
        @if (isPickedByCurrentUser)
        {
            <!-- Display Mode (default jika sudah ada data) -->
            <div id="invoiceDisplayMode" class="@(hasInvoiceData ? "" : "d-none")">
                <div class="row mb-0">
                    <dl class="col-12 col-sm-6 mb-2">
                        <dt class="fw-semibold text-uppercase text-secondary">SA No</dt>
                        <dd class="fw-medium text-secondary-emphasis">
                            @if (!string.IsNullOrEmpty(Model.SANo))
                            {
                                <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle fs-6">@Model.SANo</span>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Belum diisi</span>
                            }
                        </dd>
                    </dl>
                    <dl class="col-12 col-sm-6 mb-2">
                        <dt class="fw-semibold text-uppercase text-secondary">SP3 No</dt>
                        <dd class="fw-medium text-secondary-emphasis">
                            @if (!string.IsNullOrEmpty(Model.SP3No))
                            {
                                <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle fs-6">@Model.SP3No</span>
                            }
                            else
                            {
                                <span class="text-muted fst-italic">Belum diisi</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>

            <!-- Edit Mode (form) -->
            <div id="invoiceEditMode" class="@(hasInvoiceData ? "d-none" : "")">
                <form method="post" asp-action="UpdateInvoiceData" asp-route-id="@Model.ProcurementId" id="invoiceForm" hx-boost="false">
                    @Html.AntiForgeryToken()
                    <div class="row mb-0">
                        <div class="col-12 col-sm-6 mb-3">
                            <label for="saNo" class="form-label fw-semibold text-uppercase text-secondary small">SA No</label>
                            <input type="text" class="form-control" id="saNo" name="saNo" value="@Model.SANo" placeholder="Masukkan nomor SA" />
                            <div class="form-text">Nomor SA (Service Agreement)</div>
                        </div>
                        <div class="col-12 col-sm-6 mb-3">
                            <label for="sp3No" class="form-label fw-semibold text-uppercase text-secondary small">SP3 No</label>
                            <input type="text" class="form-control" id="sp3No" name="sp3No" value="@Model.SP3No" placeholder="Masukkan nomor SP3" />
                            <div class="form-text">Nomor SP3</div>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2">
                        @if (hasInvoiceData)
                        {
                            <button type="button" class="btn btn-outline-secondary" id="btnCancelEdit">
                                <i class="bi bi-x me-1"></i> Batal
                            </button>
                        }
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i> Simpan
                        </button>
                    </div>
                </form>
            </div>
        }
        else
        {
            <!-- Read-only untuk user yang belum pickup -->
            <div class="row mb-0">
                <dl class="col-12 col-sm-6 mb-2">
                    <dt class="fw-semibold text-uppercase text-secondary">SA No</dt>
                    <dd class="fw-medium text-secondary-emphasis">
                        @if (!string.IsNullOrEmpty(Model.SANo))
                        {
                            @Model.SANo
                        }
                        else
                        {
                            <span class="text-muted fst-italic">Belum diisi</span>
                        }
                    </dd>
                </dl>
                <dl class="col-12 col-sm-6 mb-2">
                    <dt class="fw-semibold text-uppercase text-secondary">SP3 No</dt>
                    <dd class="fw-medium text-secondary-emphasis">
                        @if (!string.IsNullOrEmpty(Model.SP3No))
                        {
                            @Model.SP3No
                        }
                        else
                        {
                            <span class="text-muted fst-italic">Belum diisi</span>
                        }
                    </dd>
                </dl>
            </div>
            <div class="alert alert-info mb-0">
                <i class="bi bi-info-circle me-1"></i>
                Silakan pickup procurement ini terlebih dahulu untuk mengisi data invoice.
            </div>
        }
    </div>
</article>
