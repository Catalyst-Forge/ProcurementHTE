@using ProcurementHTE.Core.Common
@using ProcurementHTE.Core.Models
@model PagedResult<Procurement>
@{
    var currentTab = ViewBag.CurrentTab as string ?? "waiting";
    var currentSearch = ViewBag.Search as string ?? "";
    var pageSize = Model.PageSize;
}
@if (Model?.TotalPages > 1) {
    <nav aria-label="Page navigation" class="mt-3">
        <ul class="pagination justify-content-center">
            @if (Model.Page > 1) {
                <li class="page-item">
                    <a class="page-link" href="?tab=@currentTab&page=@(Model.Page - 1)&pageSize=@pageSize&search=@currentSearch">
                        Previous
                    </a>
                </li>
            }

            @for (var i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++) {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" href="?tab=@currentTab&page=@i&pageSize=@pageSize&search=@currentSearch">
                        @i
                    </a>
                </li>
            }

            @if (Model.Page < Model.TotalPages) {
                <li class="page-item">
                    <a class="page-link" href="?tab=@currentTab&page=@(Model.Page + 1)&pageSize=@pageSize&search=@currentSearch">
                        Next
                    </a>
                </li>
            }
        </ul>
    </nav>
}
