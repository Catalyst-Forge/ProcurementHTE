@model ProcurementHTE.Core.Models.Procurement

<!-- Pickup History -->
<article class="card shadow-sm mb-3 rounded-4">
    <header class="card-header mt-2 fw-semibold bg-transparent border-bottom-0">
        <h2 class="card-title mb-0 h5"><i class="bi bi-clock-history text-primary me-1"></i> Pickup History</h2>
    </header>
    <hr class="mx-3 my-2" />
    <div class="card-body">
        @if (Model.AppoUser != null)
        {
            <div class="mb-3 pb-3 border-bottom">
                <div class="fw-semibold text-uppercase text-secondary small mb-1">AP-PO Pickup</div>
                <div class="fw-medium text-secondary-emphasis">
                    <i class="bi bi-person me-1"></i> @Model.AppoUser.FullName
                </div>
                @if (Model.PickedUpAt.HasValue)
                {
                    <small class="text-muted">
                        <i class="bi bi-calendar me-1"></i> @Model.PickedUpAt.Value.ToString("dd MMM yyyy HH:mm")
                    </small>
                }
            </div>
        }

        @if (Model.ApInvoiceUser != null)
        {
            <div class="mb-3 pb-3 @(Model.ArUser != null ? "border-bottom" : "")">
                <div class="fw-semibold text-uppercase text-secondary small mb-1">AP-Invoice Pickup</div>
                <div class="fw-medium text-secondary-emphasis">
                    <i class="bi bi-person me-1"></i> @Model.ApInvoiceUser.FullName
                </div>
                @if (Model.ApInvoicePickedUpAt.HasValue)
                {
                    <small class="text-muted">
                        <i class="bi bi-calendar me-1"></i> @Model.ApInvoicePickedUpAt.Value.ToString("dd MMM yyyy HH:mm")
                    </small>
                }
            </div>
        }

        @if (Model.ArUser != null)
        {
            <div class="mb-0">
                <div class="fw-semibold text-uppercase text-secondary small mb-1">AR Pickup</div>
                <div class="fw-medium text-secondary-emphasis">
                    <i class="bi bi-person me-1"></i> @Model.ArUser.FullName
                </div>
                @if (Model.ArPickedUpAt.HasValue)
                {
                    <small class="text-muted">
                        <i class="bi bi-calendar me-1"></i> @Model.ArPickedUpAt.Value.ToString("dd MMM yyyy HH:mm")
                    </small>
                }
            </div>
        }

        @if (Model.AppoUser == null && Model.ApInvoiceUser == null && Model.ArUser == null)
        {
            <p class="text-muted mb-0">No pickup history available</p>
        }
    </div>
</article>
