@model ProcurementHTE.Core.Models.Procurement
@inject Microsoft.AspNetCore.Identity.UserManager<ProcurementHTE.Core.Models.User> UserManager
@{
    ViewData["Title"] = "Invoice Details";
    var currentUserId = UserManager.GetUserId(User);
    var isPickedByCurrentUser = Model.ApInvoiceUserId == currentUserId;
}

<header class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Invoice Details</h1>
    <a asp-action="Index" asp-route-tab="@(isPickedByCurrentUser ? "mypickups" : "waiting")" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</header>

<div class="row">
    <div class="col-lg-8">
        @await Html.PartialAsync("_InvoiceProcInfo", Model)
        @await Html.PartialAsync("_InvoiceVendorInfo", Model)
        @await Html.PartialAsync("_InvoiceData", Model)
    </div>

    <div class="col-lg-4">
        @await Html.PartialAsync("_InvoicePickupHistory", Model)
        @await Html.PartialAsync("_InvoiceTimestamps", Model)
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_InvoiceScripts")
}
