@model ProcurementHTE.Core.Models.Procurement
@inject Microsoft.AspNetCore.Identity.UserManager<ProcurementHTE.Core.Models.User> UserManager
@{
    ViewData["Title"] = "Invoice Details";
    var pl = Model.ProfitLosses?.FirstOrDefault();
    var currentUserId = UserManager.GetUserId(User);
    var isPickedByCurrentUser = Model.ApInvoiceUserId == currentUserId;
    var hasInvoiceData = !string.IsNullOrEmpty(Model.SANo) || !string.IsNullOrEmpty(Model.SP3No);
}

<header class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Invoice Details</h1>
    <a asp-action="Index" asp-route-tab="@(isPickedByCurrentUser ? "mypickups" : "waiting")" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to List
    </a>
</header>

<div class="row">
    <div class="col-lg-8">
        <!-- Procurement Information -->
        <article class="card shadow-sm mb-3 rounded-4">
            <header class="card-header mt-2 fw-semibold bg-transparent border-bottom-0">
                <h2 class="card-title mb-0 h5"><i class="bi bi-info-circle text-primary me-1"></i> Procurement Information</h2>
            </header>
            <hr class="mx-3 my-2" />
            <div class="card-body">
                <div class="row mb-0">
                    <dl class="col-12 col-sm-6 col-md-4 mb-2">
                        <dt class="fw-semibold text-uppercase text-secondary">Procurement No</dt>
                        <dd class="fw-medium text-secondary-emphasis">@Model.ProcNum</dd>
                    </dl>
                    <dl class="col-12 col-sm-6 col-md-4 mb-2">
                        <dt class="fw-semibold text-uppercase text-secondary">Job Name</dt>
                        <dd class="fw-medium text-secondary-emphasis">@Model.JobName</dd>
                    </dl>
                    <dl class="col-12 col-sm-6 col-md-4 mb-2">
                        <dt class="fw-semibold text-uppercase text-secondary">WO Number</dt>
                        <dd class="fw-medium text-secondary-emphasis">@(Model.Wonum ?? "-")</dd>
                    </dl>
                    <dl class="col-12 col-sm-6 col-md-4 mb-2">
                        <dt class="fw-semibold text-uppercase text-secondary">SPK Number</dt>
                        <dd class="fw-medium text-secondary-emphasis">@(Model.SpkNumber ?? "-")</dd>
                    </dl>
                    <dl class="col-12 col-sm-6 col-md-4 mb-2">
                        <dt class="fw-semibold text-uppercase text-secondary">Job Type</dt>
                        <dd class="fw-medium text-secondary-emphasis">@(Model.JobType?.TypeName ?? "-")</dd>
                    </dl>
                    <dl class="col-12 col-sm-6 col-md-4 mb-2">
                        <dt class="fw-semibold text-uppercase text-secondary">Status</dt>
                        <dd class="fw-medium text-secondary-emphasis">
                            <span class="badge bg-primary">@(Model.Status?.StatusName ?? "-")</span>
                        </dd>
                    </dl>
                    <dl class="col-12 col-sm-6 col-md-4 mb-2">
                        <dt class="fw-semibold text-uppercase text-secondary">Start Date</dt>
                        <dd class="fw-medium text-secondary-emphasis">@(Model.StartDate == default ? "-" : Model.StartDate.ToString("dd MMM yyyy"))</dd>
                    </dl>
                    <dl class="col-12 col-sm-6 col-md-4 mb-2">
                        <dt class="fw-semibold text-uppercase text-secondary">End Date</dt>
                        <dd class="fw-medium text-secondary-emphasis">@(Model.EndDate == default ? "-" : Model.EndDate.ToString("dd MMM yyyy"))</dd>
                    </dl>
                </div>
            </div>
        </article>

        <!-- Vendor & P&L Information -->
        <article class="card shadow-sm mb-3 rounded-4">
            <header class="card-header mt-2 fw-semibold bg-transparent border-bottom-0">
                <h2 class="card-title mb-0 h5"><i class="bi bi-building text-primary me-1"></i> Vendor & P&L Information</h2>
            </header>
            <hr class="mx-3 my-2" />
            <div class="card-body">
                @if (pl != null)
                {
                    <div class="row mb-0">
                        <dl class="col-12 col-sm-6 col-md-4 mb-2">
                            <dt class="fw-semibold text-uppercase text-secondary">Selected Vendor</dt>
                            <dd class="fw-medium text-secondary-emphasis">
                                @if (pl.SelectedVendor != null)
                                {
                                    <span class="badge bg-success">@pl.SelectedVendor.VendorName</span>
                                }
                                else
                                {
                                    <text>-</text>
                                }
                            </dd>
                        </dl>
                        <dl class="col-12 col-sm-6 col-md-4 mb-2">
                            <dt class="fw-semibold text-uppercase text-secondary">Final Offer</dt>
                            <dd class="fw-medium text-secondary-emphasis">@pl.SelectedVendorFinalOffer.ToString("N0")</dd>
                        </dl>
                        <dl class="col-12 col-sm-6 col-md-4 mb-2">
                            <dt class="fw-semibold text-uppercase text-secondary">Profit/Loss</dt>
                            <dd class="fw-medium text-secondary-emphasis">
                                @{
                                    var isProfit = pl.Profit >= 0;
                                }
                                <span class="badge @(isProfit ? "bg-success" : "bg-danger")">
                                    @(isProfit ? "+" : "")@pl.Profit.ToString("N0")
                                </span>
                            </dd>
                        </dl>
                        <dl class="col-12 col-sm-6 col-md-4 mb-2">
                            <dt class="fw-semibold text-uppercase text-secondary">Margin (%)</dt>
                            <dd class="fw-medium text-secondary-emphasis">@pl.ProfitPercent.ToString("N2")%</dd>
                        </dl>
                    </div>
                }
                else
                {
                    <p class="text-muted mb-0">No P&L data available</p>
                }
            </div>
        </article>

        <!-- Invoice Data -->
        <article class="card shadow-sm mb-3 rounded-4">
            <header class="card-header mt-2 fw-semibold bg-transparent border-bottom-0 d-flex justify-content-between align-items-center">
                <h2 class="card-title mb-0 h5"><i class="bi bi-receipt text-primary me-1"></i> Invoice Data</h2>
                @if (isPickedByCurrentUser && hasInvoiceData)
                {
                    <button type="button" class="btn btn-outline-primary btn-sm" id="btnEditInvoice">
                        <i class="bi bi-pencil me-1"></i> Edit
                    </button>
                }
            </header>
            <hr class="mx-3 my-2" />
            <div class="card-body">
                @if (isPickedByCurrentUser)
                {
                    <!-- Display Mode (default jika sudah ada data) -->
                    <div id="invoiceDisplayMode" class="@(hasInvoiceData ? "" : "d-none")">
                        <div class="row mb-0">
                            <dl class="col-12 col-sm-6 mb-2">
                                <dt class="fw-semibold text-uppercase text-secondary">SA No</dt>
                                <dd class="fw-medium text-secondary-emphasis">
                                    @if (!string.IsNullOrEmpty(Model.SANo))
                                    {
                                        <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle fs-6">@Model.SANo</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Belum diisi</span>
                                    }
                                </dd>
                            </dl>
                            <dl class="col-12 col-sm-6 mb-2">
                                <dt class="fw-semibold text-uppercase text-secondary">SP3 No</dt>
                                <dd class="fw-medium text-secondary-emphasis">
                                    @if (!string.IsNullOrEmpty(Model.SP3No))
                                    {
                                        <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle fs-6">@Model.SP3No</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic">Belum diisi</span>
                                    }
                                </dd>
                            </dl>
                        </div>
                    </div>

                    <!-- Edit Mode (form) -->
                    <div id="invoiceEditMode" class="@(hasInvoiceData ? "d-none" : "")">
                        <form method="post" asp-action="UpdateInvoiceData" asp-route-id="@Model.ProcurementId" id="invoiceForm" hx-boost="false">
                            @Html.AntiForgeryToken()
                            <div class="row mb-0">
                                <div class="col-12 col-sm-6 mb-3">
                                    <label for="saNo" class="form-label fw-semibold text-uppercase text-secondary small">SA No</label>
                                    <input type="text" class="form-control" id="saNo" name="saNo" value="@Model.SANo" placeholder="Masukkan nomor SA" />
                                    <div class="form-text">Nomor SA (Service Agreement)</div>
                                </div>
                                <div class="col-12 col-sm-6 mb-3">
                                    <label for="sp3No" class="form-label fw-semibold text-uppercase text-secondary small">SP3 No</label>
                                    <input type="text" class="form-control" id="sp3No" name="sp3No" value="@Model.SP3No" placeholder="Masukkan nomor SP3" />
                                    <div class="form-text">Nomor SP3</div>
                                </div>
                            </div>
                            <div class="d-flex justify-content-end gap-2">
                                @if (hasInvoiceData)
                                {
                                    <button type="button" class="btn btn-outline-secondary" id="btnCancelEdit">
                                        <i class="bi bi-x me-1"></i> Batal
                                    </button>
                                }
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-save me-1"></i> Simpan
                                </button>
                            </div>
                        </form>
                    </div>
                }
                else
                {
                    <!-- Read-only untuk user yang belum pickup -->
                    <div class="row mb-0">
                        <dl class="col-12 col-sm-6 mb-2">
                            <dt class="fw-semibold text-uppercase text-secondary">SA No</dt>
                            <dd class="fw-medium text-secondary-emphasis">
                                @if (!string.IsNullOrEmpty(Model.SANo))
                                {
                                    @Model.SANo
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">Belum diisi</span>
                                }
                            </dd>
                        </dl>
                        <dl class="col-12 col-sm-6 mb-2">
                            <dt class="fw-semibold text-uppercase text-secondary">SP3 No</dt>
                            <dd class="fw-medium text-secondary-emphasis">
                                @if (!string.IsNullOrEmpty(Model.SP3No))
                                {
                                    @Model.SP3No
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">Belum diisi</span>
                                }
                            </dd>
                        </dl>
                    </div>
                    <div class="alert alert-info mb-0">
                        <i class="bi bi-info-circle me-1"></i>
                        Silakan pickup procurement ini terlebih dahulu untuk mengisi data invoice.
                    </div>
                }
            </div>
        </article>
    </div>

    <div class="col-lg-4">
        <!-- Pickup History -->
        <article class="card shadow-sm mb-3 rounded-4">
            <header class="card-header mt-2 fw-semibold bg-transparent border-bottom-0">
                <h2 class="card-title mb-0 h5"><i class="bi bi-clock-history text-primary me-1"></i> Pickup History</h2>
            </header>
            <hr class="mx-3 my-2" />
            <div class="card-body">
                @if (Model.AppoUser != null)
                {
                    <div class="mb-3 pb-3 border-bottom">
                        <div class="fw-semibold text-uppercase text-secondary small mb-1">AP-PO Pickup</div>
                        <div class="fw-medium text-secondary-emphasis">
                            <i class="bi bi-person me-1"></i> @Model.AppoUser.FullName
                        </div>
                        @if (Model.PickedUpAt.HasValue)
                        {
                            <small class="text-muted">
                                <i class="bi bi-calendar me-1"></i> @Model.PickedUpAt.Value.ToString("dd MMM yyyy HH:mm")
                            </small>
                        }
                    </div>
                }

                @if (Model.ApInvoiceUser != null)
                {
                    <div class="mb-3 pb-3 @(Model.ArUser != null ? "border-bottom" : "")">
                        <div class="fw-semibold text-uppercase text-secondary small mb-1">AP-Invoice Pickup</div>
                        <div class="fw-medium text-secondary-emphasis">
                            <i class="bi bi-person me-1"></i> @Model.ApInvoiceUser.FullName
                        </div>
                        @if (Model.ApInvoicePickedUpAt.HasValue)
                        {
                            <small class="text-muted">
                                <i class="bi bi-calendar me-1"></i> @Model.ApInvoicePickedUpAt.Value.ToString("dd MMM yyyy HH:mm")
                            </small>
                        }
                    </div>
                }

                @if (Model.ArUser != null)
                {
                    <div class="mb-0">
                        <div class="fw-semibold text-uppercase text-secondary small mb-1">AR Pickup</div>
                        <div class="fw-medium text-secondary-emphasis">
                            <i class="bi bi-person me-1"></i> @Model.ArUser.FullName
                        </div>
                        @if (Model.ArPickedUpAt.HasValue)
                        {
                            <small class="text-muted">
                                <i class="bi bi-calendar me-1"></i> @Model.ArPickedUpAt.Value.ToString("dd MMM yyyy HH:mm")
                            </small>
                        }
                    </div>
                }

                @if (Model.AppoUser == null && Model.ApInvoiceUser == null && Model.ArUser == null)
                {
                    <p class="text-muted mb-0">No pickup history available</p>
                }
            </div>
        </article>

        <!-- Timestamps -->
        <article class="card shadow-sm mb-3 rounded-4">
            <header class="card-header mt-2 fw-semibold bg-transparent border-bottom-0">
                <h2 class="card-title mb-0 h5"><i class="bi bi-calendar-check text-primary me-1"></i> Timestamps</h2>
            </header>
            <hr class="mx-3 my-2" />
            <div class="card-body">
                <dl class="mb-2">
                    <dt class="fw-semibold text-uppercase text-secondary small">Created</dt>
                    <dd class="fw-medium text-secondary-emphasis">@Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</dd>
                </dl>
                @if (Model.UpdatedAt.HasValue)
                {
                    <dl class="mb-0">
                        <dt class="fw-semibold text-uppercase text-secondary small">Updated</dt>
                        <dd class="fw-medium text-secondary-emphasis">@Model.UpdatedAt.Value.ToString("dd MMM yyyy HH:mm")</dd>
                    </dl>
                }
            </div>
        </article>
    </div>
</div>

@section Scripts {
    <script>
        (function() {
            var invoiceForm = document.getElementById('invoiceForm');
            var displayMode = document.getElementById('invoiceDisplayMode');
            var editMode = document.getElementById('invoiceEditMode');
            var btnEdit = document.getElementById('btnEditInvoice');
            var btnCancel = document.getElementById('btnCancelEdit');

            // Toggle to edit mode
            if (btnEdit) {
                btnEdit.addEventListener('click', function() {
                    displayMode.classList.add('d-none');
                    editMode.classList.remove('d-none');
                    btnEdit.classList.add('d-none');
                    document.getElementById('saNo').focus();
                });
            }

            // Cancel edit - back to display mode
            if (btnCancel) {
                btnCancel.addEventListener('click', function() {
                    editMode.classList.add('d-none');
                    displayMode.classList.remove('d-none');
                    btnEdit.classList.remove('d-none');
                });
            }

            // Form submit with confirmation
            if (invoiceForm) {
                invoiceForm.addEventListener('submit', function(e) {
                    e.preventDefault();
                    var form = this;

                    Swal.fire({
                        title: 'Simpan Invoice Data?',
                        text: 'Apakah Anda yakin ingin menyimpan data invoice ini?',
                        icon: 'question',
                        showCancelButton: true,
                        confirmButtonColor: '#0d6efd',
                        cancelButtonColor: '#6c757d',
                        confirmButtonText: '<i class="bi bi-save"></i> Ya, Simpan',
                        cancelButtonText: '<i class="bi bi-x"></i> Batal',
                        reverseButtons: true
                    }).then(function(result) {
                        if (result.isConfirmed) {
                            form.submit();
                        }
                    });
                });
            }
        })();
    </script>
}
