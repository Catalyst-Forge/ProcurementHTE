@using ProcurementHTE.Core.Interfaces
@model List<PendingApprovalItem>
@{
    ViewData["Title"] = "Pending Approvals";
    var currentPage = ViewBag.CurrentPage as int? ?? 1;
    var pageSize = ViewBag.PageSize as int? ?? 15;
    var totalCount = ViewBag.TotalCount as int? ?? 0;
    var totalPages = ViewBag.TotalPages as int? ?? 1;
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">
                <i class="bi bi-hourglass-split me-2 text-warning"></i>Pending Approvals
            </h4>
            <p class="text-muted mb-0">Procurement yang menunggu approval Anda</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-search me-1"></i>Tracking
            </a>
            <button type="button" id="refresh-btn" class="btn btn-outline-primary" 
                    hx-get="@Url.Action("PendingApprovals", "ProcurementTracking", new { page = currentPage, pageSize = pageSize, partial = true })"
                    hx-target="#pending-approvals-container"
                    hx-swap="innerHTML"
                    hx-indicator="#refresh-spinner">
                <span id="refresh-spinner" class="spinner-border spinner-border-sm htmx-indicator me-1" role="status"></span>
                <i class="bi bi-arrow-clockwise me-1"></i>Refresh
            </button>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-warning bg-opacity-10 rounded-circle p-3 me-3">
                        <i class="bi bi-hourglass-split text-warning fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Total Pending</div>
                        <div class="fs-4 fw-bold" id="pending-total-count">@totalCount</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-info bg-opacity-10 rounded-circle p-3 me-3">
                        <i class="bi bi-clock-history text-info fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Halaman</div>
                        <div class="fs-4 fw-bold">@currentPage / @totalPages</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 rounded-circle p-3 me-3">
                        <i class="bi bi-check2-circle text-success fs-4"></i>
                    </div>
                    <div>
                        <div class="text-muted small">Role Anda</div>
                        <div class="fs-6 fw-bold">
                            @if (User.IsInRole("Admin"))
                            {
                                <span class="badge bg-danger">Admin</span>
                            }
                            @if (User.IsInRole("Analyst HTE & LTS"))
                            {
                                <span class="badge bg-primary">Analyst HTE</span>
                            }
                            @if (User.IsInRole("Assistant Manager HTE"))
                            {
                                <span class="badge bg-info">Asst. Manager</span>
                            }
                            @if (User.IsInRole("Manager Transport & Logistic"))
                            {
                                <span class="badge bg-success">Manager</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Table Container -->
    <div id="pending-approvals-container" hx-boost="false">
        @await Html.PartialAsync("_PendingApprovalsTable", Model)
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Listen for HTMX after swap to update total count
            document.body.addEventListener('htmx:afterSwap', function(event) {
                if (event.detail.target.id === 'pending-approvals-container') {
                    const countEl = document.querySelector('#pending-total-count');
                    const newCount = document.querySelector('[data-total-count]');
                    if (countEl && newCount) {
                        countEl.textContent = newCount.dataset.totalCount;
                    }
                    // Also update sidebar badge
                    if (window.notificationSystem && window.notificationSystem.loadPendingApprovalCount) {
                        window.notificationSystem.loadPendingApprovalCount();
                    }
                }
            });

            // Refresh table when user returns to this page/tab
            document.addEventListener('visibilitychange', function() {
                if (document.visibilityState === 'visible') {
                    const refreshBtn = document.querySelector('#refresh-btn');
                    if (refreshBtn && typeof htmx !== 'undefined') {
                        // Only refresh if we're on this page
                        const container = document.querySelector('#pending-approvals-container');
                        if (container) {
                            htmx.trigger(refreshBtn, 'click');
                        }
                    }
                }
            });
        });
    </script>
}
