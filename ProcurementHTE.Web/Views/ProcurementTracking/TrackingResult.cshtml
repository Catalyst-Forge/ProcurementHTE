@model ProcurementHTE.Core.Models.DTOs.ProcurementTrackingDto
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
@using ProcurementHTE.Core.Enums

@{
    ViewData["Title"] = $"Tracking - {Model.ProcNum}";

    var statusColor = Model.CurrentStatus switch
    {
        ProcurementStatus.Rejected => "danger",
        ProcurementStatus.NeedsRevisionData => "warning",
        ProcurementStatus.NeedsRevisionPR => "warning",
        ProcurementStatus.DonePO => "success",
        _ => "primary"
    };

    // Check if current user can modify this procurement
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var isAdmin = User.IsInRole("Admin");
    var canModify = isAdmin || (!string.IsNullOrEmpty(Model.AppoUserId) && Model.AppoUserId == currentUserId);

    // Check if current user can approve based on role and status
    var isAnalyst = User.IsInRole("Analyst HTE & LTS");
    var isAsstManager = User.IsInRole("Assistant Manager HTE");
    var isManager = User.IsInRole("Manager Transport & Logistic");
    var canApprove = Model.IsWaitingApproval && (
        isAdmin ||
        (isAnalyst && Model.CurrentStatus == ProcurementStatus.WaitingApprovalAnalyst) ||
        (isAsstManager && Model.CurrentStatus == ProcurementStatus.WaitingApprovalAsstManager) ||
        (isManager && Model.CurrentStatus == ProcurementStatus.WaitingApprovalManager)
    );

    // Check if user can resubmit revision
    var isOperation = User.IsInRole("Operation");
    var isAppo = User.IsInRole("AP-PO");
    var isPicOps = !string.IsNullOrEmpty(Model.PicOpsUserId) && Model.PicOpsUserId == currentUserId;
    var isAssignedAppo = !string.IsNullOrEmpty(Model.AppoUserId) && Model.AppoUserId == currentUserId;
    var canResubmitData = Model.CurrentStatus == ProcurementStatus.NeedsRevisionData &&
        (isAdmin || isOperation || isAnalyst || isPicOps);
    var canResubmitPR = Model.CurrentStatus == ProcurementStatus.NeedsRevisionPR &&
        (isAdmin || isAppo || isAssignedAppo);
    var needsRevision = Model.CurrentStatus == ProcurementStatus.NeedsRevisionData || 
        Model.CurrentStatus == ProcurementStatus.NeedsRevisionPR;
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-2">
                <i class="bi bi-arrow-left me-1"></i>Kembali
            </a>
            <h4 class="fw-bold mb-1">@Model.ProcNum</h4>
            <span class="badge bg-@statusColor">@Model.CurrentStatusDescription</span>
            @if (!string.IsNullOrEmpty(Model.PrNumber))
            {
                <a asp-controller="PurchaseRequisitions" asp-action="Details" asp-route-id="@Model.PrId" class="badge bg-secondary text-decoration-none ms-2">
                    <i class="bi bi-link-45deg"></i> PR: @Model.PrNumber
                </a>
            }
        </div>
        <div>
            @if (Model.CanSendApproval && canModify)
            {
                <form asp-action="SendApproval" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="procurementId" value="@Model.ProcurementId" />
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-send me-1"></i>Send for Approval
                    </button>
                </form>
            }
        </div>
    </div>

    <div class="row g-4">
        <!-- Left Column -->
        <div class="col-lg-4">
            <!-- Procurement Info -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom">
                    <h6 class="mb-0 fw-bold">
                        <i class="bi bi-file-text me-2"></i>Informasi Procurement
                    </h6>
                </div>
                <div class="card-body">
                    <table class="table table-sm table-borderless mb-0">
                        <tr>
                            <td class="text-muted" style="width: 40%">Proc Number</td>
                            <td class="fw-medium">@Model.ProcNum</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Project</td>
                            <td>
                                @{
                                    var projectBadgeClass = Model.ProjectRegion switch
                                    {
                                        ProjectRegion.SMTR => "bg-success",
                                        ProjectRegion.JWKT => "bg-primary",
                                        ProjectRegion.AKOMODASI => "bg-info",
                                        _ => "bg-secondary"
                                    };
                                }
                                <span class="badge @projectBadgeClass">@Model.ProjectRegion</span>
                            </td>
                        </tr>
                        <tr>
                            <td class="text-muted">WO Number</td>
                            <td>@Model.Wonum</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Job Name</td>
                            <td>@Model.JobName</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Date</td>
                            <td>@Model.DocumentDate.ToString("dd MMM yyyy")</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Documents</td>
                            <td>
                                <span class="badge bg-@(Model.AllMandatoryDocsReady ? "success" : "warning")">
                                    @Model.UploadedMandatoryDocs/@Model.TotalMandatoryDocs uploaded
                                </span>
                            </td>
                        </tr>
                    </table>

                    @if (!string.IsNullOrEmpty(Model.IspaNumber))
                    {
                        <hr class="my-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted small">ISPA Number</span>
                            <span class="fw-medium">@Model.IspaNumber</span>
                        </div>
                        @if (Model.IspaDate.HasValue || Model.IspaSubmitDate.HasValue)
                        {
                            <div class="small text-muted mb-1">
                                @if (Model.IspaDate.HasValue)
                                {
                                    <span><i class="bi bi-calendar me-1"></i>Tgl ISPA: @Model.IspaDate.Value.ToString("dd MMM yyyy")</span>
                                }
                                @if (Model.IspaSubmitDate.HasValue)
                                {
                                    <span class="ms-2"><i class="bi bi-send me-1"></i>Tgl Submit: @Model.IspaSubmitDate.Value.ToString("dd MMM yyyy")</span>
                                }
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.IspaFileName))
                        {
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <span class="small text-truncate" style="max-width: 150px;" title="@Model.IspaFileName">
                                    <i class="bi bi-file-pdf text-danger me-1"></i>@Model.IspaFileName
                                </span>
                                <a asp-controller="ProcurementTracking" asp-action="DownloadIspaFile" asp-route-procurementId="@Model.ProcurementId" 
                                   class="btn btn-sm btn-outline-primary" title="Download ISPA">
                                    <i class="bi bi-download"></i>
                                </a>
                            </div>
                        }
                        <small class="text-muted">Submitted: @Model.IspaSubmittedAt?.ToString("dd MMM yyyy HH:mm")</small>
                    }

                    @if (!string.IsNullOrEmpty(Model.HardcopyEvidenceFileName))
                    {
                        <hr class="my-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small">Hardcopy Evidence</span>
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="showHardcopyEvidence('@Model.ProcurementId')">
                                <i class="bi bi-eye me-1"></i>View
                            </button>
                        </div>
                        <small class="text-muted">@Model.HardcopySubmittedAt?.ToString("dd MMM yyyy HH:mm")</small>
                    }

                    @if (!string.IsNullOrEmpty(Model.PoNumber))
                    {
                        <hr class="my-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small">PO Number</span>
                            <span class="fw-medium text-success">@Model.PoNumber</span>
                        </div>
                        <small class="text-muted">@Model.PoSubmittedAt?.ToString("dd MMM yyyy HH:mm")</small>
                    }
                </div>
            </div>

            <!-- QR Code -->
            @if (Model.IsWaitingApproval && !string.IsNullOrEmpty(Model.ApprovalQrUrl))
            {
                var qrImageUrl = Model.ApprovalQrUrl;
                var qrImageUrlLarge = Model.ApprovalQrUrl?.Replace("size=200x200", "size=300x300");

                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom">
                        <h6 class="mb-0 fw-bold">
                            <i class="bi bi-qr-code me-2"></i>QR Code Approval
                        </h6>
                    </div>
                    <div class="card-body text-center">
                        <img src="@qrImageUrl" alt="QR Code Approval" class="img-fluid mb-2" style="max-width: 200px;">
                        <p class="text-muted small mb-1">Scan untuk approval via mobile</p>
                        <code class="small">@Model.ProcNum</code>
                        <div class="mt-3">
                            <a href="@qrImageUrlLarge" download="QR-@(Model.ProcNum).png" class="btn btn-sm btn-outline-primary me-2">
                                <i class="bi bi-download me-1"></i>Download
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="printQrCode('@qrImageUrlLarge', '@Model.ProcNum')">
                                <i class="bi bi-printer me-1"></i>Print
                            </button>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom">
                        <h6 class="mb-0 fw-bold">
                            <i class="bi bi-qr-code me-2"></i>QR Code
                        </h6>
                    </div>
                    <div class="card-body text-center">
                        <div class="text-muted py-3">
                            @if (!Model.IsWaitingApproval)
                            {
                                <span><i class="bi bi-info-circle me-1"></i>QR hanya tersedia saat status Waiting Approval</span>
                            }
                            else
                            {
                                <span><i class="bi bi-exclamation-circle me-1"></i>QR belum di-generate. Kirim untuk approval terlebih dahulu.</span>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Responsible Users -->
            <div class="card border-0 shadow-sm mt-4">
                <div class="card-header bg-white border-bottom">
                    <h6 class="mb-0 fw-bold">
                        <i class="bi bi-people me-2"></i>Responsible Users
                    </h6>
                </div>
                <div class="card-body">
                    <table class="table table-sm table-borderless mb-0">
                        <tr>
                            <td class="text-muted" style="width: 45%">
                                @(Model.AnalystHtePjs ? "Pjs. " : "")Analyst HTE
                                @if (Model.AnalystHtePjs)
                                {
                                    <span class="badge bg-warning text-dark ms-1" title="Penanggung Jawab Sementara">Pjs</span>
                                }
                            </td>
                            <td>@(Model.AnalystHteUserName ?? "-")</td>
                        </tr>
                        <tr>
                            <td class="text-muted">
                                @(Model.AssistantManagerPjs ? "Pjs. " : "")Asst. Manager
                                @if (Model.AssistantManagerPjs)
                                {
                                    <span class="badge bg-warning text-dark ms-1" title="Penanggung Jawab Sementara">Pjs</span>
                                }
                            </td>
                            <td>@(Model.AssistantManagerUserName ?? "-")</td>
                        </tr>
                        <tr>
                            <td class="text-muted">
                                @(Model.ManagerPjs ? "Pjs. " : "")Manager
                                @if (Model.ManagerPjs)
                                {
                                    <span class="badge bg-warning text-dark ms-1" title="Penanggung Jawab Sementara">Pjs</span>
                                }
                            </td>
                            <td>@(Model.ManagerUserName ?? "-")</td>
                        </tr>
                        @if (Model.RequiredApprovalLevel >= 5)
                        {
                            <tr>
                                <td class="text-muted">
                                    @(Model.VicePresidentPjs ? "Pjs. " : "")Vice President
                                    @if (Model.VicePresidentPjs)
                                    {
                                        <span class="badge bg-warning text-dark ms-1" title="Penanggung Jawab Sementara">Pjs</span>
                                    }
                                </td>
                                <td>@(Model.VicePresidentUserName ?? "-")</td>
                            </tr>
                        }
                        @if (Model.RequiredApprovalLevel >= 6)
                        {
                            <tr>
                                <td class="text-muted">
                                    @(Model.OperationDirectorPjs ? "Pjs. " : "")Operation Director
                                    @if (Model.OperationDirectorPjs)
                                    {
                                        <span class="badge bg-warning text-dark ms-1" title="Penanggung Jawab Sementara">Pjs</span>
                                    }
                                </td>
                                <td>@(Model.OperationDirectorUserName ?? "-")</td>
                            </tr>
                        }
                        @if (Model.RequiredApprovalLevel >= 7)
                        {
                            <tr>
                                <td class="text-muted">
                                    @(Model.PresidentDirectorPjs ? "Pjs. " : "")President Director
                                    @if (Model.PresidentDirectorPjs)
                                    {
                                        <span class="badge bg-warning text-dark ms-1" title="Penanggung Jawab Sementara">Pjs</span>
                                    }
                                </td>
                                <td>@(Model.PresidentDirectorUserName ?? "-")</td>
                            </tr>
                        }
                    </table>
                </div>
            </div>
        </div>

        <!-- Right Column -->
        <div class="col-lg-8">
            <!-- PnL Summary Card -->
            @await Html.PartialAsync("_PnLSummaryCard", Model.PnLSummary)

            <!-- Progress -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom">
                    <h6 class="mb-0 fw-bold">
                        <i class="bi bi-diagram-3 me-2"></i>Progress Tracking
                    </h6>
                </div>
                <div class="card-body">
                    @await Html.PartialAsync("_ProcurementProgressBar", Model)
                </div>
            </div>

            <!-- Action Buttons - Only visible for Admin or Assigned Analyst -->
            @if (canModify)
            {
                @if (Model.CurrentStatus == ProcurementHTE.Core.Enums.ProcurementStatus.OnSubmitISPA)
                {
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-white border-bottom">
                            <h6 class="mb-0 fw-bold">
                                <i class="bi bi-pencil-square me-2"></i>Submit ISPA
                            </h6>
                        </div>
                        <div class="card-body">
                            <form asp-action="SubmitIspa" method="post" enctype="multipart/form-data" hx-boost="false">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="procurementId" value="@Model.ProcurementId" />
                                
                                <div class="row g-3">
                                    <!-- Nomor ISPA -->
                                    <div class="col-md-6">
                                        <label class="form-label small">Nomor ISPA <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" name="ispaNumber" placeholder="Masukkan nomor ISPA" required />
                                    </div>
                                    
                                    <!-- Tanggal ISPA -->
                                    <div class="col-md-3">
                                        <label class="form-label small">Tanggal ISPA <span class="text-danger">*</span></label>
                                        <input type="date" class="form-control" name="ispaDate" required />
                                    </div>
                                    
                                    <!-- Tanggal Submit ISPA -->
                                    <div class="col-md-3">
                                        <label class="form-label small">Tanggal Submit ISPA <span class="text-danger">*</span></label>
                                        <input type="date" class="form-control" name="ispaSubmitDate" required />
                                    </div>
                                    
                                    <!-- Upload File ISPA -->
                                    <div class="col-12">
                                        <label class="form-label small">Upload Dokumen ISPA (PDF) <span class="text-danger">*</span></label>
                                        <input type="file" class="form-control" name="ispaFile" accept="application/pdf,.pdf" required />
                                        <small class="form-text text-muted">Format: PDF. Maksimal: 50MB</small>
                                    </div>
                                    
                                    <!-- Submit Button -->
                                    <div class="col-12">
                                        <button type="submit" class="btn btn-primary">
                                            <i class="bi bi-check-lg me-1"></i>Submit ISPA
                                        </button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                }

                @if (Model.CurrentStatus == ProcurementHTE.Core.Enums.ProcurementStatus.OnSubmitHardcopy)
                {
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-white border-bottom">
                            <h6 class="mb-0 fw-bold">
                                <i class="bi bi-cloud-upload me-2"></i>Upload Hardcopy Evidence
                            </h6>
                        </div>
                        <div class="card-body">
                            <form asp-action="SubmitJustification" method="post" enctype="multipart/form-data" hx-boost="false">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="procurementId" value="@Model.ProcurementId" />
                                <div class="mb-3">
                                    <input type="file" class="form-control" name="justificationFile" accept="image/*" required />
                                    <small class="form-text text-muted">Format: JPG, PNG, GIF. Max: 10MB</small>
                                </div>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-upload me-1"></i>Upload
                                </button>
                            </form>
                        </div>
                    </div>
                }

                @if (Model.CurrentStatus == ProcurementHTE.Core.Enums.ProcurementStatus.OnSubmitPO)
                {
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-white border-bottom">
                            <h6 class="mb-0 fw-bold">
                                <i class="bi bi-pencil-square me-2"></i>Submit PO Number
                            </h6>
                        </div>
                        <div class="card-body">
                            <form asp-action="SubmitPo" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="procurementId" value="@Model.ProcurementId" />
                                <div class="input-group">
                                    <input type="text" class="form-control" name="poNumber" placeholder="Masukkan nomor PO" required />
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-check-lg me-1"></i>Submit
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                }
            }

            @* Revision Status Section - For PIC Ops or APPO when revision is needed *@
            @if (needsRevision)
            {
                var isDataRevision = Model.CurrentStatus == ProcurementStatus.NeedsRevisionData;
                var revisionType = isDataRevision ? "Data" : "PR/Document";
                var responsibleRole = isDataRevision ? "PIC Ops / Analyst HTE" : "AP-PO";
                var cardBorderClass = isDataRevision ? "border-warning" : "border-primary";
                var headerBgClass = isDataRevision ? "bg-warning-subtle text-warning" : "bg-primary-subtle text-primary";
                var canResubmit = isDataRevision ? canResubmitData : canResubmitPR;

                <div class="card border-0 shadow-sm mb-4 @cardBorderClass">
                    <div class="card-header @headerBgClass border-bottom">
                        <h6 class="mb-0 fw-bold">
                            <i class="bi bi-arrow-repeat me-2"></i>Revision Required - @revisionType
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-warning mb-3">
                            <i class="bi bi-exclamation-triangle me-2"></i>
                            <strong>Perlu Revisi:</strong> Procurement ini dikembalikan untuk perbaikan oleh approver.
                            <br/>
                            <small class="text-muted">Ditangani oleh: <strong>@responsibleRole</strong></small>
                        </div>

                        @if (!string.IsNullOrEmpty(Model.RejectionNote))
                        {
                            <div class="mb-3">
                                <label class="form-label small text-muted fw-bold">Catatan dari Approver:</label>
                                <div class="p-2 bg-light rounded border">
                                    @Model.RejectionNote
                                </div>
                            </div>
                        }

                        @if (Model.PendingRevisionSymptoms.HasValue && Model.PendingRevisionSymptoms.Value != RejectionSymptom.None)
                        {
                            <div class="mb-3">
                                <label class="form-label small text-muted fw-bold">Masalah yang Perlu Diperbaiki:</label>
                                <ul class="list-group list-group-flush">
                                    @foreach (var symptomName in Model.PendingRevisionSymptoms.Value.GetSelectedDisplayNames())
                                    {
                                        <li class="list-group-item py-1 px-2 bg-transparent">
                                            <i class="bi bi-dot text-danger"></i> @symptomName
                                        </li>
                                    }
                                </ul>
                            </div>
                        }

                        @if (Model.RevisionCount > 0)
                        {
                            <div class="mb-3">
                                <small class="text-muted">Revisi ke-@Model.RevisionCount</small>
                            </div>
                        }

                        @if (canResubmit)
                        {
                            <hr/>
                            <p class="text-muted small mb-3">
                                Setelah melakukan perbaikan yang diperlukan, klik tombol di bawah untuk submit ulang.
                            </p>
                            <button type="button" class="btn btn-success w-100" id="resubmitBtn" data-procurement-id="@Model.ProcurementId">
                                <i class="bi bi-send me-1"></i>Submit Revision
                            </button>
                        }
                        else
                        {
                            <div class="alert alert-secondary mb-0">
                                <i class="bi bi-person-lock me-2"></i>
                                Menunggu <strong>@responsibleRole</strong> untuk melakukan perbaikan.
                            </div>
                        }
                    </div>
                </div>
            }

            @* Manual Approval Section - For Analyst, Asst Manager, Manager, or Admin *@
            @if (canApprove)
            {
                <div class="card border-0 shadow-sm mb-4 border-success">
                    <div class="card-header bg-success-subtle border-bottom">
                        <h6 class="mb-0 fw-bold text-success">
                            <i class="bi bi-check-circle me-2"></i>Approval Actions
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-info-circle me-2"></i>
                            <strong>Current Status:</strong> @Model.CurrentStatusDescription
                            <br/>
                            <small class="text-muted">Anda dapat melakukan approval atau reject untuk procurement ini.</small>
                        </div>

                        <div class="row g-3">
                            @* Approve Form *@
                            <div class="col-md-6">
                                <form asp-action="Approve" method="post" id="approveForm">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="procurementId" value="@Model.ProcurementId" />
                                    <div class="mb-3">
                                        <label class="form-label small text-muted">Catatan Approval (Opsional)</label>
                                        <input type="text" class="form-control" name="approvalNote" placeholder="Masukkan catatan..." />
                                    </div>
                                    <button type="button" class="btn btn-success w-100" onclick="confirmApprove()">
                                        <i class="bi bi-check-lg me-1"></i>Approve
                                    </button>
                                </form>
                            </div>

                            @* Return for Revision Form *@
                            <div class="col-md-6">
                                <button type="button" class="btn btn-danger w-100" data-bs-toggle="modal" data-bs-target="#rejectModal">
                                    <i class="bi bi-x-lg me-1"></i>Return for Revision
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Reject/Revision Modal -->
                <div class="modal fade" id="rejectModal" tabindex="-1" aria-labelledby="rejectModalLabel" aria-hidden="true">
                    <div class="modal-dialog modal-lg">
                        <div class="modal-content">
                            <div class="modal-header bg-danger text-white">
                                <h5 class="modal-title" id="rejectModalLabel">
                                    <i class="bi bi-arrow-return-left me-2"></i>Return for Revision
                                </h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <form id="revisionForm">
                                @Html.AntiForgeryToken()
                                <div class="modal-body">
                                    <input type="hidden" name="procurementId" value="@Model.ProcurementId" />
                                    
                                    <div class="alert alert-info mb-3">
                                        <i class="bi bi-info-circle me-2"></i>
                                        Pilih masalah yang ditemukan. Masalah akan ditangani secara berurutan - <strong>Data Issues</strong> terlebih dahulu, kemudian <strong>PR Issues</strong>.
                                    </div>

                                    <div class="row g-3">
                                        @* Data Issues Group *@
                                        <div class="col-md-6">
                                            <div class="card border-warning h-100">
                                                <div class="card-header bg-warning-subtle">
                                                    <h6 class="mb-0 fw-bold text-warning">
                                                        <i class="bi bi-database me-2"></i>Data Issues
                                                    </h6>
                                                    <small class="text-muted">Ditangani oleh PIC Ops</small>
                                                </div>
                                                <div class="card-body">
                                                    <div class="form-check mb-2">
                                                        <input class="form-check-input symptom-check" type="checkbox" name="symptoms" value="1" id="symptom1">
                                                        <label class="form-check-label" for="symptom1">Anomali nilai P&L</label>
                                                    </div>
                                                    <div class="form-check mb-2">
                                                        <input class="form-check-input symptom-check" type="checkbox" name="symptoms" value="2" id="symptom2">
                                                        <label class="form-check-label" for="symptom2">Data tanggal tidak sesuai</label>
                                                    </div>
                                                    <div class="form-check mb-2">
                                                        <input class="form-check-input symptom-check" type="checkbox" name="symptoms" value="4" id="symptom4">
                                                        <label class="form-check-label" for="symptom4">Vendor/SPK tidak valid</label>
                                                    </div>
                                                    <div class="form-check mb-2">
                                                        <input class="form-check-input symptom-check" type="checkbox" name="symptoms" value="8" id="symptom8">
                                                        <label class="form-check-label" for="symptom8">Data pekerjaan tidak sesuai</label>
                                                    </div>
                                                    <div class="form-check mb-2">
                                                        <input class="form-check-input symptom-check" type="checkbox" name="symptoms" value="16" id="symptom16">
                                                        <label class="form-check-label" for="symptom16">Data kontrak tidak valid</label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        @* PR Issues Group *@
                                        <div class="col-md-6">
                                            <div class="card border-primary h-100">
                                                <div class="card-header bg-primary-subtle">
                                                    <h6 class="mb-0 fw-bold text-primary">
                                                        <i class="bi bi-file-earmark-text me-2"></i>PR Issues
                                                    </h6>
                                                    <small class="text-muted">Ditangani oleh AP-PO</small>
                                                </div>
                                                <div class="card-body">
                                                    <div class="form-check mb-2">
                                                        <input class="form-check-input symptom-check pr-symptom" type="checkbox" name="symptoms" value="32" id="symptom32">
                                                        <label class="form-check-label" for="symptom32">
                                                            <strong class="text-danger">PR tidak bisa digabung</strong>
                                                            <small class="d-block text-muted">Akan unlink dan reset ke draft</small>
                                                        </label>
                                                    </div>
                                                    <div class="form-check mb-2">
                                                        <input class="form-check-input symptom-check" type="checkbox" name="symptoms" value="64" id="symptom64">
                                                        <label class="form-check-label" for="symptom64">Linking PR tidak sesuai</label>
                                                    </div>
                                                    <div class="form-check mb-2">
                                                        <input class="form-check-input symptom-check" type="checkbox" name="symptoms" value="128" id="symptom128">
                                                        <label class="form-check-label" for="symptom128">Dokumen tidak lengkap</label>
                                                    </div>
                                                    <div class="form-check mb-2">
                                                        <input class="form-check-input symptom-check" type="checkbox" name="symptoms" value="256" id="symptom256">
                                                        <label class="form-check-label" for="symptom256">Format dokumen tidak valid</label>
                                                    </div>
                                                    <div class="form-check mb-2">
                                                        <input class="form-check-input symptom-check" type="checkbox" name="symptoms" value="512" id="symptom512">
                                                        <label class="form-check-label" for="symptom512">Dokumen kadaluarsa</label>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        @* Other Issues *@
                                        <div class="col-12">
                                            <div class="form-check">
                                                <input class="form-check-input symptom-check" type="checkbox" name="symptoms" value="1024" id="symptom1024">
                                                <label class="form-check-label" for="symptom1024">
                                                    Masalah lainnya (jelaskan di catatan)
                                                </label>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="mt-3">
                                        <label class="form-label fw-bold">Catatan Rejection <span class="text-danger">*</span></label>
                                        <textarea class="form-control" name="rejectionNote" id="rejectionNoteModal" rows="3" placeholder="Jelaskan detail masalah yang ditemukan..." required></textarea>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Batal</button>
                                    <button type="button" class="btn btn-danger" id="submitRevisionBtn">
                                        <i class="bi bi-arrow-return-left me-1"></i>Return for Revision
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }

            <!-- History -->
            @if (Model.StatusHistory.Any())
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom">
                        <h6 class="mb-0 fw-bold">
                            <i class="bi bi-clock-history me-2"></i>Status History
                        </h6>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="small text-muted">Date</th>
                                    <th class="small text-muted">Status</th>
                                    <th class="small text-muted">Changed By</th>
                                    <th class="small text-muted">Note</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var history in Model.StatusHistory.OrderByDescending(h => h.ChangedAt))
                                {
                                    <tr>
                                        <td>
                                            <div>@history.ChangedAt.ToString("dd MMM yyyy")</div>
                                            <small class="text-muted">@history.ChangedAt.ToString("HH:mm")</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-secondary">@history.StatusDescription</span>
                                        </td>
                                        <td>@history.ChangedByFullName</td>
                                        <td class="text-muted">@(string.IsNullOrEmpty(history.Note) ? "-" : history.Note)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<script src="~/js/tracking-result.js"></script>
