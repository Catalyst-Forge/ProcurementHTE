@model ProcurementHTE.Core.Models.DTOs.ProcurementTrackingDto
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = $"Tracking - {Model.ProcNum}";

    var statusColor = Model.CurrentStatus switch
    {
        ProcurementHTE.Core.Enums.ProcurementStatus.Rejected => "danger",
        ProcurementHTE.Core.Enums.ProcurementStatus.DonePO => "success",
        _ => "primary"
    };

    // Check if current user can modify this procurement
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var isAdmin = User.IsInRole("Admin");
    var canModify = isAdmin || (!string.IsNullOrEmpty(Model.AppoUserId) && Model.AppoUserId == currentUserId);

    // Check if current user can approve based on role and status
    var isAnalyst = User.IsInRole("Analyst HTE & LTS");
    var isAsstManager = User.IsInRole("Assistant Manager HTE");
    var isManager = User.IsInRole("Manager Transport & Logistic");
    var canApprove = Model.IsWaitingApproval && (
        isAdmin ||
        (isAnalyst && Model.CurrentStatus == ProcurementHTE.Core.Enums.ProcurementStatus.WaitingApprovalAnalyst) ||
        (isAsstManager && Model.CurrentStatus == ProcurementHTE.Core.Enums.ProcurementStatus.WaitingApprovalAsstManager) ||
        (isManager && Model.CurrentStatus == ProcurementHTE.Core.Enums.ProcurementStatus.WaitingApprovalManager)
    );
}

<div class="container-fluid py-4">
    <!-- Header -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div>
            <a asp-action="Index" class="btn btn-sm btn-outline-secondary mb-2">
                <i class="bi bi-arrow-left me-1"></i>Kembali
            </a>
            <h4 class="fw-bold mb-1">@Model.ProcNum</h4>
            <span class="badge bg-@statusColor">@Model.CurrentStatusDescription</span>
            @if (!string.IsNullOrEmpty(Model.PrNumber))
            {
                <a asp-controller="PurchaseRequisitions" asp-action="Details" asp-route-id="@Model.PrId" class="badge bg-secondary text-decoration-none ms-2">
                    <i class="bi bi-link-45deg"></i> PR: @Model.PrNumber
                </a>
            }
        </div>
        <div>
            @if (Model.CanSendApproval && canModify)
            {
                <form asp-action="SendApproval" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="procurementId" value="@Model.ProcurementId" />
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-send me-1"></i>Send for Approval
                    </button>
                </form>
            }
        </div>
    </div>

    <div class="row g-4">
        <!-- Left Column -->
        <div class="col-lg-4">
            <!-- Procurement Info -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom">
                    <h6 class="mb-0 fw-bold">
                        <i class="bi bi-file-text me-2"></i>Informasi Procurement
                    </h6>
                </div>
                <div class="card-body">
                    <table class="table table-sm table-borderless mb-0">
                        <tr>
                            <td class="text-muted" style="width: 40%">Proc Number</td>
                            <td class="fw-medium">@Model.ProcNum</td>
                        </tr>
                        <tr>
                            <td class="text-muted">WO Number</td>
                            <td>@Model.Wonum</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Job Name</td>
                            <td>@Model.JobName</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Date</td>
                            <td>@Model.DocumentDate.ToString("dd MMM yyyy")</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Documents</td>
                            <td>
                                <span class="badge bg-@(Model.AllMandatoryDocsReady ? "success" : "warning")">
                                    @Model.UploadedMandatoryDocs/@Model.TotalMandatoryDocs uploaded
                                </span>
                            </td>
                        </tr>
                    </table>

                    @if (!string.IsNullOrEmpty(Model.IspaNumber))
                    {
                        <hr class="my-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small">ISPA Number</span>
                            <span class="fw-medium">@Model.IspaNumber</span>
                        </div>
                        <small class="text-muted">@Model.IspaSubmittedAt?.ToString("dd MMM yyyy HH:mm")</small>
                    }

                    @if (!string.IsNullOrEmpty(Model.HardcopyEvidenceFileName))
                    {
                        <hr class="my-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small">Hardcopy Evidence</span>
                            <button type="button" class="btn btn-sm btn-outline-primary" onclick="showHardcopyEvidence('@Model.ProcurementId')">
                                <i class="bi bi-eye me-1"></i>View
                            </button>
                        </div>
                        <small class="text-muted">@Model.HardcopySubmittedAt?.ToString("dd MMM yyyy HH:mm")</small>
                    }

                    @if (!string.IsNullOrEmpty(Model.PoNumber))
                    {
                        <hr class="my-3">
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-muted small">PO Number</span>
                            <span class="fw-medium text-success">@Model.PoNumber</span>
                        </div>
                        <small class="text-muted">@Model.PoSubmittedAt?.ToString("dd MMM yyyy HH:mm")</small>
                    }
                </div>
            </div>

            <!-- QR Code -->
            @if (Model.IsWaitingApproval && !string.IsNullOrEmpty(Model.ApprovalQrUrl))
            {
                var qrImageUrl = Model.ApprovalQrUrl;
                var qrImageUrlLarge = Model.ApprovalQrUrl?.Replace("size=200x200", "size=300x300");

                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom">
                        <h6 class="mb-0 fw-bold">
                            <i class="bi bi-qr-code me-2"></i>QR Code Approval
                        </h6>
                    </div>
                    <div class="card-body text-center">
                        <img src="@qrImageUrl" alt="QR Code Approval" class="img-fluid mb-2" style="max-width: 200px;">
                        <p class="text-muted small mb-1">Scan untuk approval via mobile</p>
                        <code class="small">@Model.ProcNum</code>
                        <div class="mt-3">
                            <a href="@qrImageUrlLarge" download="QR-@(Model.ProcNum).png" class="btn btn-sm btn-outline-primary me-2">
                                <i class="bi bi-download me-1"></i>Download
                            </a>
                            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="printQrCode('@qrImageUrlLarge', '@Model.ProcNum')">
                                <i class="bi bi-printer me-1"></i>Print
                            </button>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom">
                        <h6 class="mb-0 fw-bold">
                            <i class="bi bi-qr-code me-2"></i>QR Code
                        </h6>
                    </div>
                    <div class="card-body text-center">
                        <div class="text-muted py-3">
                            @if (!Model.IsWaitingApproval)
                            {
                                <span><i class="bi bi-info-circle me-1"></i>QR hanya tersedia saat status Waiting Approval</span>
                            }
                            else
                            {
                                <span><i class="bi bi-exclamation-circle me-1"></i>QR belum di-generate. Kirim untuk approval terlebih dahulu.</span>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Responsible Users -->
            <div class="card border-0 shadow-sm mt-4">
                <div class="card-header bg-white border-bottom">
                    <h6 class="mb-0 fw-bold">
                        <i class="bi bi-people me-2"></i>Responsible Users
                    </h6>
                </div>
                <div class="card-body">
                    <table class="table table-sm table-borderless mb-0">
                        <tr>
                            <td class="text-muted" style="width: 45%">Analyst HTE</td>
                            <td>@(Model.AnalystHteUserName ?? "-")</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Asst. Manager</td>
                            <td>@(Model.AssistantManagerUserName ?? "-")</td>
                        </tr>
                        <tr>
                            <td class="text-muted">Manager</td>
                            <td>@(Model.ManagerUserName ?? "-")</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <!-- Right Column -->
        <div class="col-lg-8">
            <!-- Progress -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom">
                    <h6 class="mb-0 fw-bold">
                        <i class="bi bi-diagram-3 me-2"></i>Progress Tracking
                    </h6>
                </div>
                <div class="card-body">
                    @await Html.PartialAsync("_ProcurementProgressBar", Model)
                </div>
            </div>

            <!-- Action Buttons - Only visible for Admin or Assigned Analyst -->
            @if (canModify)
            {
                @if (Model.CurrentStatus == ProcurementHTE.Core.Enums.ProcurementStatus.OnSubmitISPA)
                {
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-white border-bottom">
                            <h6 class="mb-0 fw-bold">
                                <i class="bi bi-pencil-square me-2"></i>Submit ISPA Number
                            </h6>
                        </div>
                        <div class="card-body">
                            <form asp-action="SubmitIspa" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="procurementId" value="@Model.ProcurementId" />
                                <div class="input-group">
                                    <input type="text" class="form-control" name="ispaNumber" placeholder="Masukkan nomor ISPA" required />
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-check-lg me-1"></i>Submit
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                }

                @if (Model.CurrentStatus == ProcurementHTE.Core.Enums.ProcurementStatus.OnSubmitHardcopy)
                {
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-white border-bottom">
                            <h6 class="mb-0 fw-bold">
                                <i class="bi bi-cloud-upload me-2"></i>Upload Hardcopy Evidence
                            </h6>
                        </div>
                        <div class="card-body">
                            <form asp-action="SubmitJustification" method="post" enctype="multipart/form-data" hx-boost="false">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="procurementId" value="@Model.ProcurementId" />
                                <div class="mb-3">
                                    <input type="file" class="form-control" name="justificationFile" accept="image/*" required />
                                    <small class="form-text text-muted">Format: JPG, PNG, GIF. Max: 10MB</small>
                                </div>
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-upload me-1"></i>Upload
                                </button>
                            </form>
                        </div>
                    </div>
                }

                @if (Model.CurrentStatus == ProcurementHTE.Core.Enums.ProcurementStatus.OnSubmitPO)
                {
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-white border-bottom">
                            <h6 class="mb-0 fw-bold">
                                <i class="bi bi-pencil-square me-2"></i>Submit PO Number
                            </h6>
                        </div>
                        <div class="card-body">
                            <form asp-action="SubmitPo" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="procurementId" value="@Model.ProcurementId" />
                                <div class="input-group">
                                    <input type="text" class="form-control" name="poNumber" placeholder="Masukkan nomor PO" required />
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-check-lg me-1"></i>Submit
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                }
            }

            @* Manual Approval Section - For Analyst, Asst Manager, Manager, or Admin *@
            @if (canApprove)
            {
                <div class="card border-0 shadow-sm mb-4 border-success">
                    <div class="card-header bg-success-subtle border-bottom">
                        <h6 class="mb-0 fw-bold text-success">
                            <i class="bi bi-check-circle me-2"></i>Approval Actions
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="alert alert-info mb-3">
                            <i class="bi bi-info-circle me-2"></i>
                            <strong>Current Status:</strong> @Model.CurrentStatusDescription
                            <br/>
                            <small class="text-muted">Anda dapat melakukan approval atau reject untuk procurement ini.</small>
                        </div>

                        <div class="row g-3">
                            @* Approve Form *@
                            <div class="col-md-6">
                                <form asp-action="Approve" method="post" id="approveForm">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="procurementId" value="@Model.ProcurementId" />
                                    <div class="mb-3">
                                        <label class="form-label small text-muted">Catatan Approval (Opsional)</label>
                                        <input type="text" class="form-control" name="approvalNote" placeholder="Masukkan catatan..." />
                                    </div>
                                    <button type="button" class="btn btn-success w-100" onclick="confirmApprove()">
                                        <i class="bi bi-check-lg me-1"></i>Approve
                                    </button>
                                </form>
                            </div>

                            @* Reject Form *@
                            <div class="col-md-6">
                                <form asp-action="Reject" method="post" id="rejectForm">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="procurementId" value="@Model.ProcurementId" />
                                    <div class="mb-3">
                                        <label class="form-label small text-muted">Alasan Reject <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" name="rejectionNote" id="rejectionNote" placeholder="Masukkan alasan reject..." required />
                                    </div>
                                    <button type="button" class="btn btn-danger w-100" onclick="confirmReject()">
                                        <i class="bi bi-x-lg me-1"></i>Reject
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- History -->
            @if (Model.StatusHistory.Any())
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom">
                        <h6 class="mb-0 fw-bold">
                            <i class="bi bi-clock-history me-2"></i>Status History
                        </h6>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="small text-muted">Date</th>
                                    <th class="small text-muted">Status</th>
                                    <th class="small text-muted">Changed By</th>
                                    <th class="small text-muted">Note</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var history in Model.StatusHistory.OrderByDescending(h => h.ChangedAt))
                                {
                                    <tr>
                                        <td>
                                            <div>@history.ChangedAt.ToString("dd MMM yyyy")</div>
                                            <small class="text-muted">@history.ChangedAt.ToString("HH:mm")</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-secondary">@history.StatusDescription</span>
                                        </td>
                                        <td>@history.ChangedByFullName</td>
                                        <td class="text-muted">@(string.IsNullOrEmpty(history.Note) ? "-" : history.Note)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<script>
    (function() {
        window.printQrCode = function(qrUrl, procNum) {
            var w = window.open('', '_blank', 'width=400,height=500');
            if (!w) {
                alert('Popup blocked. Mohon izinkan popup untuk mencetak QR.');
                return;
            }
            var htmlContent = '<!DOCTYPE html><html><head><title>QR Code - ' + procNum + '</title>' +
                '<style>body{display:flex;flex-direction:column;align-items:center;justify-content:center;height:100vh;margin:0;font-family:Arial,sans-serif;}h3{margin-bottom:10px;}p{margin:5px 0;color:#666;}img{max-width:300px;margin:20px 0;}</style>' +
                '</head><body><h3>QR Code Approval</h3><p>' + procNum + '</p>' +
                '<img src="' + qrUrl + '" alt="QR Code" onload="window.print()"></body></html>';
            w.document.write(htmlContent);
            w.document.close();
        };

        window.confirmApprove = function() {
            Swal.fire({
                title: 'Konfirmasi Approval',
                text: 'Apakah Anda yakin ingin meng-approve procurement ini?',
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#198754',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Ya, Approve',
                cancelButtonText: 'Batal'
            }).then(function(result) {
                if (result.isConfirmed) {
                    document.getElementById('approveForm').submit();
                }
            });
        };

        window.confirmReject = function() {
            var rejectionNote = document.getElementById('rejectionNote').value;
            if (!rejectionNote || rejectionNote.trim() === '') {
                Swal.fire({
                    title: 'Alasan Wajib Diisi',
                    text: 'Silakan masukkan alasan reject terlebih dahulu.',
                    icon: 'warning',
                    confirmButtonColor: '#0d6efd'
                });
                return;
            }

            Swal.fire({
                title: 'Konfirmasi Reject',
                text: 'Apakah Anda yakin ingin me-reject procurement ini?',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Ya, Reject',
                cancelButtonText: 'Batal'
            }).then(function(result) {
                if (result.isConfirmed) {
                    document.getElementById('rejectForm').submit();
                }
            });
        };

        window.showHardcopyEvidence = function(procurementId) {
            // Show loading
            Swal.fire({
                title: 'Loading...',
                text: 'Mengambil gambar hardcopy evidence...',
                allowOutsideClick: false,
                didOpen: function() {
                    Swal.showLoading();
                }
            });

            // Fetch presigned URL from API
            fetch('/ProcurementTracking/HardcopyEvidence/' + procurementId)
                .then(function(response) {
                    if (!response.ok) throw new Error('Hardcopy evidence tidak ditemukan');
                    return response.json();
                })
                .then(function(data) {
                    Swal.fire({
                        title: 'Hardcopy Evidence',
                        html: '<img src="' + data.url + '" class="img-fluid rounded" style="max-height: 70vh;" alt="Hardcopy Evidence">',
                        width: '80%',
                        showCloseButton: true,
                        showConfirmButton: false,
                        customClass: {
                            popup: 'swal-wide'
                        }
                    });
                })
                .catch(function(error) {
                    Swal.fire({
                        title: 'Error',
                        text: error.message || 'Gagal mengambil hardcopy evidence',
                        icon: 'error'
                    });
                });
        };
    })();
</script>
