@model ProcurementHTE.Core.Models.DTOs.PnLSummaryCardDto?
@{
    Func<decimal, string> formatMoney = value => value.ToString("N0");
    Func<decimal, string> formatPercent = value => value.ToString("N2") + "%";
}

@if (Model != null && Model.HasData)
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold">
                <i class="bi bi-graph-up-arrow me-2 text-success"></i>Ringkasan Profit & Loss
            </h6>
            @if (!string.IsNullOrEmpty(Model.SelectedVendorName))
            {
                <span class="badge bg-primary">
                    <i class="bi bi-building me-1"></i>@Model.SelectedVendorName
                </span>
            }
        </div>
        <div class="card-body">
            <div class="row g-3">
                <!-- Total Revenue -->
                <div class="col-6 col-md-3">
                    <div class="p-3 bg-light rounded-3 text-center h-100">
                        <div class="text-muted small mb-1">
                            <i class="bi bi-cash-stack me-1"></i>Total Revenue
                        </div>
                        <div class="fw-bold text-primary fs-6">
                            Rp @formatMoney(Model.TotalRevenue)
                        </div>
                    </div>
                </div>
                
                <!-- Final Offer -->
                <div class="col-6 col-md-3">
                    <div class="p-3 bg-light rounded-3 text-center h-100">
                        <div class="text-muted small mb-1">
                            <i class="bi bi-tag me-1"></i>Final Offer
                        </div>
                        <div class="fw-bold text-info fs-6">
                            Rp @formatMoney(Model.FinalOffer)
                        </div>
                    </div>
                </div>
                
                <!-- Profit -->
                <div class="col-6 col-md-3">
                    <div class="p-3 @(Model.Profit >= 0 ? "bg-success-subtle" : "bg-danger-subtle") rounded-3 text-center h-100">
                        <div class="text-muted small mb-1">
                            <i class="bi bi-currency-dollar me-1"></i>Profit
                        </div>
                        <div class="fw-bold @(Model.Profit >= 0 ? "text-success" : "text-danger") fs-6">
                            Rp @formatMoney(Model.Profit)
                        </div>
                    </div>
                </div>
                
                <!-- Profit Margin -->
                <div class="col-6 col-md-3">
                    <div class="p-3 @(Model.ProfitMarginPercent >= 0 ? "bg-success-subtle" : "bg-danger-subtle") rounded-3 text-center h-100">
                        <div class="text-muted small mb-1">
                            <i class="bi bi-percent me-1"></i>Margin
                        </div>
                        <div class="fw-bold @(Model.ProfitMarginPercent >= 0 ? "text-success" : "text-danger") fs-5">
                            @formatPercent(Model.ProfitMarginPercent)
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom">
            <h6 class="mb-0 fw-bold">
                <i class="bi bi-graph-up-arrow me-2"></i>Ringkasan Profit & Loss
            </h6>
        </div>
        <div class="card-body text-center py-4">
            <div class="text-muted">
                <i class="bi bi-info-circle me-1"></i>
                Data Profit & Loss belum tersedia untuk procurement ini.
            </div>
        </div>
    </div>
}
