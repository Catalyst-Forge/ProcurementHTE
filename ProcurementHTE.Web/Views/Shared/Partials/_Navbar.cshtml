@using Microsoft.AspNetCore.Identity
@inject UserManager<User> UserManager

@{
    var user = await UserManager.GetUserAsync(User);
    var fullName = user?.FullName;
    var email = user?.Email;
}

<nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white shadow-sm mb-3">
  <div class="container-fluid">
    <button class="btn d-lg-none border" type="button" data-bs-toggle="offcanvas" data-bs-target="#sidebar" aria-controls="sidebar">
      <i class="bi bi-arrow-bar-right"></i>
    </button>
    
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
            aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="navbar-collapse collapse d-sm-flex justify-content-end">
      <ul class="navbar-nav gap-2">
        @if (User.Identity?.IsAuthenticated == true) {
          <!-- Notification Bell -->
          <li class="nav-item dropdown">
            <button type="button" class="btn btn-sm fs-4 position-relative" id="dropdownNotification" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false" title="Notifikasi">
              <i class="bi bi-bell"></i>
              <span class="notification-badge position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="display: none;">
                0
              </span>
            </button>

            <div class="dropdown-menu dropdown-menu-end shadow notification-dropdown" aria-labelledby="dropdownNotification" style="width: 360px; max-height: 450px;">
              <div class="dropdown-header d-flex justify-content-between align-items-center py-2 px-3 border-bottom">
                <span class="fw-semibold">Notifikasi</span>
                <button type="button" class="btn btn-sm btn-link text-decoration-none mark-all-read-btn p-0">
                  <i class="bi bi-check2-all"></i> Tandai Semua Dibaca
                </button>
              </div>
              <div class="notification-list" style="max-height: 350px; overflow-y: auto;">
                <div class="text-center text-muted py-4">
                  <i class="bi bi-hourglass-split fs-2"></i>
                  <p class="mb-0 mt-2">Memuat notifikasi...</p>
                </div>
              </div>
              <div class="dropdown-footer text-center py-2 border-top d-flex justify-content-between px-3">
                <a href="#" class="text-decoration-none small" onclick="window.notificationSystem.loadNotifications(); return false;">
                  <i class="bi bi-arrow-clockwise"></i> Muat Ulang
                </a>
                <a asp-controller="Dashboard" asp-action="Notifications" class="text-decoration-none small fw-semibold text-primary"
                   hx-get='@Url.Action("Notifications", "Dashboard")'
                   hx-target="#app-content"
                   hx-indicator="#content-loading"
                   hx-push-url="true">
                  <i class="bi bi-list-ul"></i> Lihat Semua
                </a>
              </div>
            </div>
          </li>
          
          <li class="nav-item dropdown">
            <button type="button" class="btn btn-sm fs-4 dropdown-toggle" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false"><i class="bi bi-person-circle"></i></button>

            <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="dropdownUser">
              <li>
                <a class="dropdown-item"
                   href="@Url.Action("Settings", "Account")"
                   hx-get='@Url.Action("Settings", "Account")'
                   hx-target="#app-content"
                   hx-indicator="#content-loading"
                   hx-push-url="true"
                   data-nav-controller="Account"
                   data-nav-action="Settings">Profil &amp; Keamanan</a>
              </li>
              <li><hr class="dropdown-divider" /></li>
              <li>
                <form asp-action="Logout" asp-controller="Auth" method="post" class="" hx-boost="false" id="logout-form">
                  <button type="submit" class="dropdown-item">Sign Out</button>
                </form>
              </li>
            </ul>
          </li>

          <div class="d-flex flex-column ms-2">
            <span>@fullName</span>
            <small class="text-muted">@email</small>
          </div>
        } else {
          <li class="nav-item"><a asp-controller="Auth" asp-action="Login" class="nav-link">Login</a></li>
        }
      </ul>
    </div>
  </div>
</nav>

