<style>
    .procurement-progress-container {
        padding: 20px;
    }

    .progress-tracker {
        position: relative;
    }

    .progress-step {
        position: relative;
        padding: 15px 0;
    }

    .step-content {
        display: flex;
        align-items: flex-start;
        gap: 15px;
    }

    .step-icon {
        flex-shrink: 0;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        transition: all 0.3s ease;
    }

    .progress-step.completed .step-icon {
        background-color: #28a745;
        color: white;
    }

    .progress-step.current .step-icon {
        background-color: #007bff;
        color: white;
        animation: pulse 2s infinite;
    }

    .progress-step.pending .step-icon {
        background-color: #e9ecef;
        color: #6c757d;
    }

    .step-details {
        flex: 1;
    }

    .step-number {
        font-size: 12px;
        color: #6c757d;
        text-transform: uppercase;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .step-title {
        font-size: 16px;
        font-weight: 600;
        color: #212529;
        margin-top: 4px;
    }

    .step-timestamp, .step-user {
        font-size: 13px;
        color: #6c757d;
        margin-top: 4px;
    }

    .step-line {
        position: absolute;
        left: 19px;
        top: 55px;
        bottom: -15px;
        width: 2px;
        background-color: #e9ecef;
        transition: background-color 0.3s ease;
    }

    .step-line.completed {
        background-color: #28a745;
    }

    @@keyframes pulse {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(0, 123, 255, 0.7);
        }
        50% {
            box-shadow: 0 0 0 10px rgba(0, 123, 255, 0);
        }
    }

    @@media (max-width: 576px) {
        .step-icon {
            width: 30px;
            height: 30px;
            font-size: 16px;
        }

        .step-title {
            font-size: 14px;
        }

        .step-line {
            left: 14px;
        }
    }
</style>
