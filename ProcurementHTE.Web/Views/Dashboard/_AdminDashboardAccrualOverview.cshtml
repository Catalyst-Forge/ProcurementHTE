@model DashboardViewModel

<div class="row g-3 mb-4">
    <div class="col-md-12">
        <div class="card shadow-sm">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-receipt-cutoff me-2 text-warning"></i>Status Data Accrual</h5>
                <a asp-controller="Accrual" asp-action="Index" class="btn btn-sm btn-outline-warning">
                    <i class="bi bi-pencil-square"></i> Kelola Accrual
                </a>
            </div>
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-3 text-center border-end">
                        <p class="text-muted mb-1 small">Pending Accrual</p>
                        <h3 class="text-warning fw-bold mb-0">@Model.PendingAccrualCount</h3>
                        <small class="text-muted">Belum diisi</small>
                    </div>
                    <div class="col-md-3 text-center border-end">
                        <p class="text-muted mb-1 small">Filled Accrual</p>
                        <h3 class="text-success fw-bold mb-0">@Model.FilledAccrualCount</h3>
                        <small class="text-muted">Sudah diisi</small>
                    </div>
                    <div class="col-md-3 text-center border-end">
                        <p class="text-muted mb-1 small">Total Potensi Accrual</p>
                        <h4 class="text-info fw-bold mb-0">Rp @Model.TotalPotensiAccrual.ToString("N0")</h4>
                        <small class="text-muted">Estimasi nilai</small>
                    </div>
                    <div class="col-md-3 text-center">
                        <p class="text-muted mb-1 small">Progress</p>
                        <div class="progress mb-2 admin-progress">
                            <div class="progress-bar bg-success" role="progressbar" style="width: @Model.AccrualFillPercentage%" aria-valuenow="@Model.AccrualFillPercentage" aria-valuemin="0" aria-valuemax="100">
                                @Model.AccrualFillPercentage%
                            </div>
                        </div>
                        <small class="text-muted">@Model.FilledAccrualCount / @Model.TotalProcurements</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
