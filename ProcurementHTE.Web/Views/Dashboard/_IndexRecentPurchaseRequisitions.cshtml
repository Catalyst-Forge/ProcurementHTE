@model DashboardViewModel

<div class="row g-3">
    <div class="col-md-12">
        <div class="card shadow-sm">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="bi bi-file-earmark-ruled me-2"></i>Purchase Requisitions Terbaru
                </h5>
                <a asp-controller="PurchaseRequisitions" asp-action="Index" class="btn btn-sm btn-outline-primary">
                    Lihat Semua <i class="bi bi-arrow-right"></i>
                </a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>PR Number</th>
                                <th>Request Date</th>
                                <th>Description</th>
                                <th>Created By</th>
                                <th class="text-center">Procurements</th>
                                <th>Created At</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.RecentPurchaseRequisitions.Any())
                            {
                                @foreach (var pr in Model.RecentPurchaseRequisitions)
                                {
                                    <tr>
                                        <td>
                                            <a asp-controller="PurchaseRequisitions" asp-action="Details" asp-route-id="@pr.PrId" class="text-decoration-none">
                                                <strong>@pr.PrNumber</strong>
                                            </a>
                                        </td>
                                        <td>@pr.RequestDate.ToString("dd MMM yyyy")</td>
                                        <td>
                                            <small class="text-muted">
                                                @(string.IsNullOrEmpty(pr.Description) ? "-" : (pr.Description.Length > 50 ? pr.Description.Substring(0, 50) + "..." : pr.Description))
                                            </small>
                                        </td>
                                        <td><small>@pr.CreatedBy</small></td>
                                        <td class="text-center">
                                            <span class="badge bg-primary">@pr.ProcurementCount</span>
                                        </td>
                                        <td>
                                            <small class="text-muted">@pr.CreatedAt.ToString("dd MMM yyyy HH:mm")</small>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted py-4">
                                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                        Belum ada Purchase Requisition
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
