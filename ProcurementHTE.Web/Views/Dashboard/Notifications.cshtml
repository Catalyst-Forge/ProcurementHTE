@using ProcurementHTE.Core.Models.DTOs
@model List<NotificationDto>
@{
    ViewData["Title"] = "Riwayat Notifikasi";
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var hasNextPage = (bool)(ViewBag.HasNextPage ?? false);
    var hasPreviousPage = (bool)(ViewBag.HasPreviousPage ?? false);
    var unreadOnly = (bool)(ViewBag.UnreadOnly ?? false);
    var unreadCount = (int)(ViewBag.UnreadCount ?? 0);
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">
            <i class="bi bi-bell me-2"></i>Riwayat Notifikasi
        </h1>
        <div class="d-flex gap-2 align-items-center">
            @if (unreadCount > 0)
            {
                <span class="badge bg-danger">@unreadCount belum dibaca</span>
            }
            <button type="button" class="btn btn-outline-primary btn-sm" id="markAllReadBtn">
                <i class="bi bi-check2-all me-1"></i>Tandai Semua Dibaca
            </button>
        </div>
    </div>

    <!-- Filter -->
    <div class="card shadow-sm mb-4">
        <div class="card-body py-2">
            <div class="d-flex gap-3 align-items-center">
                <span class="text-muted">Filter:</span>
                <div class="form-check form-check-inline mb-0">
                    <input class="form-check-input" type="radio" name="filterNotif" id="filterAll" 
                           @(unreadOnly ? "" : "checked")
                           onchange="window.location.href='@Url.Action("Notifications", "Dashboard")'">
                    <label class="form-check-label" for="filterAll">Semua</label>
                </div>
                <div class="form-check form-check-inline mb-0">
                    <input class="form-check-input" type="radio" name="filterNotif" id="filterUnread" 
                           @(unreadOnly ? "checked" : "")
                           onchange="window.location.href='@Url.Action("Notifications", "Dashboard", new { unreadOnly = true })'">
                    <label class="form-check-label" for="filterUnread">Belum Dibaca</label>
                </div>
            </div>
        </div>
    </div>

    <!-- Notification List -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            @if (Model.Count == 0)
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-bell-slash fs-1"></i>
                    <p class="mb-0 mt-3">Tidak ada notifikasi</p>
                </div>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var notification in Model)
                    {
                        <a href="@(notification.ActionUrl ?? "#")" 
                           class="list-group-item list-group-item-action d-flex align-items-start gap-3 py-3 notification-history-item @(!notification.IsRead ? "bg-light" : "")"
                           data-notification-id="@notification.NotificationId"
                           onclick="markNotificationRead('@notification.NotificationId')">
                            <div class="notification-icon-lg flex-shrink-0 rounded-circle d-flex align-items-center justify-content-center" 
                                 style="width: 48px; height: 48px; background-color: @GetIconBackground(notification.NotificationType)">
                                <i class="@GetIconClass(notification.NotificationType) fs-5 text-white"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start">
                                    <h6 class="mb-1 @(!notification.IsRead ? "fw-bold" : "")">
                                        @notification.Title
                                        @if (!notification.IsRead)
                                        {
                                            <span class="badge bg-primary ms-2">Baru</span>
                                        }
                                    </h6>
                                    <small class="text-muted">@notification.TimeAgo</small>
                                </div>
                                <p class="mb-1 text-muted">@notification.Message</p>
                                <small class="text-muted">
                                    <i class="bi bi-clock me-1"></i>@notification.CreatedAt.ToString("dd MMM yyyy, HH:mm")
                                </small>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>

        @if (hasPreviousPage || hasNextPage)
        {
            <div class="card-footer bg-white d-flex justify-content-between align-items-center">
                <div>
                    Halaman @currentPage
                </div>
                <nav aria-label="Notification pagination">
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(hasPreviousPage ? "" : "disabled")">
                            <a class="page-link" 
                               href="@Url.Action("Notifications", "Dashboard", new { page = currentPage - 1, unreadOnly })"
                               hx-get='@Url.Action("Notifications", "Dashboard", new { page = currentPage - 1, unreadOnly })'
                               hx-target="#app-content"
                               hx-indicator="#content-loading"
                               hx-push-url="true">
                                <i class="bi bi-chevron-left"></i> Sebelumnya
                            </a>
                        </li>
                        <li class="page-item @(hasNextPage ? "" : "disabled")">
                            <a class="page-link" 
                               href="@Url.Action("Notifications", "Dashboard", new { page = currentPage + 1, unreadOnly })"
                               hx-get='@Url.Action("Notifications", "Dashboard", new { page = currentPage + 1, unreadOnly })'
                               hx-target="#app-content"
                               hx-indicator="#content-loading"
                               hx-push-url="true">
                                Berikutnya <i class="bi bi-chevron-right"></i>
                            </a>
                        </li>
                    </ul>
                </nav>
            </div>
        }
    </div>
</div>

@functions {
    string GetIconClass(string? type) => type switch
    {
        "ProcurementPublished" => "bi bi-megaphone",
        "ApprovedByAnalyst" => "bi bi-check-circle",
        "ApprovedByAssistantManager" => "bi bi-check2-circle",
        "ApprovedByManager" => "bi bi-check2-all",
        "PrRejected" => "bi bi-x-circle",
        "PrCompleted" => "bi bi-trophy",
        _ => "bi bi-bell"
    };

    string GetIconBackground(string? type) => type switch
    {
        "ProcurementPublished" => "#0d6efd",
        "ApprovedByAnalyst" or "ApprovedByAssistantManager" or "ApprovedByManager" => "#198754",
        "PrRejected" => "#dc3545",
        "PrCompleted" => "#ffc107",
        _ => "#6c757d"
    };
}

@section Scripts {
    <script>
        async function markNotificationRead(notificationId) {
            try {
                await fetch(`/api/notifications/${notificationId}/read`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                // Update UI
                const item = document.querySelector(`[data-notification-id="${notificationId}"]`);
                if (item) {
                    item.classList.remove('bg-light');
                    const badge = item.querySelector('.badge.bg-primary');
                    if (badge) badge.remove();
                    const title = item.querySelector('h6');
                    if (title) title.classList.remove('fw-bold');
                }

                // Update notification badge in navbar
                if (window.notificationSystem) {
                    window.notificationSystem.loadNotifications();
                }
            } catch (error) {
                console.error('Failed to mark notification as read:', error);
            }
        }

        document.getElementById('markAllReadBtn')?.addEventListener('click', async function() {
            try {
                const response = await fetch('/api/notifications/read-all', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });

                if (response.ok) {
                    // Refresh the page to show updated state
                    window.location.reload();
                }
            } catch (error) {
                console.error('Failed to mark all as read:', error);
            }
        });
    </script>
}
