@model DashboardViewModel

<div class="card shadow-sm">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-people me-2"></i>Status Aktivitas User</h5>
        <div>
            <span class="badge bg-success me-2"><i class="bi bi-circle-fill admin-dot"></i> <span data-online-users-count>@Model.OnlineUsersCount</span> Online</span>
            <span class="badge bg-secondary"><i class="bi bi-circle admin-dot"></i> <span data-offline-users-count>@((Model.UserActivities?.Count ?? 0) - Model.OnlineUsersCount)</span> Offline</span>
        </div>
    </div>
    <div class="card-body p-0" data-user-activity-table>
        @if (Model.UserActivities != null && Model.UserActivities.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="admin-status-col">Status</th>
                            <th>User</th>
                            <th>Job Title</th>
                            <th>Waktu</th>
                            <th class="text-end">Last Activity</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.UserActivities)
                        {
                            <tr data-user-id="@user.UserId" data-user-status="@(user.IsOnline ? "online" : "offline")">
                                <td class="text-center">
                                    @if (user.IsOnline)
                                    {
                                        <div class="position-relative d-inline-block">
                                            <i class="bi bi-person-fill text-success fs-5 user-status-icon"></i>
                                            <span class="position-absolute top-0 start-100 translate-middle p-1 bg-success border border-light rounded-circle">
                                                <span class="visually-hidden">Online</span>
                                            </span>
                                        </div>
                                    }
                                    else
                                    {
                                        <i class="bi bi-person text-secondary fs-5 user-status-icon"></i>
                                    }
                                </td>
                                <td>
                                    <div class="fw-semibold">@user.FullName</div>
                                    <div class="text-muted small">@@@user.UserName</div>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(user.JobTitle))
                                    {
                                        <small class="text-muted"><i class="bi bi-briefcase"></i> @user.JobTitle</small>
                                    }
                                    else
                                    {
                                        <small class="text-muted">-</small>
                                    }
                                </td>
                                <td>@await Html.PartialAsync("_AdminDashboardUserStatusBadge", user)</td>
                                <td class="text-end">
                                    <small class="@(user.IsOnline ? "text-success" : "text-muted") user-last-activity">
                                        <i class="bi bi-clock"></i> @user.StatusTime
                                    </small>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i><small>Belum ada data aktivitas user</small>
            </div>
        }
    </div>
</div>
