@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid py-4">
    @await Html.PartialAsync("_IndexHeader", Model)
    @await Html.PartialAsync("_IndexStats", Model)
    @await Html.PartialAsync("_IndexFinancialSummary", Model)
    @await Html.PartialAsync("_IndexCharts", Model)
    @await Html.PartialAsync("_IndexProcurementTables", Model)
    @await Html.PartialAsync("_IndexTopVendors", Model)
    @await Html.PartialAsync("_IndexRecentPurchaseRequisitions", Model)
</div>

@section Scripts {
    @await Html.PartialAsync("_IndexScripts", Model)
}
