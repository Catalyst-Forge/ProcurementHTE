@model DashboardViewModel

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header bg-white py-3"><h5 class="mb-0"><i class="bi bi-pie-chart me-2"></i>Procurement by Status</h5></div>
            <div class="card-body"><canvas id="procurementStatusChart" height="300"></canvas></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header bg-white py-3"><h5 class="mb-0"><i class="bi bi-bar-chart me-2"></i>Procurement by Job Type</h5></div>
            <div class="card-body"><canvas id="jobTypeChart" height="300"></canvas></div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header bg-white py-3"><h5 class="mb-0"><i class="bi bi-people me-2"></i>Users by Role</h5></div>
            <div class="card-body"><canvas id="roleDistributionChart" height="300"></canvas></div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-12">
        <div class="card shadow-sm">
            <div class="card-header bg-white py-3"><h5 class="mb-0"><i class="bi bi-geo-alt me-2"></i>Procurement by Region</h5></div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6"><canvas id="regionChart" height="200"></canvas></div>
                    <div class="col-md-6">
                        <div class="table-responsive">
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Region</th>
                                        <th class="text-center">Count</th>
                                        <th class="text-end">Total Value</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model.RegionDistribution.Any())
                                    {
                                        @foreach (var region in Model.RegionDistribution)
                                        {
                                            <tr>
                                                <td><i class="bi bi-geo-alt-fill text-primary"></i> @region.RegionName</td>
                                                <td class="text-center"><span class="badge bg-primary">@region.Count</span></td>
                                                <td class="text-end"><strong>Rp @region.TotalValue.ToString("N0")</strong></td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="3" class="text-center text-muted py-3">
                                                <i class="bi bi-geo fs-3 d-block mb-1"></i>Belum ada data region
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
