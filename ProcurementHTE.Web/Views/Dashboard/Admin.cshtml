@using System.Text.Json
@model ProcurementHTE.Web.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid py-4" data-dashboard-realtime="true">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">
            <i class="bi bi-speedometer2 me-2"></i>Dashboard Procurement - @Model.RoleName
        </h1>
        <div class="d-flex align-items-center gap-3">
            <!-- Real-time status indicator -->
            <div id="realtime-status" class="realtime-status status-connected" title="Real-time updates active">
                <i class="bi bi-circle-fill"></i>
            </div>
            <div class="text-muted">
                <i class="bi bi-clock me-1"></i>
                <span id="currentDateTime"></span>
            </div>
        </div>
    </div>

    <!-- Statistics Cards Row -->
    <div class="row g-3 mb-4">
        <!-- Total Procurements -->
        <div class="col-xl-4 col-md-3 col-sm-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 small">Total Procurement</p>
                            <h3 class="mb-0 fw-bold">@Model.TotalProcurements</h3>
                            <small class="text-success">
                                <i class="bi bi-activity"></i>
                                @Model.ActiveProcurements Active
                            </small>
                        </div>
                        <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-cart-check fs-2 text-primary"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Pending Approvals -->
        <div class="col-xl-4 col-md-3 col-sm-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 small">Pending Approvals</p>
                            <h3 class="mb-0 fw-bold">@Model.PendingApprovals</h3>
                            <small class="text-warning">
                                <i class="bi bi-hourglass-split"></i>
                                Memerlukan Persetujuan
                            </small>
                        </div>
                        <div class="bg-warning bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-clipboard-check fs-2 text-warning"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Vendors -->
        <div class="col-xl-4 col-md-3 col-sm-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 small">Total Vendor</p>
                            <h3 class="mb-0 fw-bold">@Model.TotalVendors</h3>
                            <small class="text-info">
                                <i class="bi bi-people"></i>
                                Vendor Terdaftar
                            </small>
                        </div>
                        <div class="bg-info bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-building fs-2 text-info"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Revenue -->
        <div class="col-xl-4 col-md-3 col-sm-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 small">Total Revenue</p>
                            <h3 class="mb-0 fw-bold">@Model.TotalRevenue.ToString("N0")</h3>
                            <small class="text-success">
                                <i class="bi bi-graph-up-arrow"></i>
                                Profit: @Model.TotalProfit.ToString("N0")
                            </small>
                        </div>
                        <div class="bg-success bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-currency-dollar fs-2 text-success"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total Purchase Requisitions -->
        <div class="col-xl-4 col-md-3 col-sm-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 small">Purchase Requisitions</p>
                            <h3 class="mb-0 fw-bold">@Model.TotalPurchaseRequisitions</h3>
                            <small class="text-primary">
                                <i class="bi bi-file-earmark-text"></i>
                                Total PR
                            </small>
                        </div>
                        <div class="bg-purple bg-opacity-10 rounded-3 p-3" style="background-color: rgba(111, 66, 193, 0.1);">
                            <i class="bi bi-file-earmark-ruled fs-2" style="color: #6f42c1;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Online Users -->
        <div class="col-xl-4 col-md-3 col-sm-6">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1 small">User Online</p>
                            <h3 class="mb-0 fw-bold">@Model.OnlineUsersCount</h3>
                            <small class="text-success">
                                <i class="bi bi-circle-fill" style="font-size: 8px;"></i>
                                Active Now
                            </small>
                        </div>
                        <div class="bg-success bg-opacity-10 rounded-3 p-3">
                            <i class="bi bi-people-fill fs-2 text-success"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Financial Summary Card -->
    <div class="row g-3 mb-4">
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">
                        <i class="bi bi-graph-up me-2"></i>Ringkasan Keuangan
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-3">
                            <p class="text-muted mb-1">Total Revenue</p>
                            <h4 class="text-primary mb-0">Rp @Model.TotalRevenue.ToString("N0")</h4>
                        </div>
                        <div class="col-md-3">
                            <p class="text-muted mb-1">Total Cost</p>
                            <h4 class="text-danger mb-0">Rp @Model.TotalCost.ToString("N0")</h4>
                        </div>
                        <div class="col-md-3">
                            <p class="text-muted mb-1">Net Profit</p>
                            <h4 class="text-success mb-0">Rp @Model.TotalProfit.ToString("N0")</h4>
                        </div>
                        <div class="col-md-3">
                            <p class="text-muted mb-1">Profit Margin</p>
                            <h4 class="text-info mb-0">@Model.ProfitMargin%</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Data Tables Row with Recent Activities for Admin -->
    <div class="row g-3 mb-4">
        <!-- Recent Procurements -->
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-clock-history me-2"></i>Procurement Terbaru
                    </h5>
                    <a asp-controller="Procurements" asp-action="Index" class="btn btn-sm btn-outline-primary">
                        Lihat Semua <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Proc Number</th>
                                    <th>Job Type</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var proc in Model.RecentProcurements.Take(5))
                                {
                                    <tr>
                                        <td>
                                            <strong>@proc.ProcNum</strong>
                                            <br>
                                            <small class="text-muted">@proc.CreatedDate.ToString("dd MMM yyyy")</small>
                                        </td>
                                        <td><small>@proc.JobTypeName</small></td>
                                        <td>
                                            <span class="badge bg-@(GetStatusBadgeClass(proc.StatusName))">
                                                @proc.StatusName
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Pending Approvals -->
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">
                        <i class="bi bi-exclamation-circle me-2"></i>Pending Approvals
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Procurement</th>
                                    <th class="text-center">Days</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var approval in Model.PendingApprovalsDetail.Take(5))
                                {
                                    <tr>
                                        <td>
                                            <strong>@approval.ProcNum</strong>
                                            <br>
                                            <small class="text-muted">@approval.DocumentName</small>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-@(approval.DaysWaiting > 3 ? "danger" : "warning")">
                                                @approval.DaysWaiting
                                            </span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="row g-3 mb-4">
        <!-- Procurement Status Chart -->
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">
                        <i class="bi bi-pie-chart me-2"></i>Procurement by Status
                    </h5>
                </div>
                <div class="card-body">
                    <canvas id="procurementStatusChart" height="300"></canvas>
                </div>
            </div>
        </div>

        <!-- Job Type Distribution Chart -->
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">
                        <i class="bi bi-bar-chart me-2"></i>Procurement by Job Type
                    </h5>
                </div>
                <div class="card-body">
                    <canvas id="jobTypeChart" height="300"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Monthly Trend Chart -->
    @*<div class="row g-3 mb-4">
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">
                        <i class="bi bi-graph-up-arrow me-2"></i>Tren Procurement (12 Bulan Terakhir)
                    </h5>
                </div>
                <div class="card-body">
                    <canvas id="monthlyTrendChart" height="100"></canvas>
                </div>
            </div>
        </div>
    </div> *@

    <!-- Purchase Requisition Chart -->
    @* <div class="row g-3 mb-4">
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">
                        <i class="bi bi-file-earmark-bar-graph me-2"></i>Purchase Requisition Trend
                    </h5>
                </div>
                <div class="card-body">
                    <canvas id="purchaseRequisitionChart" height="100"></canvas>
                </div>
            </div>
        </div>
    </div> *@

    <!-- User Activity Status Row -->
    <div class="row g-3 mb-4">
        
        <!-- Recent Activities (Admin Only) -->
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">
                        <i class="bi bi-activity me-2"></i>Recent Activities
                    </h5>
                </div>
                <div class="card-body" style="max-height: 400px; overflow-y: auto;">
                    <div class="activity-list">
                        @if (Model.RecentActivities != null && Model.RecentActivities.Any())
                        {
                            @foreach (var activity in Model.RecentActivities)
                            {
                                <div class="d-flex mb-3 pb-3 border-bottom">
                                    <div class="flex-shrink-0">
                                        <div class="bg-primary bg-opacity-10 rounded-circle p-2">
                                            <i class="bi bi-person-check text-primary"></i>
                                        </div>
                                    </div>
                                    <div class="flex-grow-1 ms-3">
                                        <div class="small fw-semibold">@activity.User</div>
                                        <div class="text-muted small">@activity.Description</div>
                                        <div class="text-muted small">
                                            <i class="bi bi-clock"></i> @activity.Time.ToString("dd MMM yyyy HH:mm")
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                <small>No recent activities</small>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- User Activity Status (Combined Online/Offline) -->
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-people me-2"></i>Status Aktivitas User
                    </h5>
                    <div>
                        <span class="badge bg-success me-2">
                            <i class="bi bi-circle-fill" style="font-size: 8px;"></i>
                            <span data-online-users-count>@Model.OnlineUsersCount</span> Online
                        </span>
                        <span class="badge bg-secondary">
                            <i class="bi bi-circle" style="font-size: 8px;"></i>
                            <span data-offline-users-count>@(Model.UserActivities?.Count - Model.OnlineUsersCount)</span> Offline
                        </span>
                    </div>
                </div>
                <div class="card-body p-0" data-user-activity-table>
                    @if (Model.UserActivities != null && Model.UserActivities.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 50px;">Status</th>
                                        <th>User</th>
                                        <th>Job Title</th>
                                        <th>Waktu</th>
                                        <th class="text-end">Last Activity</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var user in Model.UserActivities)
                                    {
                                        <tr data-user-id="@user.UserId" data-user-status="@(user.IsOnline ? "online" : "offline")">
                                            <td class="text-center">
                                                @if (user.IsOnline)
                                                {
                                                    <div class="position-relative d-inline-block">
                                                        <i class="bi bi-person-fill text-success fs-5 user-status-icon"></i>
                                                        <span class="position-absolute top-0 start-100 translate-middle p-1 bg-success border border-light rounded-circle">
                                                            <span class="visually-hidden">Online</span>
                                                        </span>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <i class="bi bi-person text-secondary fs-5 user-status-icon"></i>
                                                }
                                            </td>
                                            <td>
                                                <div class="fw-semibold">@user.FullName</div>
                                                <div class="text-muted small">@@@user.UserName</div>
                                            </td>
                                            <td>
                                                @if (!string.IsNullOrEmpty(user.JobTitle))
                                                {
                                                    <small class="text-muted"><i class="bi bi-briefcase"></i> @user.JobTitle</small>
                                                }
                                                else
                                                {
                                                    <small class="text-muted">-</small>
                                                }
                                            </td>
                                            <td>
                                                @if (user.IsOnline)
                                                {
                                                    <span class="badge bg-success user-status-badge">
                                                        <i class="bi bi-circle-fill" style="font-size: 6px;"></i> Online
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary user-status-badge">
                                                        <i class="bi bi-circle" style="font-size: 6px;"></i> Offline
                                                    </span>
                                                }
                                            </td>
                                            <td class="text-end">
                                                <small class="@(user.IsOnline ? "text-success" : "text-muted") user-last-activity">
                                                    <i class="bi bi-clock"></i> @user.StatusTime
                                                </small>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                            <small>Belum ada data aktivitas user</small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Top Vendors Table -->
    <div class="row g-3 mb-4">
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0">
                        <i class="bi bi-trophy me-2"></i>Top 10 Vendor Performance
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Vendor Code</th>
                                    <th>Vendor Name</th>
                                    <th class="text-center">Total Offers</th>
                                    <th class="text-center">Selected</th>
                                    <th class="text-center">Win Rate</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < Model.TopVendors.Count; i++)
                                {
                                    var vendor = Model.TopVendors[i];
                                    <tr>
                                        <td><strong>@(i + 1)</strong></td>
                                        <td>@vendor.VendorCode</td>
                                        <td>@vendor.VendorName</td>
                                        <td class="text-center">
                                            <span class="badge bg-info">@vendor.OfferCount</span>
                                        </td>
                                        <td class="text-center">
                                            <span class="badge bg-success">@vendor.SelectedCount</span>
                                        </td>
                                        <td class="text-center">
                                            <div class="progress" style="height: 20px;">
                                                <div class="progress-bar bg-@(GetWinRateClass(vendor.WinRate))"
                                                     role="progressbar"
                                                     style="width: @(vendor.WinRate)%"
                                                     aria-valuenow="@vendor.WinRate"
                                                     aria-valuemin="0"
                                                     aria-valuemax="100">
                                                    @vendor.WinRate%
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Purchase Requisitions Table -->
    <div class="row g-3">
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-file-earmark-ruled me-2"></i>Purchase Requisitions Terbaru
                    </h5>
                    <a asp-controller="PurchaseRequisitions" asp-action="Index" class="btn btn-sm btn-outline-primary">
                        Lihat Semua <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>PR Number</th>
                                    <th>Request Date</th>
                                    <th>Description</th>
                                    <th>Created By</th>
                                    <th class="text-center">Procurements</th>
                                    <th>Created At</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.RecentPurchaseRequisitions.Any())
                                {
                                    @foreach (var pr in Model.RecentPurchaseRequisitions)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@pr.PrNumber</strong>
                                            </td>
                                            <td>@pr.RequestDate.ToString("dd MMM yyyy")</td>
                                            <td>
                                                <small class="text-muted">
                                                    @(string.IsNullOrEmpty(pr.Description) ? "-" : (pr.Description.Length > 50 ? pr.Description.Substring(0, 50) + "..." : pr.Description))
                                                </small>
                                            </td>
                                            <td><small>@pr.CreatedBy</small></td>
                                            <td class="text-center">
                                                <span class="badge bg-primary">@pr.ProcurementCount</span>
                                            </td>
                                            <td>
                                                <small class="text-muted">@pr.CreatedAt.ToString("dd MMM yyyy HH:mm")</small>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">
                                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                            Belum ada Purchase Requisition
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("~/Views/Dashboard/Partials/_DashboardChartsScripts.cshtml", Model)
    
    <script>
        // Update current date time
        function updateDateTime() {
            const now = new Date();
            const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' };
            const element = document.getElementById('currentDateTime');
            if (element) {
                element.textContent = now.toLocaleDateString('id-ID', options);
            }
        }
        updateDateTime();
        setInterval(updateDateTime, 60000);

        // Chart.js default config
        if (typeof Chart !== 'undefined') {
            Chart.defaults.font.family = "'Segoe UI', Tahoma, Geneva, Verdana, sans-serif";
        }

        // Job Type Distribution Chart (Bar)
        const jobTypeData = @Html.Raw(JsonSerializer.Serialize(Model.JobTypeDistribution, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase }));
        if (document.getElementById('jobTypeChart') && typeof Chart !== 'undefined') {
            const jobTypeChart = new Chart(document.getElementById('jobTypeChart'), {
                type: 'bar',
                data: {
                    labels: jobTypeData.map(item => item.jobTypeName),
                    datasets: [{
                        label: 'Count',
                        data: jobTypeData.map(item => item.count),
                        backgroundColor: 'rgba(13, 110, 253, 0.7)',
                        borderColor: 'rgb(13, 110, 253)',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: { beginAtZero: true }
                    }
                }
            });
        }

        // Monthly Trend Chart (Line)
        const monthlyData = @Html.Raw(JsonSerializer.Serialize(Model.MonthlyProcurementTrend, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase }));
        if (document.getElementById('monthlyTrendChart') && typeof Chart !== 'undefined') {
            const monthlyChart = new Chart(document.getElementById('monthlyTrendChart'), {
                type: 'line',
                data: {
                    labels: monthlyData.map(item => item.monthYear),
                    datasets: [{
                        label: 'Procurement Count',
                        data: monthlyData.map(item => item.count),
                        borderColor: 'rgb(75, 192, 192)',
                        backgroundColor: 'rgba(75, 192, 192, 0.2)',
                        tension: 0.4,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: { beginAtZero: true }
                    }
                }
            });
        }

        // Purchase Requisition Chart (Doughnut)
        const prTrendData = @Html.Raw(JsonSerializer.Serialize(Model.MonthlyPurchaseRequisitionTrend, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase }));
        if (document.getElementById('purchaseRequisitionChart') && typeof Chart !== 'undefined') {
            new Chart(document.getElementById('purchaseRequisitionChart'), {
                type: 'doughnut',
                data: {
                    labels: prTrendData.map(item => item.monthYear),
                    datasets: [{
                        label: 'Purchase Requisitions',
                        data: prTrendData.map(item => item.count),
                        backgroundColor: ['#6f42c1', '#0d6efd', '#198754', '#ffc107', '#dc3545', '#0dcaf0', '#6610f2', '#fd7e14', '#20c997', '#e83e8c', '#adb5bd', '#343a40'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });
        }
    </script>

    <!-- User Online/Offline Management Script -->
    <script>
        // Load online/offline users data
        async function loadOnlineUsers() {
            try {
                const response = await fetch('/Dashboard/Admin/GetOnlineUsers');
                if (!response.ok) {
                    throw new Error('Failed to fetch online users');
                }
                const data = await response.json();
                
                console.log('Online users data:', data);
                
                // Validate data
                if (!data || !Array.isArray(data.users)) {
                    console.error('Invalid data structure:', data);
                    return;
                }
                
                // Update badge counters
                const onlineBadge = document.querySelector('[data-online-users-count]');
                const offlineBadge = document.querySelector('[data-offline-users-count]');
                if (onlineBadge) onlineBadge.textContent = data.onlineCount || 0;
                if (offlineBadge) offlineBadge.textContent = data.offlineCount || 0;
                
                // Update existing user activity table
                updateUserActivityTable(data.users);
            } catch (error) {
                console.error('Error loading online users:', error);
            }
        }
        
        function updateUserActivityTable(users) {
            if (!Array.isArray(users) || users.length === 0) {
                console.log('No users to update');
                return;
            }
            
            const activityTable = document.querySelector('[data-user-activity-table]');
            if (!activityTable) {
                console.log('Activity table not found');
                return;
            }
            
            users.forEach(user => {
                if (!user || !user.id) return;
                
                const row = activityTable.querySelector(`tr[data-user-id="${user.id}"]`);
                if (!row) return;
                
                // Update status
                const wasOnline = row.dataset.userStatus === 'online';
                const isOnline = user.isOnline || false;
                
                if (wasOnline !== isOnline) {
                    row.dataset.userStatus = isOnline ? 'online' : 'offline';
                    
                    // Update icon
                    const iconCell = row.querySelector('.user-status-icon');
                    if (iconCell) {
                        const parentTd = iconCell.closest('td');
                        if (parentTd) {
                            if (isOnline) {
                                parentTd.innerHTML = `
                                    <div class="position-relative d-inline-block">
                                        <i class="bi bi-person-fill text-success fs-5 user-status-icon"></i>
                                        <span class="position-absolute top-0 start-100 translate-middle p-1 bg-success border border-light rounded-circle">
                                            <span class="visually-hidden">Online</span>
                                        </span>
                                    </div>
                                `;
                            } else {
                                parentTd.innerHTML = '<i class="bi bi-person text-secondary fs-5 user-status-icon"></i>';
                            }
                        }
                    }
                    
                    // Update badge
                    const badge = row.querySelector('.user-status-badge');
                    if (badge) {
                        badge.className = isOnline ? 'badge bg-success user-status-badge' : 'badge bg-secondary user-status-badge';
                        badge.innerHTML = isOnline 
                            ? '<i class="bi bi-circle-fill" style="font-size: 6px;"></i> Online'
                            : '<i class="bi bi-circle" style="font-size: 6px;"></i> Offline';
                    }
                    
                    // Update last activity
                    const activityCell = row.querySelector('.user-last-activity');
                    if (activityCell) {
                        activityCell.className = isOnline ? 'text-success user-last-activity' : 'text-muted user-last-activity';
                        if (user.connectionInfo && user.connectionInfo.lastActivityAt) {
                            activityCell.innerHTML = `<i class="bi bi-clock"></i> ${formatDateTime(user.connectionInfo.lastActivityAt)}`;
                        } else if (isOnline) {
                            activityCell.innerHTML = '<i class="bi bi-clock"></i> Online sekarang';
                        }
                    }
                    
                    console.log(`Updated user ${user.userName} to ${isOnline ? 'online' : 'offline'}`);
                }
            });
        }
        
        function formatDateTime(dateString) {
            if (!dateString) return '-';
            try {
                const date = new Date(dateString);
                const now = new Date();
                const diff = Math.floor((now - date) / 1000); // difference in seconds
                
                if (diff < 60) return 'Baru saja';
                if (diff < 3600) return `${Math.floor(diff / 60)} menit yang lalu`;
                if (diff < 86400) return `${Math.floor(diff / 3600)} jam yang lalu`;
                
                const options = { 
                    year: 'numeric', 
                    month: 'short', 
                    day: 'numeric', 
                    hour: '2-digit', 
                    minute: '2-digit' 
                };
                return date.toLocaleDateString('id-ID', options);
            } catch (e) {
                console.error('Error formatting date:', e);
                return '-';
            }
        }
        
        // Load data on page load
        document.addEventListener('DOMContentLoaded', function() {
            // Initial load
            setTimeout(loadOnlineUsers, 1000);
            
            // Auto refresh every 30 seconds
            setInterval(loadOnlineUsers, 30000);
        });
        
        // Listen for real-time SignalR updates
        if (typeof window.dashboardConnection !== 'undefined' && window.dashboardConnection) {
            window.dashboardConnection.on('UserActivityChanged', function(data) {
                console.log('User status changed:', data.userName || data.fullName, data.isOnline ? 'online' : 'offline');
                // Reload the user list when user status changes
                loadOnlineUsers();
            });
        }
    </script>

    <!-- SignalR for Real-time Updates -->
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@latest/dist/browser/signalr.min.js"></script>
    <script src="~/js/dashboard-realtime.js" asp-append-version="true"></script>

    <!-- Real-time status indicator styles -->
    <style>
        .realtime-status {
            display: inline-flex;
            align-items: center;
            font-size: 12px;
            padding: 4px 8px;
            border-radius: 4px;
        }
        .realtime-status.status-connected {
            color: #198754;
            background-color: #d1e7dd;
        }
        .realtime-status.status-reconnecting {
            color: #ffc107;
            background-color: #fff3cd;
            animation: pulse 1.5s ease-in-out infinite;
        }
        .realtime-status.status-disconnected,
        .realtime-status.status-error {
            color: #dc3545;
            background-color: #f8d7da;
        }
        @@keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        @@keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
    </style>
}

@functions {
    string GetStatusBadgeClass(string status) {
        return status?.ToLower() switch {
            "created" => "success",
            "draft" => "secondary",
            "in progress" => "primary",
            "completed" => "info",
            _ => "danger"
        };
    }

    string GetWinRateClass(decimal winRate) {
        return winRate switch {
            >= 70 => "success",
            >= 40 => "info",
            >= 20 => "warning",
            _ => "danger"
        };
    }
}
