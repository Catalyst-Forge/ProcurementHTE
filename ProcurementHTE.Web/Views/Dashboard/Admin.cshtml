@using System.Text.Json
@model DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    var jsonOptions = new JsonSerializerOptions(JsonSerializerDefaults.Web);
    var adminChartConfig = new
    {
        roleDistribution = Model.RoleDistribution,
        regionDistribution = Model.RegionDistribution
    };
}

<div class="container-fluid py-4" data-dashboard-realtime="true">
    @await Html.PartialAsync("_AdminDashboardHeader", Model)
    @await Html.PartialAsync("_AdminDashboardStats", Model)
    @await Html.PartialAsync("_AdminDashboardAccrualOverview", Model)
    @await Html.PartialAsync("_AdminDashboardFinancialSummary", Model)
    @await Html.PartialAsync("_AdminDashboardProcurementTables", Model)
    @await Html.PartialAsync("_AdminDashboardCharts", Model)
    @await Html.PartialAsync("_AdminDashboardUserActivity", Model)
    @await Html.PartialAsync("_AdminDashboardTopVendors", Model)
    @await Html.PartialAsync("_AdminDashboardRecentPurchaseRequisitions", Model)
</div>

@section Scripts {
    @await Html.PartialAsync("~/Views/Dashboard/Partials/_DashboardChartsScripts.cshtml", Model)
    <script>
        window.adminDashboardConfig = @Html.Raw(JsonSerializer.Serialize(adminChartConfig, jsonOptions));
    </script>
    <script src="~/js/dashboard/admin/charts.js" asp-append-version="true"></script>
    <script src="~/js/dashboard/admin/users.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@latest/dist/browser/signalr.min.js"></script>
    <script src="~/js/dashboard-realtime-ui.js" asp-append-version="true"></script>`r`n    <script src="~/js/dashboard-realtime.js" asp-append-version="true"></script>
}

@section HeadScripts {
    <link rel="stylesheet" href="~/css/dashboard-admin.css" asp-append-version="true" />
}
