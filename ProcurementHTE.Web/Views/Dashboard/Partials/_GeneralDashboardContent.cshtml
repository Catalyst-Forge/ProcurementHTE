@using System.Text.Json
@model ProcurementHTE.Web.Models.ViewModels.DashboardViewModel

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">
            <i class="bi bi-speedometer2 me-2"></i>Dashboard Procurement - @Model.RoleName
        </h1>
        <div class="text-muted">
            <i class="bi bi-clock me-1"></i>
            <span id="currentDateTime"></span>
        </div>
    </div>

    @await Html.PartialAsync("~/Views/Dashboard/Partials/_DashboardStatsCards.cshtml", Model)
    @await Html.PartialAsync("~/Views/Dashboard/Partials/_DashboardFinancialSummary.cshtml", Model)
    @await Html.PartialAsync("~/Views/Dashboard/Partials/_DashboardDataTables.cshtml", Model)
    @await Html.PartialAsync("~/Views/Dashboard/Partials/_DashboardCharts.cshtml", Model)
    @await Html.PartialAsync("~/Views/Dashboard/Partials/_DashboardVendorsTable.cshtml", Model)
    @await Html.PartialAsync("~/Views/Dashboard/Partials/_DashboardPurchaseRequisitions.cshtml", Model)
</div>

@* Include Dashboard Charts Scripts *@
@await Html.PartialAsync("~/Views/Dashboard/Partials/_DashboardChartsScripts.cshtml", Model)

<script>
    // Update current date time
    function updateDateTime() {
        const now = new Date();
        const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' };
        const element = document.getElementById('currentDateTime');
        if (element) {
            element.textContent = now.toLocaleDateString('id-ID', options);
        }
    }
    updateDateTime();
    setInterval(updateDateTime, 60000);
</script>
