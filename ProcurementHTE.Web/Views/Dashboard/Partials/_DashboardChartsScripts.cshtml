@using System.Text.Json
@using ProcurementHTE.Core.Models.DTOs
@using ProcurementHTE.Web.Models.ViewModels
@model ProcurementHTE.Web.Models.ViewModels.DashboardViewModel
@{
    var jsonOptions = new JsonSerializerOptions(JsonSerializerDefaults.Web);
    // Use ProcurementsByStatus (ViewModels) for charts
    var procurementStatusJson = JsonSerializer.Serialize(Model.ProcurementsByStatus ?? new List<StatusCountViewModel>(), jsonOptions);
    var revenuePerMonthJson = JsonSerializer.Serialize(Model.RevenuePerMonth ?? Array.Empty<RevenuePerMonthDto>(), jsonOptions);
    // ApprovalStatus removed - approval per-document sudah dihapus
    var documentApprovalStatsJson = JsonSerializer.Serialize(Model.DocumentApprovalStats ?? new List<StatusCountViewModel>(), jsonOptions);
    var jobTypeDistributionJson = JsonSerializer.Serialize(Model.JobTypeDistribution ?? new List<JobTypeCountViewModel>(), jsonOptions);
    var monthlyProcurementTrendJson = JsonSerializer.Serialize(Model.MonthlyProcurementTrend ?? new List<MonthlyTrendViewModel>(), jsonOptions);
    var monthlyPrTrendJson = JsonSerializer.Serialize(Model.MonthlyPurchaseRequisitionTrend ?? new List<MonthlyTrendViewModel>(), jsonOptions);
}
<script>
    (function renderDashboardCharts(retry = 0) {
        const MAX_RETRIES = 5;
        if (typeof window.Chart === "undefined") {
            if (retry < MAX_RETRIES) {
                setTimeout(() => renderDashboardCharts(retry + 1), 250);
            }
            return;
        }

        const destroyExistingChart = (canvas) => {
            if (!canvas || typeof Chart === "undefined") return;
            let existing = Chart.getChart ? (Chart.getChart(canvas) || Chart.getChart(canvas.id)) : null;
            if (!existing && Chart.instances) {
                if (Chart.instances instanceof Map) {
                    existing = Chart.instances.get(canvas) || Chart.instances.get(canvas.id);
                } else if (Array.isArray(Chart.instances)) {
                    existing = Chart.instances.find(inst => inst?.canvas === canvas);
                } else {
                    existing = Chart.instances[canvas.id] || Chart.instances[canvas];
                }
            }
            if (existing && typeof existing.destroy === "function") {
                existing.destroy();
            }
        };

        const renderNoDataMessage = (ctx, canvas, message = "No data available") => {
            if (!ctx || !canvas) return;
            ctx.font = "16px Arial";
            ctx.fillStyle = "#999";
            ctx.textAlign = "center";
            ctx.textBaseline = "middle";
            ctx.fillText(message, canvas.width / 2, canvas.height / 2);
        };

        // Procurement Status Chart
        const procurementStatusCanvas = document.getElementById("procurementStatusChart");
        if (procurementStatusCanvas) {
            const procurementStatusData = @Html.Raw(procurementStatusJson);
            const procurementStatusCtx = procurementStatusCanvas.getContext("2d");
            destroyExistingChart(procurementStatusCanvas);
            
            if (procurementStatusData && procurementStatusData.length > 0) {
                new Chart(procurementStatusCtx, {
                    type: "doughnut",
                    data: {
                        labels: procurementStatusData.map(item => item.statusName),
                        datasets: [{
                            data: procurementStatusData.map(item => item.count),
                            backgroundColor: ["#0d6efd","#198754","#ffc107","#dc3545","#6c757d"],
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: {
                                position: "bottom"
                            }
                        }
                    }
                });
            } else {
                renderNoDataMessage(procurementStatusCtx, procurementStatusCanvas, "No data available");
            }
        }

        // Revenue Chart
        const revenueCanvas = document.getElementById("revenueChart");
        if (revenueCanvas) {
            const revenuePerMonth = @Html.Raw(revenuePerMonthJson);
            const revenueCtx = revenueCanvas.getContext("2d");
            const monthNames = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
            const revenueLabels = revenuePerMonth.map(item => monthNames[item.month - 1]);
            const revenueData = revenuePerMonth.map(item => item.total);

            destroyExistingChart(revenueCanvas);
            
            if (revenuePerMonth && revenuePerMonth.length > 0) {
                new Chart(revenueCtx, {
                    type: "line",
                    data: {
                        labels: revenueLabels,
                        datasets: [{
                            label: "Revenue",
                            data: revenueData,
                            borderColor: "#0d6efd",
                            backgroundColor: "rgba(13, 110, 253, 0.12)",
                            tension: 0.35,
                            fill: true,
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: {
                                display: false
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    callback: function(value) {
                                        return "Rp " + Number(value).toLocaleString("id-ID");
                                    }
                                }
                            }
                        }
                    }
                });
            }
        }

        // Approval Status Chart - now using DocumentApprovalStats (PR status based)
        const approvalCanvas = document.getElementById("approvalStatusChart");
        if (approvalCanvas) {
            const approvalStatus = @Html.Raw(documentApprovalStatsJson);
            const approvalCtx = approvalCanvas.getContext("2d");
            destroyExistingChart(approvalCanvas);
            
            if (approvalStatus && approvalStatus.length > 0) {
                new Chart(approvalCtx, {
                    type: "doughnut",
                    data: {
                        labels: approvalStatus.map(x => x.statusName),
                        datasets: [{
                            data: approvalStatus.map(x => x.count),
                            backgroundColor: ["#198754", "#ffc107", "#dc3545", "#0d6efd"],
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: { position: "bottom" }
                        }
                    }
                });
            }
        }

        // Job Type Distribution Chart
        const jobTypeCanvas = document.getElementById("jobTypeChart");
        if (jobTypeCanvas) {
            const jobTypeData = @Html.Raw(jobTypeDistributionJson);
            const jobTypeCtx = jobTypeCanvas.getContext("2d");
            destroyExistingChart(jobTypeCanvas);
            
            if (jobTypeData && jobTypeData.length > 0) {
                new Chart(jobTypeCtx, {
                    type: "bar",
                    data: {
                        labels: jobTypeData.map(item => item.jobTypeName),
                        datasets: [{
                            label: "Count",
                            data: jobTypeData.map(item => item.count),
                            backgroundColor: "rgba(13, 110, 253, 0.7)",
                            borderColor: "rgb(13, 110, 253)",
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            y: { 
                                beginAtZero: true,
                                ticks: { precision: 0 }
                            }
                        }
                    }
                });
            } else {
                renderNoDataMessage(jobTypeCtx, jobTypeCanvas, "No data available");
            }
        }

        // Monthly Procurement Trend Chart
        const monthlyTrendCanvas = document.getElementById("monthlyTrendChart");
        if (monthlyTrendCanvas) {
            const monthlyTrendData = @Html.Raw(monthlyProcurementTrendJson);
            const monthlyTrendCtx = monthlyTrendCanvas.getContext("2d");
            destroyExistingChart(monthlyTrendCanvas);
            
            if (monthlyTrendData && monthlyTrendData.length > 0) {
                new Chart(monthlyTrendCtx, {
                    type: "line",
                    data: {
                        labels: monthlyTrendData.map(item => item.monthYear),
                        datasets: [{
                            label: "Procurement Count",
                            data: monthlyTrendData.map(item => item.count),
                            borderColor: "rgb(75, 192, 192)",
                            backgroundColor: "rgba(75, 192, 192, 0.2)",
                            tension: 0.4,
                            fill: true
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            y: { 
                                beginAtZero: true,
                                ticks: { precision: 0 }
                            }
                        }
                    }
                });
            } else {
                renderNoDataMessage(monthlyTrendCtx, monthlyTrendCanvas, "No data available");
            }
        }

        // Purchase Requisition Chart (Line chart for trend)
        const prCanvas = document.getElementById("purchaseRequisitionChart");
        if (prCanvas) {
            const prTrendData = @Html.Raw(monthlyPrTrendJson);
            const prCtx = prCanvas.getContext("2d");
            destroyExistingChart(prCanvas);

            if (prTrendData && prTrendData.length > 0) {
                new Chart(prCtx, {
                    type: "line",
                    data: {
                        labels: prTrendData.map(item => item.monthYear),
                        datasets: [{
                            label: "Purchase Requisitions",
                            data: prTrendData.map(item => item.count),
                            borderColor: "#6f42c1",
                            backgroundColor: "rgba(111, 66, 193, 0.2)",
                            tension: 0.4,
                            fill: true,
                            borderWidth: 2,
                            pointRadius: 4,
                            pointHoverRadius: 6,
                            pointBackgroundColor: "#6f42c1",
                            pointBorderColor: "#fff",
                            pointBorderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        return "Total PR: " + context.parsed.y;
                                    }
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: { precision: 0 }
                            },
                            x: {
                                grid: {
                                    display: false
                                }
                            }
                        }
                    }
                });
            } else {
                renderNoDataMessage(prCtx, prCanvas, "No data available");
            }
        }
    })();
</script>
