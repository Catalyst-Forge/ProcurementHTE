@model AccountSettingsPageViewModel

<div class="card mt-4 shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div><h5 class="mb-0">Two-Factor Authentication</h5></div>
        @if (Model.Settings.TwoFactor.IsEnabled)
        {
            <form asp-action="DisableTwoFactor" method="post">
                <button type="submit" class="btn btn-outline-danger btn-sm">Nonaktifkan</button>
            </form>
        }
    </div>
    <div class="card-body">
        @if (!Model.Settings.TwoFactor.IsEnabled)
        {
            @await Html.PartialAsync("_SettingsTwoFactorDisabled", Model)
        }
        else
        {
            @await Html.PartialAsync("_SettingsTwoFactorEnabled", Model)
        }
    </div>
</div>
