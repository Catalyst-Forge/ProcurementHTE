@model AccountSettingsPageViewModel

<div class="d-flex flex-wrap align-items-center justify-content-between mb-4 gap-3">
    <div>
        <h2 class="mb-0">Pengaturan Akun</h2>
        <p class="text-muted mb-0">Kelola identitas dasar, keamanan, dan perangkat aktif.</p>
    </div>
    <span class="badge @(Model.Settings.TwoFactor.IsEnabled ? "text-bg-success" : "text-bg-secondary")">
        @(Model.Settings.TwoFactor.IsEnabled ? "2FA Aktif" : "2FA Belum Aktif")
    </span>
</div>
