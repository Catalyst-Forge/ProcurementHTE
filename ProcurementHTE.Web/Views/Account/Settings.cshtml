@using System.Text.Json
@using ProcurementHTE.Core.Enums
@model AccountSettingsViewModel

@{
    ViewData["Title"] = "Pengaturan Akun";
    var page = new AccountSettingsPageViewModel
    {
        Settings = Model,
        ShowPhoneVerify = ViewBag.ShowPhoneVerify is bool showPhoneVerify && showPhoneVerify,
        DevMagicLink = ViewBag.DevMagicLink as string,
        DevPhoneOtp = ViewBag.DevPhoneOtp as string,
        EmailVerificationCooldown = ViewBag.EmailVerificationCooldown as int? ?? 0,
        PhoneVerificationCooldown = ViewBag.PhoneVerificationCooldown as int? ?? 0,
        SmsVerificationAvailable = ViewBag.SmsVerificationAvailable as bool? ?? false,
        RequireEmailVerificationForTwoFactor = (ViewBag.RequireEmailVerificationForTwoFactor as bool?) ?? false,
        RequirePhoneVerificationForTwoFactor = (ViewBag.RequirePhoneVerificationForTwoFactor as bool?) ?? false
    };
    var jsConfig = new
    {
        sendCodeUrl = Url.Action("SendTwoFactorCode"),
        authenticatorMethod = TwoFactorMethod.AuthenticatorApp.ToString(),
        emailMethod = TwoFactorMethod.Email.ToString(),
        smsMethod = TwoFactorMethod.Sms.ToString()
    };
}

@section HeadScripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/cropperjs@1.6.1/dist/cropper.min.css" />
}

@await Html.PartialAsync("_SettingsHeader", page)
@await Html.PartialAsync("_SettingsHero", page)
@await Html.PartialAsync("_SettingsAvatarForm")
@await Html.PartialAsync("_SettingsContactVerification", page)
@await Html.PartialAsync("_SettingsProfileCard", Model)
@await Html.PartialAsync("_SettingsSecurityArea", page)
@await Html.PartialAsync("_SettingsAvatarModal")

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/cropperjs@1.6.1/dist/cropper.min.js"></script>
    <script>
        window.accountSettingsConfig = @Html.Raw(JsonSerializer.Serialize(jsConfig, new JsonSerializerOptions(JsonSerializerDefaults.Web)));
    </script>
    <script src="~/js/account/settings/avatar.js" asp-append-version="true"></script>
    <script src="~/js/account/settings/two-factor.js" asp-append-version="true"></script>
    <script src="~/js/account/settings/cooldown.js" asp-append-version="true"></script>
    <script src="~/js/account/settings/otp.js" asp-append-version="true"></script>
}
