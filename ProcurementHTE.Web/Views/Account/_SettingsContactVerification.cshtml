@model AccountSettingsPageViewModel

<div class="card shadow-sm mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div>
            <h5 class="mb-0">Verifikasi Kontak</h5>
            <small class="text-muted">Pastikan email terverifikasi. Verifikasi nomor HP akan aktif setelah gateway SMS/WhatsApp tersedia.</small>
        </div>
        <span class="badge @(Model.ContactVerificationComplete ? "text-bg-success" : "text-bg-warning")">
            @(Model.ContactVerificationComplete ? "Kontak utama tervalidasi" : "Butuh verifikasi")
        </span>
    </div>
    <div class="card-body">
        <div class="row g-4">
            <div class="col-md-6">
                @await Html.PartialAsync("_SettingsEmailVerification", Model)
            </div>
            <div class="col-md-6">
                @await Html.PartialAsync("_SettingsPhoneVerification", Model)
            </div>
        </div>
    </div>
</div>
