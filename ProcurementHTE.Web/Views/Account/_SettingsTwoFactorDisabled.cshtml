@using ProcurementHTE.Core.Enums
@model AccountSettingsPageViewModel

<div class="alert alert-warning small">
    Pilih metode autentikasi yang Anda inginkan, kemudian masukkan kode verifikasi untuk mengaktifkan.
</div>
<form asp-action="EnableTwoFactor" method="post" id="twoFactorEnableForm">
    <div class="mb-3">
        <label class="form-label fw-semibold">Metode</label>
        <div class="list-group">
            <label class="list-group-item d-flex align-items-start gap-2">
                <input class="form-check-input mt-1" type="radio" name="method" value="@TwoFactorMethod.AuthenticatorApp" checked />
                <span><span class="fw-semibold d-block">Authenticator App</span><small class="text-muted">Gunakan Google Authenticator, Microsoft Authenticator, dll.</small></span>
            </label>
            <label class="list-group-item d-flex align-items-start gap-2">
                <input class="form-check-input mt-1" type="radio" name="method" value="@TwoFactorMethod.Email" />
                <span><span class="fw-semibold d-block">Email OTP</span><small class="text-muted">Kode dikirim ke email @Model.Settings.Overview.Email.</small></span>
            </label>
            <label class="list-group-item d-flex align-items-start gap-2 @(Model.SmsVerificationAvailable && Model.Settings.Overview.PhoneNumberConfirmed ? string.Empty : "text-muted")">
                <input class="form-check-input mt-1" type="radio" name="method" value="@TwoFactorMethod.Sms" @(Model.SmsVerificationAvailable && Model.Settings.Overview.PhoneNumberConfirmed ? string.Empty : "disabled") />
                <span>
                    <span class="fw-semibold d-block">SMS OTP</span>
                    <small class="text-muted">@(Model.SmsVerificationAvailable ? "Pastikan nomor HP sudah terverifikasi." : "Belum tersedia sampai gateway SMS/WhatsApp dikonfigurasi.")</small>
                </span>
            </label>
        </div>
    </div>

    <div class="border rounded p-3 mb-3 bg-light-subtle small" id="authenticatorInfo">
        <div class="d-flex flex-wrap align-items-center gap-3">
            <div>
                <span class="fw-semibold d-block text-uppercase text-muted small">Kode Rahasia</span>
                <span class="fs-5 fw-bold">@Model.Settings.TwoFactor.SharedKey</span>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Settings.TwoFactor.AuthenticatorQrBase64))
            {
                <img src="data:image/png;base64,@Model.Settings.TwoFactor.AuthenticatorQrBase64" alt="QR" class="border rounded w-100" />
            }
        </div>
        <p class="mt-3 mb-0">Scan QR atau masukkan kode rahasia ke aplikasi autentikator.</p>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold">Kode Verifikasi</label>
        <div class="input-group">
            <input type="text" name="verificationCode" class="form-control" placeholder="123456" required maxlength="8" />
            <button type="button" class="btn btn-outline-secondary d-none" id="btnSendSetupCode">Kirim Kode</button>
        </div>
        <small class="text-muted" id="twoFactorCodeHelp">Masukkan kode dari aplikasi authenticator.</small>
    </div>

    <div class="d-flex justify-content-end">
        <button type="submit" class="btn btn-success"><i class="bi bi-shield-lock"></i> Aktifkan 2FA</button>
    </div>
</form>
