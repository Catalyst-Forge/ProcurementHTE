@using ProcurementHTE.Web.Models.Admin
@model UserManagementIndexViewModel

@{
    ViewData["Title"] = "Manajemen User";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Manajemen User</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Tambah User
    </a>
</div>

@await Html.PartialAsync("Partials/_SummaryCards", Model)

@await Html.PartialAsync("Partials/_Filter", Model)

<div class="card">
    <div class="card-header">
        Daftar User
    </div>
    <div class="card-body p-0">
        @await Html.PartialAsync("Partials/_UserTable", Model)
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="card-footer">
            @await Html.PartialAsync("Partials/_Pagination", Model)
        </div>
    }
</div>
