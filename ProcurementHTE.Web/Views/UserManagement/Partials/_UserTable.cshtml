@using ProcurementHTE.Web.Models.Admin
@model UserManagementIndexViewModel

<div class="table-responsive">
    <table class="table table-hover mb-0 align-middle">
        <thead class="table-light">
            <tr>
                <th>Nama</th>
                <th>Email</th>
                <th>Username</th>
                <th>Jabatan</th>
                <th>Roles</th>
                <th>Status</th>
                <th>2FA</th>
                <th>Last Login</th>
                <th style="width: 140px;"></th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Users.Any())
            {
                foreach (var user in Model.Users)
                {
                    <tr>
                        <td>@user.DisplayName</td>
                        <td>@user.Email</td>
                        <td>@user.UserName</td>
                        <td>@user.JobTitle</td>
                        <td>
                            @if (user.Roles.Any())
                            {
                                foreach (var role in user.Roles)
                                {
                                    <span class="badge bg-primary me-1">@role</span>
                                }
                            }
                        </td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge bg-success">Aktif</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Nonaktif</span>
                            }
                        </td>
                        <td>
                            @if (user.TwoFactorEnabled)
                            {
                                <span class="badge bg-info text-dark">Aktif</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">-</span>
                            }
                        </td>
                        <td>
                            @(user.LastLoginAt?.ToString("dd/MM/yyyy HH:mm") ?? "-")
                        </td>
                        <td class="text-end">
                            @{
                                var currentUserId = User?.Claims?.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                                var isSelf = string.Equals(user.Id, currentUserId, StringComparison.OrdinalIgnoreCase);
                            }
                            <div class="btn-group btn-group-sm">
                                <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-outline-primary" title="Edit user">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <form asp-action="ToggleActive" asp-route-id="@user.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-outline-warning"
                                            title="Aktif/Nonaktif"
                                            onclick="return confirm('Ubah status aktif user ini?');">
                                        <i class="bi bi-power"></i>
                                    </button>
                                </form>
                                <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit"
                                            class="btn btn-outline-danger"
                                            title="Hapus user"
                                            @(isSelf ? "disabled" : "")
                                            onclick="return confirm('Hapus user ini? Tindakan tidak dapat dibatalkan.');">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="9" class="text-center py-4">
                        Tidak ada data user.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
