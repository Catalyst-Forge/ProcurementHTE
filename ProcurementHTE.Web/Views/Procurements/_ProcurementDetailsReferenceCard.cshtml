@model ProcurementDetailsPageViewModel

<article class="card shadow-sm mb-3 rounded-4">
    <header class="card-header mt-2 fw-semibold bg-transparent border-bottom-0">
        <h2 class="card-title mb-0 h5"><i class="bi bi-hash text-primary me-1"></i> Reference Numbers</h2>
    </header>
    <hr class="mx-3 my-2" />

    <div class="card-body">
        <div class="row mb-0">
            <dl class="col-12 col-sm-6 col-md-4 mb-2">
                <dt class="fw-semibold text-uppercase text-secondary">@Html.DisplayNameFor(m => m.Procurement.SpkNumber)</dt>
                <dd class="fw-medium text-secondary-emphasis">@Model.Procurement.SpkNumber</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-4 mb-2">
                <dt class="fw-semibold text-uppercase text-secondary">@Html.DisplayNameFor(m => m.Procurement.SpmpNumber)</dt>
                <dd class="fw-medium text-secondary-emphasis">@Model.Procurement.SpmpNumber</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-4 mb-2">
                <dt class="fw-semibold text-uppercase text-secondary">@Html.DisplayNameFor(m => m.Procurement.MemoNumber)</dt>
                <dd class="fw-medium text-secondary-emphasis">@Model.Procurement.MemoNumber</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-4 mb-2">
                <dt class="fw-semibold text-uppercase text-secondary">@Html.DisplayNameFor(m => m.Procurement.OeNumber)</dt>
                <dd class="fw-medium text-secondary-emphasis">@Model.Procurement.OeNumber</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-4 mb-2">
                <dt class="fw-semibold text-uppercase text-secondary">@Html.DisplayNameFor(m => m.Procurement.RaNumber)</dt>
                <dd class="fw-medium text-secondary-emphasis">@Model.Procurement.RaNumber</dd>
            </dl>
        </div>
    </div>
</article>
