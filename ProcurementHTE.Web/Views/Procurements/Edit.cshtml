@model ProcurementHTE.Web.Models.ViewModels.ProcurementEditViewModel
@using ProcurementHTE.Core.Models
@using System.Collections.Generic
@{
    ViewData["Title"] = "Edit Procurement";

    Model.Details ??= new List<ProcDetail>();
    Model.Offers ??= new List<ProcOffer>();
}

@await Html.PartialAsync("_EditHeader", Model)

<form asp-action="Edit" method="post" enctype="multipart/form-data" class="js-loading-form" hx-boost="false">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="ProcurementId" />
    <input type="hidden" asp-for="ProcNum" />
    <input type="hidden" asp-for="JobTypeId" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    @await Html.PartialAsync("_EditOverview", Model)
    @await Html.PartialAsync("_EditSchedule", Model)
    @await Html.PartialAsync("_EditReferenceNumbers", Model)
    @await Html.PartialAsync("_EditOffers", Model)
    @await Html.PartialAsync("_EditApprovals", Model)
    @await Html.PartialAsync("_EditActions", Model)
</form>

@section Scripts {
    @await Html.PartialAsync("_EditScripts")
}