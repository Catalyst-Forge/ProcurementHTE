@model ProcurementDetailsPageViewModel

<section class="tab-pane" id="document-tab-pane" role="tabpanel" aria-labelledby="document-tab" tabindex="0">
    <div class="mb-3">
        <header class="mt-2 fw-semibold bg-transparent border-bottom-0">
            <h2 class="card-title mb-0 h5"><i class="bi bi-folder-fill text-primary me-1"></i> Procurement Documents</h2>
        </header>
        <hr />

        @if (Model.Documents.Any())
        {
            <div class="list-group shadow-sm rounded-3">
                @foreach (var doc in Model.Documents)
                {
                    <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <div class="d-flex flex-column flex-sm-row align-items-sm-center">
                            <i class="bi bi-file-earmark-pdf text-danger fs-5 me-3"></i>
                            <div>
                                <div class="fw-semibold">@doc.FileName</div>
                                <small class="text-muted">@doc.Description</small>
                            </div>
                        </div>

                        <div class="text-end">
                            <small class="small text-muted d-block mb-1">@doc.CreatedAt.ToLongDateString()</small>
                            <div class="d-flex flex-column flex-sm-row gap-1 align-items-end">
                                <button type="button"
                                        class="btn btn-sm btn-outline-secondary btn-preview"
                                        data-doc-id="@doc.ProcDocumentId"
                                        data-doc-name="@doc.FileName"
                                        data-file-name="@doc.FileName">
                                    <i class="bi bi-eye"></i> Preview
                                </button>
                                <a asp-controller="ProcurementDocuments"
                                   asp-action="Download"
                                   asp-route-id="@doc.ProcDocumentId"
                                   class="btn btn-outline-primary btn-sm btn-download"
                                   role="button"
                                   data-doc-id="@doc.ProcDocumentId"
                                   hx-boost="false"
                                   download>
                                    <i class="bi bi-download"></i> Download
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="alert alert-info mb-0">No documents available for this procurement.</div>
        }
    </div>
</section>
