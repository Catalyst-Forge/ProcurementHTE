@model ProcurementDetailsPageViewModel

@{
    var rows = Model.ProfitLoss!.Rows;
}

<article class="card shadow-sm mb-3 rounded-4">
    <header class="card-header fw-semibold bg-transparent border-bottom-0 mt-2">
        <h2 class="card-title mb-0 h5"><i class="bi bi-award text-primary me-1"></i> Vendor Comparison</h2>
    </header>
    <hr class="mx-3 my-2" />

    <div class="card-body">
        <div class="table-responsive rounded-3">
            <table class="table align-middle mb-0">
                <thead class="table-info">
                    <tr>
                        <th>Vendor</th>
                        <th class="text-end">Final Offer</th>
                        <th class="text-end">Profit</th>
                        <th class="text-end">Profit %</th>
                        <th class="text-center">Result</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in rows)
                    {
                        <tr class="@(row.IsSelected ? "table-success" : "")">
                            <td>@row.VendorName</td>
                            <td class="text-end">@row.FinalOffer.ToIDR()</td>
                            <td class="text-end">@row.Profit.ToIDR()</td>
                            <td class="text-end">@row.ProfitPercent.ToPersen()</td>
                            <td class="text-center">
                                @if (row.IsSelected)
                                {
                                    <span class="badge py-2 px-3 bg-success-subtle text-success border border-success rounded-5">
                                        <i class="bi bi-check-circle-fill"></i> Selected
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="small text-muted px-3 pb-3">
        The selected vendor is chosen based on the best profit,
        calculated from the vendor with the lowest total price
        (Σ the minimum price per item across all negotiation rounds).
    </div>
</article>
