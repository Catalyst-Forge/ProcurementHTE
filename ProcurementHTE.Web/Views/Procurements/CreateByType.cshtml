@model ProcurementCreateViewModel
@{
    ViewData["Title"] = "Create Procurement";
    Model.Procurement ??= new Procurement();
    Model.Details ??= new List<ProcDetail>();
    Model.Offers ??= new List<ProcOffer>();
}

@await Html.PartialAsync("_CreateByTypeHeader", Model)

<form asp-action="Create" method="post" enctype="multipart/form-data" class="js-loading-form" id="procurementForm" novalidate hx-boost="false">
    @Html.AntiForgeryToken()
    @await Html.PartialAsync("_CreateByTypeValidationSummary", Model)
    @await Html.PartialAsync("_CreateByTypeOverview", Model)
    @await Html.PartialAsync("_CreateByTypeSchedule", Model)
    @await Html.PartialAsync("_CreateByTypeReferenceNumbers", Model)
    @await Html.PartialAsync("_CreateByTypeOffers", Model)
    @await Html.PartialAsync("_CreateByTypeApprovals", Model)
    @await Html.PartialAsync("_CreateByTypeActions", Model)
</form>

@section Scripts {
    @await Html.PartialAsync("_CreateByTypeScripts", Model)
}
