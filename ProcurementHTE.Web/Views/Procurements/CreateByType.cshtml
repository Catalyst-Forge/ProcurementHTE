@model ProcurementHTE.Web.Models.ViewModels.ProcurementCreateViewModel
@using Microsoft.AspNetCore.Mvc.Rendering
@using ProcurementHTE.Core.Models
@using System.Linq
@{
    ViewData["Title"] = "Create Procurement";
    var jobTypes = (Model.JobTypes ?? Enumerable.Empty<JobTypes>()).ToList();
    var procurement = Model.Procurement ??= new Procurement();
    Model.Details ??= new List<ProcDetail>();
    Model.Offers ??= new List<ProcOffer>();

    var contractTypeOptions = Html.GetEnumSelectList<ProcurementHTE.Core.Enums.ContractType>();
    var categoryOptions = Html.GetEnumSelectList<ProcurementHTE.Core.Enums.ProcurementCategory>();
    var projectRegionOptions = Html.GetEnumSelectList<ProcurementHTE.Core.Enums.ProjectRegion>();

    var picOpsOptions = (Model.PicOpsUsers ?? Enumerable.Empty<SelectListItem>()).ToList();
    var analystOptions = (Model.AnalystUsers ?? Enumerable.Empty<SelectListItem>()).ToList();
    var assistantManagerOptions = (Model.AssistantManagerUsers ?? Enumerable.Empty<SelectListItem>()).ToList();
    var managerOptions = (Model.ManagerUsers ?? Enumerable.Empty<SelectListItem>()).ToList();

    // Helper untuk format date - return null jika MinValue agar input kosong
    string? FormatDateValue(DateTime date) => date == DateTime.MinValue ? null : date.ToString("yyyy-MM-dd");

    var jobTypeOptions = new SelectList(jobTypes, "JobTypeId", "TypeName", procurement.JobTypeId);

    var unitTypes = ViewBag.UnitTypes as List<UnitType> ?? new List<UnitType>();
    var selectedJobTypeName = ViewBag.SelectedJobTypeName as string ?? "Other";
}

<header class="hstack justify-content-between mb-3">
    <div>
        <h2 class="mb-1">@ViewData["Title"]</h2>
    </div>
    <a class="btn btn-outline-secondary" asp-action="Index" role="button">
        <i class="bi bi-arrow-left"></i> Back
    </a>
</header>

<form asp-action="Create" method="post" enctype="multipart/form-data" class="js-loading-form" id="procurementForm" novalidate hx-boost="false">
    @Html.AntiForgeryToken()

    <!-- General Errors Display (for status not found, etc.) -->
    @if (!ViewData.ModelState.IsValid)
    {
        var generalErrors = ViewData.ModelState[""]?.Errors;
        if (generalErrors != null && generalErrors.Count > 0)
        {
            <div class="alert alert-danger mb-3">
                <strong><i class="bi bi-exclamation-triangle"></i> Error:</strong>
                <ul class="mb-0 mt-2">
                    @foreach (var error in generalErrors)
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
            </div>
        }
    }

    <!-- OVERVIEW -->
    <section class="card shadow-sm mb-3 p-2 rounded-4">
        <fieldset class="card-body">
            <legend class="card-title fw-semibold">Procurement Overview</legend>
            <hr />

            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label" asp-for="Procurement.JobTypeId">Job Type</label>
                    <select class="form-select" asp-for="Procurement.JobTypeId" asp-items="jobTypeOptions"></select>
                    <span class="text-danger" asp-validation-for="Procurement.JobTypeId"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Procurement.ContractType" class="form-label"></label>
                    <select asp-for="Procurement.ContractType" class="form-select" asp-items="contractTypeOptions"></select>
                    <span class="text-danger" asp-validation-for="Procurement.ContractType"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Procurement.ProcurementCategory" class="form-label">Jenis Pengadaan</label>

                    <select asp-for="Procurement.ProcurementCategory"
                            class="form-select"
                            asp-items="categoryOptions"
                            hx-get="@Url.Action("RenderRaNumberField", "Procurements")"
                            hx-trigger="change"
                            hx-target="#raNumberWrapper"
                            hx-swap="innerHTML"
                            hx-vals="js:{category: event.target.value, raNumber: document.getElementById('Procurement_RaNumber')?.value || ''}"></select>

                    <span class="text-danger" asp-validation-for="Procurement.ProcurementCategory"></span>
                </div>
            </div>

            <div class="row g-3 mt-0">
                <div class="col-12">
                    <label asp-for="Procurement.JobName" class="form-label"></label>
                    <textarea asp-for="Procurement.JobName" class="form-control" rows="3" maxlength="255"></textarea>
                    <span class="text-danger" asp-validation-for="Procurement.JobName"></span>
                </div>
            </div>

            <div class="row g-3 mt-0">
                <div class="col-md-4">
                    <label asp-for="Procurement.ProjectRegion" class="form-label"></label>
                    <select asp-for="Procurement.ProjectRegion" class="form-select" asp-items="projectRegionOptions"></select>
                    <span class="text-danger" asp-validation-for="Procurement.ProjectRegion"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Procurement.ProjectCode" class="form-label"></label>
                    <input asp-for="Procurement.ProjectCode" class="form-control" maxlength="64" />
                    <span class="text-danger" asp-validation-for="Procurement.ProjectCode"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Procurement.Wonum" class="form-label"></label>
                    <input asp-for="Procurement.Wonum" class="form-control" maxlength="100" />
                    <span class="text-danger" asp-validation-for="Procurement.Wonum"></span>
                </div>
            </div>
        </fieldset>
    </section>

    <section class="card shadow-sm mb-3 p-2 rounded-4">
        <fieldset class="card-body">
            <legend class="card-title fw-semibold">Schedule &amp; Etc</legend>
            <hr />

            <div class="row g-3">
                <div class="col-md-3">
                    <label asp-for="Procurement.DocumentDate" class="form-label"></label>
                    <input asp-for="Procurement.DocumentDate" type="date" class="form-control" value="@FormatDateValue(Model.Procurement.DocumentDate)" />
                    <span class="text-danger" asp-validation-for="Procurement.DocumentDate"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Procurement.StartDate" class="form-label"></label>
                    <input asp-for="Procurement.StartDate" type="date" class="form-control" value="@FormatDateValue(Model.Procurement.StartDate)" />
                    <span class="text-danger" asp-validation-for="Procurement.StartDate"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Procurement.EndDate" class="form-label"></label>
                    <input asp-for="Procurement.EndDate" type="date" class="form-control" value="@FormatDateValue(Model.Procurement.EndDate)" />
                    <span class="text-danger" asp-validation-for="Procurement.EndDate"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Procurement.PotentialAccrualDate" class="form-label"></label>
                    <input asp-for="Procurement.PotentialAccrualDate" type="date" class="form-control" />
                    <span class="text-danger" asp-validation-for="Procurement.PotentialAccrualDate"></span>
                </div>
            </div>

            <div class="row g-3 mt-0">
                <div class="col-md-6">
                    <label asp-for="Procurement.LtcName" class="form-label"></label>
                    <input asp-for="Procurement.LtcName" class="form-control" maxlength="255" />
                    <span class="text-danger" asp-validation-for="Procurement.LtcName"></span>
                </div>
            </div>

            <div class="mt-3">
                <label asp-for="Procurement.Note" class="form-label"></label>
                <textarea asp-for="Procurement.Note" class="form-control" rows="3" maxlength="1000"></textarea>
                <span class="text-danger" asp-validation-for="Procurement.Note"></span>
            </div>
        </fieldset>
    </section>

    <!-- REFERENCE NUMBERS -->
    <section class="card shadow-sm mb-3 p-2 rounded-4">
        <fieldset class="card-body">
            <legend class="card-title fw-semibold">Reference Numbers</legend>
            <hr />

            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Procurement.SpkNumber" class="form-label"></label>
                    <input asp-for="Procurement.SpkNumber" class="form-control" maxlength="100" />
                    <span class="text-danger" asp-validation-for="Procurement.SpkNumber"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Procurement.SpmpNumber" class="form-label"></label>
                    <div class="input-group">
                        <input asp-for="Procurement.SpmpNumber" class="form-control" maxlength="50" placeholder="e.g., 4514" />
                        <span class="input-group-text">/PDC-1110/@DateTime.Now.Year-S0</span>
                    </div>
                    <small class="form-text text-muted">Masukkan angka/kode saja (contoh: 4514)</small>
                    <span class="text-danger" asp-validation-for="Procurement.SpmpNumber"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="Procurement.MemoNumber" class="form-label"></label>
                    <input asp-for="Procurement.MemoNumber" class="form-control" maxlength="100" />
                    <span class="text-danger" asp-validation-for="Procurement.MemoNumber"></span>
                </div>
            </div>

            <div class="row g-3 mt-0">
                <div class="col-md-6">
                    <label asp-for="Procurement.OeNumber" class="form-label"></label>
                    <div class="input-group">
                        <input asp-for="Procurement.OeNumber" class="form-control" maxlength="50" placeholder="e.g., OE-TRS" />
                        <span class="input-group-text">/PDC-1110/@DateTime.Now.Year-S0</span>
                    </div>
                    <small class="form-text text-muted">Masukkan prefix saja (contoh: OE-TRS)</small>
                    <span class="text-danger" asp-validation-for="Procurement.OeNumber"></span>
                </div>

                <div class="col-md-6" id="raNumberWrapper">
                    @if (Model.Procurement?.ProcurementCategory == ProcurementHTE.Core.Enums.ProcurementCategory.Jasa)
                    {
                        @* @await Html.PartialAsync("_RaNumberField", new ViewDataDictionary(ViewData) { { "RaNumberValue", Model.Procurement.RaNumber } }) *@
                        <label class="form-label" asp-for="Procurement.RaNumber"></label>
                        <input class="form-control" asp-for="Procurement.RaNumber" />
                        <span class="text-danger" asp-validation-for="Procurement.RaNumber"></span>
                    }
                </div>
            </div>

            <div class="row g-3 mt-0">
                <div class="col-md-6">
                    <label asp-for="Procurement.NoRig" class="form-label"></label>
                    <input asp-for="Procurement.NoRig" class="form-control" maxlength="100" placeholder="Masukkan No. Rig" />
                    <span class="text-danger" asp-validation-for="Procurement.NoRig"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Procurement.NoHte" class="form-label"></label>
                    <input asp-for="Procurement.NoHte" class="form-control" maxlength="100" placeholder="Masukkan No. HTE" />
                    <span class="text-danger" asp-validation-for="Procurement.NoHte"></span>
                </div>
            </div>
        </fieldset>
    </section>

    <!-- ITEM PENAWARAN -->
    <section class="card shadow-sm mb-3 p-2 rounded-4">
        <fieldset class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <legend class="card-title fw-semibold mb-0">Offer Item</legend>
                <div class="w-100 text-end">
                    <button type="button" class="btn btn-sm btn-outline-primary" id="btn-add-offer">
                        <i class="bi bi-plus-lg"></i> <span class="ms-1">Add Item</span>
                    </button>
                </div>
            </div>
            <hr />

            <div class="row g-3" id="offers-container">
                @{
                    var offers = Model.Offers ?? new List<ProcOffer>();
                    // Jika tidak ada offers, tampilkan 1 row kosong
                    if (!offers.Any())
                    {
                        offers = new List<ProcOffer> { new ProcOffer() };
                    }
                }
                @for (var i = 0; i < offers.Count; i++)
                {
                    var offer = offers[i];
                    var idx = i;
                    <div class="col-12 offer-row position-relative">
                        <input type="hidden" name="Offers.Index" value="@idx" />

                        <div class="row g-1 align-items-end">
                            <div class="col-md-10">
                                <div class="row g-1">
                                    <div class="col-md-6">
                                        <label class="form-label">Item <span class="text-danger">*</span></label>
                                        <input class="form-control" 
                                               name="Offers[@(idx)].ItemPenawaran" 
                                               value="@offer.ItemPenawaran" />
                                        @Html.ValidationMessage($"Offers[{idx}].ItemPenawaran", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Qty Items <span class="text-danger">*</span></label>
                                        <input type="number" min="1" step="1"
                                               class="form-control text-end"
                                               name="Offers[@(idx)].Qty" 
                                               value="@(offer.Qty > 0 ? offer.Qty : "")" />
                                        @Html.ValidationMessage($"Offers[{idx}].Qty", new { @class = "text-danger" })
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label">Unit Items <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" 
                                               name="Offers[@(idx)].Unit" 
                                               value="@offer.Unit"
                                               placeholder="Pcs, Unit, Set..." />
                                        @Html.ValidationMessage($"Offers[{idx}].Unit", new { @class = "text-danger" })
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <button type="button"
                                        class="btn btn-outline-danger js-remove-offer w-100">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </fieldset>
    </section>

    <!-- APPROVALS -->
    <section class="card shadow-sm mb-3 p-2 rounded-4">
        <fieldset class="card-body">
            <legend class="card-title fw-semibold">Approvals &amp; PIC</legend>
            <hr />

            <div class="row g-3">
                <!-- Analyst HTE -->
                <div class="col-md-5">
                    <label asp-for="Procurement.AnalystHteUserId" class="form-label">Analyst HTE &amp; LTS</label>
                    <select asp-for="Procurement.AnalystHteUserId" class="form-select" asp-items="analystOptions">
                        <option value="">Select Analyst</option>
                    </select>
                    <span class="text-danger" asp-validation-for="Procurement.AnalystHteUserId"></span>
                </div>
                <div class="col-md-1 d-flex align-items-end pb-3">
                    <div class="form-check">
                        <input asp-for="Procurement.AnalystHtePjs" class="form-check-input" type="checkbox" />
                        <label asp-for="Procurement.AnalystHtePjs" class="form-check-label">Pjs</label>
                    </div>
                </div>

                <!-- Assistant Manager -->
                <div class="col-md-5">
                    <label asp-for="Procurement.AssistantManagerUserId" class="form-label">Assistant Manager HTE</label>
                    <select asp-for="Procurement.AssistantManagerUserId" class="form-select" asp-items="assistantManagerOptions">
                        <option value="">Select Assistant Manager</option>
                    </select>
                    <span class="text-danger" asp-validation-for="Procurement.AssistantManagerUserId"></span>
                </div>
                <div class="col-md-1 d-flex align-items-end pb-3">
                    <div class="form-check">
                        <input asp-for="Procurement.AssistantManagerPjs" class="form-check-input" type="checkbox" />
                        <label asp-for="Procurement.AssistantManagerPjs" class="form-check-label">Pjs</label>
                    </div>
                </div>

                <!-- Manager -->
                <div class="col-md-5">
                    <label asp-for="Procurement.ManagerUserId" class="form-label">Manager Transport &amp; Logistic</label>
                    <select asp-for="Procurement.ManagerUserId" class="form-select" asp-items="managerOptions">
                        <option value="">Select Manager</option>
                    </select>
                    <span class="text-danger" asp-validation-for="Procurement.ManagerUserId"></span>
                </div>
                <div class="col-md-1 d-flex align-items-end pb-3">
                    <div class="form-check">
                        <input asp-for="Procurement.ManagerPjs" class="form-check-input" type="checkbox" />
                        <label asp-for="Procurement.ManagerPjs" class="form-check-label">Pjs</label>
                    </div>
                </div>
            </div>

            <hr class="my-3" />
            <p class="text-muted small mb-2">Pjs untuk Level Direksi (jika diperlukan)</p>
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="form-check">
                        <input asp-for="Procurement.VicePresidentPjs" class="form-check-input" type="checkbox" />
                        <label asp-for="Procurement.VicePresidentPjs" class="form-check-label">Pjs. Vice President</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-check">
                        <input asp-for="Procurement.OperationDirectorPjs" class="form-check-input" type="checkbox" />
                        <label asp-for="Procurement.OperationDirectorPjs" class="form-check-label">Pjs. Operation Director</label>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="form-check">
                        <input asp-for="Procurement.PresidentDirectorPjs" class="form-check-input" type="checkbox" />
                        <label asp-for="Procurement.PresidentDirectorPjs" class="form-check-label">Pjs. President Director</label>
                    </div>
                </div>
            </div>
        </fieldset>
    </section>

    <!-- Hidden field for submit action -->
    <input type="hidden" name="submitAction" id="submitActionField" value="Created" />
    
    <div class="d-flex justify-content-end gap-2 mb-2">
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>

        <button type="submit" class="btn btn-outline-secondary" id="btn-save-draft" onclick="document.getElementById('submitActionField').value='Draft';">
            <i class="bi bi-save"></i> Save as Draft
        </button>

        <button type="submit" class="btn btn-success" id="btn-create" onclick="document.getElementById('submitActionField').value='Created';">
            <i class="bi bi-check2-circle"></i> Create
        </button>
    </div>
</form>

@section Scripts {
    <script>
        (function () {
            if (window.procurementOfferInit) return;
            window.procurementOfferInit = true;

            // UnitType data from server
            const unitTypes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(unitTypes.Select(u => new { u.Code, u.Name }).ToList()));

            // JobType to UnitType mapping
            const jobTypeUnitMapping = {
                'Angkutan': ['TRIP'],
                'StandBy': ['HARI', 'JAM', 'LSP'],
                'Moving': ['TRIP', 'KALI']
            };

            function getJobTypeName() {
                const jobTypeSelect = document.querySelector('[name="Procurement.JobTypeId"]');
                if (!jobTypeSelect) return '@selectedJobTypeName';
                const selectedOption = jobTypeSelect.options[jobTypeSelect.selectedIndex];
                return selectedOption ? selectedOption.text : '@selectedJobTypeName';
            }

            function getNextIndex() {
                const indexInputs = document.querySelectorAll('input[name="Offers.Index"]');
                let maxIndex = -1;
                indexInputs.forEach(function(input) {
                    const val = parseInt(input.value, 10);
                    if (!isNaN(val) && val > maxIndex) {
                        maxIndex = val;
                    }
                });
                return maxIndex + 1;
            }

            // Offer Row Template
            function offerTemplate(index) {
                return `
                    <div class="col-12 offer-row position-relative">
                        <input type="hidden" name="Offers.Index" value="${index}" />

                        <div class="row g-1 align-items-end">
                            <div class="col-md-10">
                                <div class="row g-1">
                                    <div class="col-md-6">
                                        <label class="form-label" for="Offers_ItemPenawaran">Item <span class="text-danger">*</span></label>
                                        <input class="form-control" id="Offers_ItemPenawaran" name="Offers[${index}].ItemPenawaran" data-val="true" data-val-required="The ItemPenawaran field is required." aria-describedby="Offers_ItemPenawaran-error" aria-invalid="false" />
                                        <span class="text-danger field-validation-valid" data-valmsg-for="Offers[${index}].ItemPenawaran" data-valmsg-replace="true"></span>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label" for="Offers_Qty">Qty Items <span class="text-danger">*</span></label>
                                        <input type="number" min="1" step="1"
                                                class="form-control text-end" id="Offers_Qty"
                                                name="Offers[${index}].Qty" data-val="true" data-val-required="The Quantity field is required." aria-describedby="Offers_Qty-error" aria-invalid="false" />
                                        <span class="text-danger field-validation-valid" data-valmsg-for="Offers[${index}].Qty" data-valmsg-replace="true"></span>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label" for="Offers_Unit">Unit Items <span class="text-danger">*</span></label>
                                        <input type="text" class="form-control" id="Offers_Unit" name="Offers[${index}].Unit" placeholder="Pcs, Unit, Set..." data-val="true" data-val-required="The Unit field is required." aria-describedby="Offers_Unit-error" aria-invalid="false" />
                                        <span class="text-danger field-validation-valid" data-valmsg-for="Offers[${index}].Unit" data-valmsg-replace="true"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-2">
                                <button type="button"
                                        class="btn btn-outline-danger js-remove-offer w-100">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                `;
            }

            document.addEventListener('click', function (e) {
                const addBtn = e.target.closest('#btn-add-offer');
                if (addBtn) {
                    const container = document.getElementById('offers-container');
                    const index = getNextIndex();
                    container.insertAdjacentHTML('beforeend', offerTemplate(index));
                    return;
                }

                const removeBtn = e.target.closest('.js-remove-offer');
                if (removeBtn) {
                    removeBtn.closest('.offer-row').remove();
                }
            });
        })();
    </script>
}
