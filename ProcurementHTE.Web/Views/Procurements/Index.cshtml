@using ProcurementHTE.Core.Models
@using ProcurementHTE.Core.Common
@model PagedResult<Procurement>

@{
    ViewData["Title"] = "Procurements Data";
}

@await Html.PartialAsync("Partials/_Header")

@await Html.PartialAsync("Partials/_Filter", Model)

@await Html.PartialAsync("Partials/_List", Model)

@await Html.PartialAsync("_Pager", Model)

@section Scripts {
    <script src="~/js/procurements/index.js" asp-append-version="true"></script>
}

@section HeadScripts {
    <style>
        .width-10-rem {
            min-width: 10rem;
        }
    </style>
}