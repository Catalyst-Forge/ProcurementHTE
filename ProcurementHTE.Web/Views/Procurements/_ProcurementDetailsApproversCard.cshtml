@model ProcurementDetailsPageViewModel

@{
    var procurement = Model.Procurement;
}

<article class="card shadow-sm mb-3 rounded-4">
    <header class="card-header mt-2 fw-semibold bg-transparent border-bottom-0">
        <h2 class="card-title mb-0 h5"><i class="bi bi-people text-primary me-1"></i> Approvers</h2>
    </header>
    <hr class="mx-3 my-2" />

    <div class="card-body">
        <dl class="text-bg-light p-3 rounded-4 mb-2">
            <dt class="fw-semibold text-secondary mb-2">@Html.DisplayNameFor(m => m.Procurement.PicOpsUserId)</dt>
            <dd class="fw-medium text-secondary-emphasis">@Model.PicOpsName</dd>
        </dl>
        <dl class="text-bg-light p-3 rounded-4 mb-2">
            <dt class="fw-semibold text-secondary mb-2">
                @Html.DisplayNameFor(m => m.Procurement.AnalystHteUserId)
                @if (procurement.AnalystHtePjs == true) { <span class="badge bg-warning text-dark ms-1">Pjs</span> }
            </dt>
            <dd class="fw-medium text-secondary-emphasis">@Model.AnalystName</dd>
        </dl>
        <dl class="text-bg-light p-3 rounded-4 mb-2">
            <dt class="fw-semibold text-secondary mb-2">
                @Html.DisplayNameFor(m => m.Procurement.AssistantManagerUserId)
                @if (procurement.AssistantManagerPjs == true) { <span class="badge bg-warning text-dark ms-1">Pjs</span> }
            </dt>
            <dd class="fw-medium text-secondary-emphasis">@Model.AssistantManagerName</dd>
        </dl>
        <dl class="text-bg-light p-3 rounded-4 mb-2">
            <dt class="fw-semibold text-secondary mb-2">
                @Html.DisplayNameFor(m => m.Procurement.ManagerUserId)
                @if (procurement.ManagerPjs == true) { <span class="badge bg-warning text-dark ms-1">Pjs</span> }
            </dt>
            <dd class="fw-medium text-secondary-emphasis">@Model.ManagerName</dd>
        </dl>
    </div>
</article>
