@model ProcurementHTE.Web.Models.ViewModels.ProcurementEditViewModel
@functions {
    string FormatDateValue(DateTime date)
    {
        return date == default ? "" : date.ToString("yyyy-MM-dd");
    }

    string FormatNullableDateValue(DateTime? date)
    {
        return date.HasValue && date.Value != default ? date.Value.ToString("yyyy-MM-dd") : "";
    }
}

<section class="card shadow-sm mb-3 p-2 rounded-4">
    <fieldset class="card-body">
        <legend class="card-title fw-semibold">Schedule &amp; Etc</legend>
        <hr />
        <div class="row g-3">
            <div class="col-md-3">
                <label asp-for="DocumentDate" class="form-label"></label>
                <input asp-for="DocumentDate" type="date" class="form-control" value="@FormatDateValue(Model.DocumentDate)" />
                <span asp-validation-for="DocumentDate" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="StartDate" class="form-label"></label>
                <input asp-for="StartDate" type="date" class="form-control" value="@FormatDateValue(Model.StartDate)" />
                <span asp-validation-for="StartDate" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="EndDate" class="form-label"></label>
                <input asp-for="EndDate" type="date" class="form-control" value="@FormatDateValue(Model.EndDate)" />
                <span asp-validation-for="EndDate" class="text-danger"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="PotentialAccrualDate" class="form-label"></label>
                <input asp-for="PotentialAccrualDate" type="date" class="form-control" value="@FormatNullableDateValue(Model.PotentialAccrualDate)" />
                <span asp-validation-for="PotentialAccrualDate" class="text-danger"></span>
            </div>
        </div>

        <div class="row g-3 mt-0">
            <div class="col-md-6">
                <label asp-for="LtcName" class="form-label"></label>
                <input asp-for="LtcName" class="form-control" maxlength="255" />
                <span asp-validation-for="LtcName" class="text-danger"></span>
            </div>
        </div>

        <div class="mt-3">
            <label asp-for="Note" class="form-label"></label>
            <textarea asp-for="Note" class="form-control" rows="3" maxlength="1000"></textarea>
            <span asp-validation-for="Note" class="text-danger"></span>
        </div>
    </fieldset>
</section>
