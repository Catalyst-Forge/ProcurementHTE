@model ProcurementDetailsPageViewModel

<article class="card shadow-sm mb-3 rounded-4">
    <header class="card-header fw-semibold bg-transparent border-bottom-0 mt-2">
        <h2 class="card-title mb-0 h5"><i class="bi bi-building-fill text-primary me-1"></i> Vendors Involved</h2>
    </header>
    <hr class="mx-3 my-2" />

    <div class="card-body">
        @if (Model.SelectedVendorNames.Any())
        {
            <div class="d-flex flex-wrap gap-2">
                @foreach (var name in Model.SelectedVendorNames)
                {
                    <span class="badge border rounded-5 text-secondary fw-medium px-3 py-2">@name</span>
                }
            </div>
        }
        else
        {
            <span class="text-muted">-</span>
        }
    </div>
</article>
