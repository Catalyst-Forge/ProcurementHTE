@model ProcurementDetailsPageViewModel

<article class="card shadow-sm mb-3 rounded-4">
    <header class="card-header mt-2 fw-semibold bg-transparent border-bottom-0">
        <h2 class="card-title mb-0 h5"><i class="bi bi-clipboard2-minus-fill text-primary me-1"></i> Job Information</h2>
    </header>
    <hr class="mx-3 my-2" />

    <div class="card-body">
        <div class="row mb-0">
            <dl class="col-12 col-sm-6 col-md-4 mb-2">
                <dt class="fw-semibold text-uppercase text-secondary">@Html.DisplayNameFor(m => m.Procurement.ContractType)</dt>
                <dd class="fw-medium text-secondary-emphasis">@Html.DisplayFor(m => m.Procurement.ContractType)</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-4 mb-2">
                <dt class="fw-semibold text-uppercase text-secondary">Job Type</dt>
                <dd class="fw-medium text-secondary-emphasis">@Model.JobTypeName</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-4 mb-2">
                <dt class="fw-semibold text-uppercase text-secondary">@Html.DisplayNameFor(m => m.Procurement.ProcurementCategory)</dt>
                <dd class="fw-medium text-secondary-emphasis">@Html.DisplayFor(m => m.Procurement.ProcurementCategory)</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-4 mb-2">
                <dt class="fw-semibold text-uppercase text-secondary">@Html.DisplayNameFor(m => m.Procurement.Wonum)</dt>
                <dd class="fw-medium text-secondary-emphasis">@Html.DisplayFor(m => m.Procurement.Wonum)</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-4 mb-2">
                <dt class="fw-semibold text-uppercase text-secondary">@Html.DisplayNameFor(m => m.Procurement.ProjectRegion)</dt>
                <dd class="fw-medium text-secondary-emphasis">@Html.DisplayFor(m => m.Procurement.ProjectRegion)</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-4 mb-2">
                <dt class="fw-semibold text-uppercase text-secondary">@Html.DisplayNameFor(m => m.Procurement.ProjectCode)</dt>
                <dd class="fw-medium text-secondary-emphasis">@Model.Procurement.ProjectCode</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-4 mb-2">
                <dt class="fw-semibold text-uppercase text-secondary">@Html.DisplayNameFor(m => m.Procurement.JobName)</dt>
                <dd class="fw-medium text-secondary-emphasis">@Html.DisplayFor(m => m.Procurement.JobName)</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-4 mb-2">
                <dt class="fw-semibold text-uppercase text-secondary">@Html.DisplayNameFor(m => m.Procurement.LtcName)</dt>
                <dd class="fw-medium text-secondary-emphasis">@Html.DisplayFor(m => m.Procurement.LtcName)</dd>
            </dl>
        </div>
    </div>
</article>
