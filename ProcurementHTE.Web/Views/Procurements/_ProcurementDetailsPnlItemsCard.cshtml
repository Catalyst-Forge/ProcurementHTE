@model ProcurementDetailsPageViewModel

<article class="card shadow-sm mb-3 rounded-4">
    <header class="card-header fw-semibold bg-transparent border-bottom-0 mt-2">
        <h2 class="card-title mb-0 h5"><i class="bi bi-list-ul text-primary me-1"></i> Item Details (Revenue)</h2>
    </header>
    <hr class="mx-3 my-2" />

    <div class="card-body">
        <div class="table-responsive rounded-3">
            @if (Model.IsPengangkutan)
            {
                @await Html.PartialAsync("_ProcurementDetailsPnlTransportItemsTable", Model)
            }
            else if (Model.IsSewaUnit)
            {
                @await Html.PartialAsync("_ProcurementDetailsPnlStandByItemsTable", Model)
            }
            else if (Model.IsMoving)
            {
                @await Html.PartialAsync("_ProcurementDetailsPnlMovingItemsTable", Model)
            }
        </div>
    </div>

    <div class="small text-muted px-3 pb-3">
        @if (Model.IsPengangkutan)
        {
            <text>KM/25 = (Distance - 400) / 25<br />Operator Cost per item = <em>Additional Rate × KM/25</em><br />Revenue per item = <em>(Base Price + Operator Cost) × UnitQty</em></text>
        }
        else if (Model.IsSewaUnit)
        {
            <text>Revenue per item = <em>Base Price × Durasi × Qty Items</em></text>
        }
        else if (Model.IsMoving)
        {
            <text>Revenue per item = <em>Base Price × Quantity × Qty Items</em></text>
        }
    </div>
</article>
