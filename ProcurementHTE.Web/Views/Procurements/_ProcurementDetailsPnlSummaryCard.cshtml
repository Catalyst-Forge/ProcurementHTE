@model ProcurementDetailsPageViewModel

@{
    var procurement = Model.Procurement;
    var pnl = Model.ProfitLoss!;
}

<article class="card shadow-sm mb-3 rounded-4">
    <header class="card-header fw-semibold bg-transparent border-bottom-0 mt-2">
        <h2 class="card-title mb-0 h5"><i class="bi bi-bar-chart text-primary me-1"></i> Profit &amp; Loss Statement and Summary</h2>
    </header>
    <hr class="mx-3 my-2" />

    <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="card-title mb-0 h6">Information</h3>
        </div>

        <div class="row g-3">
            <dl class="col-12 col-sm-6 col-md-3">
                <dt class="fw-semibold text-uppercase text-secondary">@Html.DisplayNameFor(m => m.Procurement.Wonum)</dt>
                <dd class="fw-medium text-secondary-emphasis">@Html.DisplayFor(m => m.Procurement.Wonum)</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-3">
                <dt class="fw-semibold text-uppercase text-secondary">WO Start</dt>
                <dd class="fw-medium text-secondary-emphasis">@procurement.StartDate.ToTanggalIndonesia()</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-3">
                <dt class="fw-semibold text-uppercase text-secondary">WO Create</dt>
                <dd class="fw-medium text-secondary-emphasis">@procurement.CreatedAt.ToTanggalIndonesia()</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-3">
                <dt class="fw-semibold text-uppercase text-secondary">Vendor</dt>
                <dd class="fw-medium text-secondary-emphasis">@pnl.SelectedVendorName</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-3">
                <dt class="fw-semibold text-uppercase text-secondary">@Html.DisplayNameFor(m => m.Procurement.Status)</dt>
                <dd class="fw-medium text-secondary-emphasis">@Html.DisplayFor(m => m.Procurement.Status!.StatusName)</dd>
            </dl>
            @if (Model.IsPengangkutan)
            {
                <dl class="col-12 col-sm-6 col-md-3">
                    <dt class="fw-semibold text-uppercase text-secondary">@Html.DisplayNameFor(m => pnl.Distance)</dt>
                    <dd class="fw-medium text-secondary-emphasis">@pnl.Distance KM</dd>
                </dl>
            }
            <dl class="col-12 col-sm-6 col-md-3">
                <dt class="fw-semibold text-uppercase text-secondary">Job Type</dt>
                <dd class="fw-medium text-secondary-emphasis">@Model.JobTypeName</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-3">
                <dt class="fw-semibold text-uppercase text-secondary">Profit & Loss Create</dt>
                <dd class="fw-medium text-secondary-emphasis">@pnl.CreatedAt.ToTanggalIndonesia()</dd>
            </dl>
        </div>

        <hr class="mt-1 mb-4" />

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3 class="card-title mb-0 h6">Summary</h3>
            <a asp-action="EditProfitLoss" asp-route-id="@pnl.ProfitLossId" class="btn btn-outline-primary">
                <i class="bi bi-arrow-repeat"></i> Recount
            </a>
        </div>

        <div class="row g-3">
            <dl class="col-12 col-sm-6 col-md-4">
                <dt class="fw-semibold text-uppercase text-secondary">@Html.DisplayNameFor(m => pnl.AccrualAmount)</dt>
                <dd class="fw-medium text-secondary-emphasis">@pnl.AccrualAmount.ToIDR()</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-4">
                <dt class="fw-semibold text-uppercase text-secondary">@Html.DisplayNameFor(m => pnl.RealizationAmount)</dt>
                <dd class="fw-medium text-secondary-emphasis">@pnl.RealizationAmount.ToIDR()</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-4">
                <dt class="fw-semibold text-uppercase text-secondary">Best Vendor</dt>
                <dd class="text-success fw-medium">@pnl.SelectedVendorName</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-4">
                <dt class="fw-semibold text-uppercase text-secondary">Total Revenue</dt>
                <dd class="fw-bold">@((pnl.Items?.Sum(x => x.Revenue) ?? 0m).ToIDR())</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-4">
                <dt class="fw-semibold text-uppercase text-secondary">Final Offer</dt>
                <dd class="fw-medium text-secondary-emphasis">@pnl.SelectedFinalOffer.ToIDR()</dd>
                <dd class="small text-muted">(Σ minimum price per item)</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-4">
                <dt class="fw-semibold text-uppercase text-secondary">Profit</dt>
                <dd class="fw-bold text-success">@pnl.Profit.ToIDR() (@pnl.ProfitPercent.ToPersen())</dd>
                <dd class="small text-muted">= Total Revenue - Final Offer</dd>
            </dl>
        </div>
    </div>
</article>
