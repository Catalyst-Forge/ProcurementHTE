@model ProcurementDetailsPageViewModel

@{
    var pnl = Model.ProfitLoss;
}

<article class="card shadow-sm mb-3 rounded-4">
    <header class="card-header mt-2 fw-semibold bg-transparent border-bottom-0">
        <h2 class="card-title mb-0 h5"><i class="bi bi-calendar-check text-primary me-1"></i> Schedule & Financials</h2>
    </header>
    <hr class="mx-3 my-2" />

    <div class="card-body">
        <div class="row mb-0">
            <dl class="col-12 col-sm-6 col-md-4 mb-2">
                <dt class="fw-semibold text-uppercase text-secondary">@Html.DisplayNameFor(m => m.Procurement.StartDate)</dt>
                <dd class="fw-medium text-secondary-emphasis">@Model.Procurement.StartDate.ToTanggalIndonesia()</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-4 mb-2">
                <dt class="fw-semibold text-uppercase text-secondary">@Html.DisplayNameFor(m => m.Procurement.EndDate)</dt>
                <dd class="fw-medium text-secondary-emphasis">@Model.Procurement.EndDate.ToTanggalIndonesia()</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-4 mb-2">
                <dt class="fw-semibold text-uppercase text-secondary">@Html.DisplayNameFor(m => m.Procurement.PotentialAccrualDate)</dt>
                <dd class="fw-medium text-secondary-emphasis">@Model.Procurement.PotentialAccrualDate.ToTanggalIndonesia()</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-4 mb-2">
                <dt class="fw-semibold text-uppercase text-secondary">Accrual Amount</dt>
                <dd class="fw-medium text-secondary-emphasis">@(pnl?.AccrualAmount.ToIDR() ?? "-")</dd>
            </dl>
            <dl class="col-12 col-sm-6 col-md-4 mb-2">
                <dt class="fw-semibold text-uppercase text-secondary">Realization Amount</dt>
                <dd class="fw-medium text-secondary-emphasis">@(pnl?.RealizationAmount.ToIDR() ?? "-")</dd>
            </dl>
        </div>
    </div>
</article>
