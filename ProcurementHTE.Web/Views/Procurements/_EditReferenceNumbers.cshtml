@model ProcurementHTE.Web.Models.ViewModels.ProcurementEditViewModel

<section class="card shadow-sm mb-3 p-2 rounded-4">
    <fieldset class="card-body">
        <legend class="card-title fw-semibold">Reference Numbers</legend>
        <hr />
        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="SpkNumber" class="form-label"></label>
                <input asp-for="SpkNumber" class="form-control" maxlength="100" />
                <span asp-validation-for="SpkNumber" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="SpmpNumber" class="form-label"></label>
                <div class="input-group">
                    <input asp-for="SpmpNumber" class="form-control" maxlength="50" placeholder="e.g., 4514" />
                    <span class="input-group-text">/PDC-1110/@DateTime.Now.Year-S0</span>
                </div>
                <small class="form-text text-muted">Masukkan angka/kode saja (contoh: 4514)</small>
                <span asp-validation-for="SpmpNumber" class="text-danger"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="MemoNumber" class="form-label"></label>
                <input asp-for="MemoNumber" class="form-control" maxlength="100" />
                <span asp-validation-for="MemoNumber" class="text-danger"></span>
            </div>
        </div>

        <div class="row g-3 mt-0">
            <div class="col-md-6">
                <label asp-for="OeNumber" class="form-label"></label>
                <div class="input-group">
                    <input asp-for="OeNumber" class="form-control" maxlength="50" placeholder="e.g., OE-TRS" />
                    <span class="input-group-text">/PDC-1110/@DateTime.Now.Year-S0</span>
                </div>
                <small class="form-text text-muted">Masukkan prefix saja (contoh: OE-TRS)</small>
                <span asp-validation-for="OeNumber" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="RaNumber" class="form-label"></label>
                <input asp-for="RaNumber" class="form-control" maxlength="100" />
                <span asp-validation-for="RaNumber" class="text-danger"></span>
            </div>
        </div>

        <div class="row g-3 mt-0">
            <div class="col-md-6">
                <label asp-for="NoRig" class="form-label"></label>
                <input asp-for="NoRig" class="form-control" maxlength="100" placeholder="Masukkan No. Rig" />
                <span asp-validation-for="NoRig" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="NoHte" class="form-label"></label>
                <input asp-for="NoHte" class="form-control" maxlength="100" placeholder="Masukkan No. HTE" />
                <span asp-validation-for="NoHte" class="text-danger"></span>
            </div>
        </div>
    </fieldset>
</section>
