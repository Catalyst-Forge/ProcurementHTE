@using Microsoft.AspNetCore.Authorization
@using ProcurementHTE.Core.Authorization
@using ProcurementHTE.Core.Models
@inject IAuthorizationService AuthZ
@model Procurement

@{
    ViewData["Title"] = "Procurement Details";

    var pnl = ViewBag.PnlViewModel as ProfitLossSummaryViewModel;
    var documents = ViewBag.Documents as IReadOnlyList<ProcDocuments> ?? [];
    var statusName = Model?.Status?.StatusName;
    var canEdit = await AuthZ.AuthorizeAsync(User, Permissions.Procurement.Edit);

    var prePickupStatuses = new[] { "Draft", "Created", "Waiting Pickup" };
    var isPrePickup = prePickupStatuses.Contains(statusName, StringComparer.OrdinalIgnoreCase);
    var earlyEditRoles = new[] { "Admin", "Operation", "Assistant Manager HTE" };
    var lateEditRoles = new[] { "AR", "AP-Invoice", "Analyst HTE & LTS", "Supply Chain Management" };
    var userRoles = User.Claims
        .Where(c => c.Type == System.Security.Claims.ClaimTypes.Role)
        .Select(c => c.Value)
        .ToList();
    var hasEarlyEditRole = userRoles.Any(r => earlyEditRoles.Contains(r, StringComparer.OrdinalIgnoreCase));
    var hasLateEditRole = userRoles.Any(r => lateEditRoles.Contains(r, StringComparer.OrdinalIgnoreCase));
    var canEditByStatus = hasEarlyEditRole
        || (!isPrePickup && hasLateEditRole)
        || (!hasLateEditRole && !hasEarlyEditRole);

    var page = new ProcurementDetailsPageViewModel
    {
        Procurement = Model!,
        ProfitLoss = pnl,
        Documents = documents,
        PicOpsName = ViewBag.PicOpsName as string ?? Model?.PicOpsUserId,
        AnalystName = ViewBag.AnalystName as string ?? Model?.AnalystHteUserId,
        AssistantManagerName = ViewBag.AssistantManagerName as string ?? Model?.AssistantManagerUserId,
        ManagerName = ViewBag.ManagerName as string ?? Model?.ManagerUserId,
        CanPublish = pnl != null && statusName == "Created",
        CanUnpublish = statusName == "Waiting Pickup",
        CanEditDelete = (statusName == "Created" || statusName == "Draft")
            && canEdit.Succeeded
            && canEditByStatus
    };
}

@await Html.PartialAsync("_ProcurementDetailsHeader", page)

<div class="tab-content" id="myTabContent">
    @await Html.PartialAsync("_ProcurementDetailsInfoTab", page)
    @await Html.PartialAsync("_ProcurementDetailsProfitLossTab", page)
    @await Html.PartialAsync("_ProcurementDetailsDocumentsTab", page)
</div>

@await Html.PartialAsync("_ProcurementDetailsForms", page)
@await Html.PartialAsync("_ProcurementDetailsPdfModal")

@section Scripts {
    <script>
        window.procurementDetailsConfig = {
            previewUrlTemplate: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Url.Action("PreviewUrl", "ProcurementDocuments", new { id = "__DOC_ID__", procurementId = Model?.ProcurementId })))
        };
    </script>
    <script src="~/js/procurements/details/core.js" asp-append-version="true"></script>
    <script src="~/js/procurements/details/preview.js" asp-append-version="true"></script>
    <script src="~/js/procurements/details/actions.js" asp-append-version="true"></script>
    <script src="~/js/procurements/details/boot.js" asp-append-version="true"></script>
}

@section HeadScripts {
    <link rel="stylesheet" href="~/css/procurement-details.css" asp-append-version="true" />
}
